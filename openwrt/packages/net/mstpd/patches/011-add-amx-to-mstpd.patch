diff --git a/amx.c b/amx.c
new file mode 100644
index 0000000..acb8117
--- /dev/null
+++ b/amx.c
@@ -0,0 +1,306 @@
+#include <stdlib.h>
+#include <amxc/amxc.h>
+#include <amxp/amxp.h>
+#include <amxp/amxp_dir.h>
+#include <amxd/amxd_dm.h>
+#include <amxd/amxd_types.h>
+#include <amxd/amxd_object.h>
+#include <amxd/amxd_object_event.h>
+#include <amxb/amxb_register.h>
+#include <amxb/amxb.h>
+#include <amxo/amxo.h>
+#include <string.h>
+
+#include "log.h"
+#include "epoll_loop.h"
+
+static amxd_object_t *root;
+static amxo_parser_t parser;
+static amxd_dm_t dm;
+static int (* handle_rpc)(amxc_var_t *args, amxc_var_t *ret);
+static amxo_hooks_t amxrt_hooks;
+static struct epoll_event_handler signal_read_handler;
+
+#define ATTR_UNUSED(X) X __attribute__((unused)) 
+
+#define COPT_NAME "name"
+#define COPT_BACKENDS "backends"
+#define COPT_BACKENDS_DIR "backend-dir"
+#define COPT_INCDIRS "include-dirs"
+#define COPT_LIBDIRS "import-dirs"
+#define COPT_MIBDIRS "mib-dirs"
+#define COPT_URIS "uris"
+
+#define BACKEND_DIR "/usr/bin/mods/amxb"
+
+static amxd_status_t _STPControl(amxd_object_t * ATTR_UNUSED(object),
+                                     amxd_function_t * ATTR_UNUSED(func),
+                                     amxc_var_t *args,
+                                     amxc_var_t *ret) 
+{
+    int rv = -1;
+    rv = handle_rpc(args, ret);
+    return rv == 0 ? amxd_status_ok : amxd_status_unknown_error;
+}
+
+static int config_add_backend(const char *name, void *priv) 
+{
+    amxc_var_t *backends = (amxc_var_t*) priv;
+    amxc_var_add(cstring_t, backends, name);
+    return 0;
+}
+
+static void config_build(amxo_parser_t *parser) 
+{
+    amxc_var_t *config = &parser->config;
+    amxc_var_t *backends = NULL;
+    amxc_var_t *connections = NULL;
+    struct stat sb;
+
+    backends = amxc_var_add_key(amxc_llist_t, config, COPT_BACKENDS, NULL);
+    connections = amxc_var_add_key(amxc_llist_t, config, COPT_URIS, NULL);
+    amxc_var_add_key(cstring_t, config, COPT_BACKENDS_DIR, BACKEND_DIR);
+
+    // set hooks to monitor config option changes
+    memset(&amxrt_hooks, 0, sizeof(amxo_hooks_t));
+    amxo_parser_set_hooks(parser, &amxrt_hooks);
+
+    amxc_var_add_key(cstring_t, &parser->config, COPT_NAME, "unbound");
+
+    amxp_dir_scan(BACKEND_DIR, "d_name matches '.*\\.so'", false, config_add_backend, backends);
+
+    // for now only ubus as backend
+    if((stat("/var/run/ubus.sock", &sb) == 0) || (stat("/var/run/ubus/ubus.sock", &sb) == 0)) 
+    {
+        if(stat("/var/run/ubus.sock", &sb) == 0)
+        {	
+            amxc_var_add(cstring_t, connections, "ubus:/var/run/ubus.sock");
+	}
+	else
+        {	
+            amxc_var_add(cstring_t, connections, "ubus:/var/run/ubus/ubus.sock");
+        }
+    }
+}
+
+static int connection_load_backends(amxc_var_t *config) 
+{
+    int retval = -1;
+    amxc_var_t *backends = GET_ARG(config, COPT_BACKENDS);
+
+    if(amxc_var_type_of(backends) == AMXC_VAR_ID_LIST) 
+    {
+        const amxc_llist_t *bel = amxc_var_constcast(amxc_llist_t, backends);
+        if(amxc_llist_is_empty(bel))
+        {	
+            goto exit;
+        }
+    }
+
+    retval = amxb_be_load_multiple(backends);
+    if(retval != 0) 
+    {
+        goto exit;
+    }
+
+exit:
+    amxb_set_config(config);
+    return retval;
+}
+
+static void el_amxp_signal_read_cb(uint32_t events, struct epoll_event_handler *p) 
+{
+    amxp_signal_read();
+}
+
+static void el_connection_read_cb(uint32_t events, struct epoll_event_handler *p) 
+{
+    amxo_connection_t* con = (amxo_connection_t*) p->arg;
+    con->reader(p->fd, con->priv);
+}
+
+static void el_add_read_fd(amxc_llist_t *connections) 
+{
+    amxc_llist_for_each(it, connections) 
+    {
+        amxo_connection_t *con = amxc_llist_it_get_data(it, amxo_connection_t, it);
+	struct epoll_event_handler *conn_read_handler = calloc(1, sizeof(struct epoll_event_handler));
+        conn_read_handler->fd = con->fd;
+	conn_read_handler->arg = con;
+        conn_read_handler->handler = el_connection_read_cb;
+
+	add_epoll(conn_read_handler);
+	con->el_data = conn_read_handler;
+    }
+}
+
+static void connection_read(int ATTR_UNUSED(fd), void *priv) 
+{
+    amxb_bus_ctx_t *bus_ctx = (amxb_bus_ctx_t*) priv;
+    if(amxb_is_data_socket(bus_ctx)) 
+    {
+        amxb_read(bus_ctx);
+    }
+}
+
+static int el_create_events(amxo_parser_t *parser) 
+{
+    int retval = -1;
+    int fd = -1;
+
+    fd = amxp_signal_fd();
+    signal_read_handler.fd = fd;
+    signal_read_handler.handler = el_amxp_signal_read_cb;
+
+    retval = add_epoll(&signal_read_handler);
+    if (retval != 0) 
+    {
+        ERROR("Failed to add signal fd to epoll fd");
+    	goto exit;
+    }
+
+    el_add_read_fd(amxo_parser_get_connections(parser));
+
+    retval = 0;
+exit:
+    return retval;
+}
+
+static int connection_connect_all(amxo_parser_t *parser) 
+{
+    int retval = 0;
+    const amxc_llist_t *uris = amxc_var_constcast(amxc_llist_t, GET_ARG(&parser->config, COPT_URIS));
+
+    amxc_llist_for_each(it, uris) 
+    {
+        amxb_bus_ctx_t *bus_ctx = NULL;
+        int fd = -1;
+        const char* uri = GET_CHAR(amxc_var_from_llist_it(it), NULL);
+
+        retval = amxb_connect(&bus_ctx, uri);
+        if(retval != 0) 
+	{
+	    ERROR("Failed to connect to uri %s", uri);
+            break;
+        }
+
+	fd = amxb_get_fd(bus_ctx);
+        amxo_connection_add(parser, fd, connection_read, uri, AMXO_BUS, bus_ctx);
+    }
+
+    return retval;
+}
+
+static int connection_register_dm(amxo_parser_t *parser, amxd_dm_t *dm) 
+{
+    int retval = 0;
+    amxc_llist_t *connections = amxo_parser_get_connections(parser);
+    amxc_llist_for_each(it, connections) 
+    {
+        amxo_connection_t *con = amxc_llist_it_get_data(it, amxo_connection_t, it);
+        amxb_bus_ctx_t *bus_ctx = (amxb_bus_ctx_t*) con->priv;
+        if(con->type != AMXO_BUS) 
+	{
+            ERROR("con type is not AMXO_BUS but %d instead", con->type);
+	    continue;
+        }
+        
+	retval = amxb_register(bus_ctx, dm);
+        if(retval != 0) 
+	{
+	    ERROR("Failed to register dm, %d", retval);
+            goto leave;
+        }
+    }
+
+leave:
+    return retval;
+}
+
+static int el_destroy(amxo_parser_t *parser) 
+{
+    remove_epoll(&signal_read_handler);
+
+    amxc_llist_for_each(it, amxo_parser_get_connections(parser)) 
+    {
+        amxo_connection_t *con = amxc_llist_it_get_data(it, amxo_connection_t, it);
+        struct epoll_event_handler *handler = (struct epoll_event_handler*) con->el_data;
+        if(handler != NULL) 
+	{
+            remove_epoll(handler);
+            free(handler);
+	    con->el_data = NULL;
+        }
+    }
+
+    return 0;
+}
+
+int connect_with_amx(int (* rpc_cb)(amxc_var_t *args, amxc_var_t *ret)) 
+{
+    int retval = -1;
+    const char *odl =
+        "%config {"
+        "}"
+        "%define {"
+        "    object MSTPD {"
+        "        void STPControl(%in %mandatory htable arguments);"
+        "    }"
+        "}"
+        "%populate {"
+        "}";
+
+    handle_rpc = rpc_cb;
+
+    amxd_dm_init(&dm);
+    amxo_parser_init(&parser);
+    config_build(&parser);
+    root = amxd_dm_get_root(&dm);
+    amxo_resolver_ftab_add(&parser, "STPControl", AMXO_FUNC(_STPControl));
+    retval = amxo_parser_parse_string(&parser, odl, root);
+    if(retval != 0) 
+    {
+	ERROR("Failed to parse odl string: %d", retval);
+        return retval;
+    }
+    amxp_sigmngr_enable(&dm.sigmngr, true);
+
+    connection_load_backends(&parser.config);
+    retval = connection_connect_all(&parser);
+    if(retval != 0) 
+    {
+	ERROR("Failed to connect all backends, %d", retval);
+        return retval;
+    }
+
+    retval = el_create_events(&parser);
+    if(retval != 0) 
+    {
+        ERROR("Failed to add signal_read_handler to epoll event loop, %d", retval);
+        return retval;
+    }
+
+    retval = connection_register_dm(&parser, &dm);
+    if(retval != 0) 
+    {
+        ERROR("Failed to register connection to dm, %d", retval);
+        return retval;
+    }
+
+    amxd_object_t* obj = amxd_dm_findf(&dm, "MSTPD.");
+    if(obj == NULL) 
+    {
+        ERROR("MSTPD object is NULL");
+	retval = -1;
+    }
+    return retval;
+}
+
+void delete_amx(void) 
+{
+    el_destroy(&parser);
+    amxd_dm_clean(&dm);
+    amxo_parser_clean(&parser);
+    amxb_be_remove_all();
+}
+
