 #include "bridge_ctl.h"
 #include "ctl_functions.h"
@@ -40,7 +41,9 @@
 #include "mstp.h"
 #include "driver.h"
 #include "libnetlink.h"
+#include "amx.h"
 
+#define SYSFS_PATH_MAX 256
 #ifndef SYSFS_CLASS_NET
 #define SYSFS_CLASS_NET "/sys/class/net"
 #endif
@@ -928,3 +931,170 @@ int bridge_track_fini(void)
     }
     return 0;
 }
+
+static int not_dot_dotdot(const struct dirent *entry)
+{
+    const char *n = entry->d_name;
+
+    return !('.' == n[0] && (0 == n[1] || ('.' == n[1] && 0 == n[2])));
+}
+
+static int get_port_list(const char *br_ifname, struct dirent ***namelist)
+{
+    int res;
+    char buf[SYSFS_PATH_MAX];
+
+    /* strlen(sysfs_class_net) + strlen("/%.230s/brif") must be < sizeof(buf)
+       to prevent truncation ; gcc7's fortify headers complain about that */
+    snprintf(buf, sizeof(buf), SYSFS_CLASS_NET "/%.230s/brif", br_ifname);
+    if(0 > (res = scandir(buf, namelist, not_dot_dotdot, versionsort)))
+        fprintf(stderr, "Error getting list of all ports of bridge %s\n",
+                br_ifname);
+    return res;
+}
+
+static int add_bridge(const char *if_name)
+{
+    int j, res, ifcount = 0;
+    int* br_array = NULL;
+    int* ifaces_lists = NULL;
+    struct dirent **namelist;
+
+    br_array = calloc(1, 2 * sizeof(int));
+    if (NULL == br_array)
+    {
+        fprintf(stderr, "out of memory, bridge %s\n",
+                if_name);
+	goto ifaces_error_exit;
+    }
+
+    br_array[0] = 1;
+    br_array[1] = if_nametoindex(if_name); 
+
+    if(0 > (ifcount = get_port_list(if_name, &namelist)))
+    {
+ifaces_error_exit:
+        free(ifaces_lists);
+	free(br_array);
+        return ifcount;
+    }
+
+    if(NULL == (ifaces_lists = malloc((ifcount + 1) * sizeof(int))))
+    {
+        fprintf(stderr, "out of memory, bridge %s, ifcount = %d\n",
+                if_name, ifcount);
+        for(j = 0; j < ifcount; ++j)
+	{
+            free(namelist[j]);
+	}
+        free(namelist);
+        ifcount = -1;
+        goto ifaces_error_exit;
+    }
+
+    ifaces_lists[0] = ifcount;
+    for(j = 1; j <= ifcount; ++j)
+    {
+        ifaces_lists[j] = if_nametoindex(namelist[j - 1]->d_name);
+        free(namelist[j - 1]);
+    }
+    free(namelist);
+
+    res = CTL_add_bridges(br_array, &ifaces_lists);
+    
+    free(ifaces_lists);
+    free(br_array);
+    return res;
+}
+
+static int del_bridge(const char *if_name)
+{
+    int* br_array = NULL;
+    int res = 0;
+
+    br_array = calloc(1, 2 * sizeof(int));
+    if (NULL == br_array)
+    {
+        fprintf(stderr, "out of memory, bridge %s\n",
+                if_name);
+	goto exit;
+    }
+
+    br_array[0] = 1;
+    br_array[1] = if_nametoindex(if_name);
+
+    res = CTL_del_bridges(br_array);
+exit:
+    free(br_array);
+    return res;
+}
+
+static int set_stp_params(const char *if_name, amxc_var_t *params)
+{
+    CIST_BridgeConfig config = {0};
+    int br_index = if_nametoindex(if_name);
+    int rv = -1;
+
+    if(br_index == 0) 
+    {
+        ERROR("Bridge %s not recognized", if_name);
+        goto exit;
+    }
+
+    config.bridge_max_age = GET_UINT32(params, "MaxAge");
+    config.set_bridge_max_age = (amxc_var_get_key(params, "MaxAge", AMXC_VAR_FLAG_DEFAULT) != NULL);
+
+    config.bridge_forward_delay = GET_UINT32(params, "ForwardingDelay");
+    config.set_bridge_forward_delay = (amxc_var_get_key(params, "ForwardingDelay", AMXC_VAR_FLAG_DEFAULT) != NULL);
+
+    config.bridge_hello_time = GET_UINT32(params, "HelloTime");
+    config.set_bridge_hello_time = (amxc_var_get_key(params, "HelloTime", AMXC_VAR_FLAG_DEFAULT) != NULL);
+
+    config.bridge_ageing_time = GET_UINT32(params, "AgingTime");
+    config.set_bridge_ageing_time = (amxc_var_get_key(params, "AgingTime", AMXC_VAR_FLAG_DEFAULT) != NULL);
+
+    rv = CTL_set_cist_bridge_config(br_index, &config);
+    if(rv != 0) 
+    {
+        ERROR("Error configuring STP parameters for bridge %s", if_name);
+    }
+
+exit:
+    return rv;
+}
+
+int rpc_cb(amxc_var_t *args, amxc_var_t *ret)
+{
+    amxc_var_t *params = GET_ARG(args, "arguments");
+    const char *if_name = GET_CHAR(params, "bridge_name");
+    int rv = -1;
+
+    if(if_name == NULL)
+    {
+        goto exit;
+    }
+    if (amxc_var_get_key(params, "Enable", AMXC_VAR_FLAG_DEFAULT) != NULL) 
+    {
+	if(GET_BOOL(params, "Enable"))
+	{
+            rv = add_bridge(if_name);
+	    if(rv != 0)
+    	    {
+        	ERROR("Failed to add bridge %s to mstpd", if_name);
+        	goto exit;
+    	    }
+        } 
+	else
+	{
+	    del_bridge(if_name);
+	    rv = 0;
+	    goto exit;
+        }
+    }
+
+    rv = set_stp_params(if_name, params);
+
+exit:
+    return rv;
+}
+
