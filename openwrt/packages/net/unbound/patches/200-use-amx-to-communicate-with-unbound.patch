-void 
+int
+handle_amx_rpc(amxc_var_t* args, amxc_var_t* ret, void* priv)
+{
+    struct daemon_remote fakerc;
+    struct worker* worker = (struct worker*) priv;
+    RES fakessl;
+    int fd[2] = {-1, -1};
+    int rbuf;
+    char buf[100];
+
+    memset(&fakessl, 0, sizeof(RES));
+    if(pipe(fd) != 0) {
+        log_err("failed to open pipe");
+        goto exit;
+    }
+    fakessl.fd = fd[1];
+    fcntl(fd[0], F_SETFL, fcntl(fd[0], F_GETFL) | O_NONBLOCK);
+
+    memset(&fakerc, 0, sizeof(struct daemon_remote));
+    fakerc.worker = worker;
+
+    execute_cmd(&fakerc, &fakessl, (char*)GET_CHAR(args, "cmd"), worker);
+
+    memset(buf, 0, sizeof(buf));
+
+    rbuf = read(fd[0], buf, sizeof(buf) - 1);
+    if(rbuf > 0) {
+        amxc_var_set(cstring_t, ret, buf);
+    }
+
+    for(size_t i = 0; i<sizeof(fd)/sizeof(fd[0]); i++) {
+        close(fd[i]);
+    }
+exit:
+    return 0;
+}
+
+void
 daemon_remote_exec(struct worker* worker)
 {
 	/* read the cmd string */
