+addrtostr(struct sockaddr_storage* addr, char* dest, size_t destlen)
+{
+	int af = (int)((struct sockaddr_in*)addr)->sin_family;
+	void* sinaddr = &((struct sockaddr_in*)addr)->sin_addr;
+	if(af == AF_INET6) {
+		sinaddr = &((struct sockaddr_in6*)addr)->sin6_addr;
