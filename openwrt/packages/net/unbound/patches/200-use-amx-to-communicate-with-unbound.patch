+    amxb_bus_ctx_t* bus_ctx = (amxb_bus_ctx_t*) priv;
+
+    if(amxb_is_data_socket(bus_ctx)) {
+        amxb_read(bus_ctx);
+    } else {
+        log_err("failed connection_read");
+    }
+}
+
+static int connection_connect_all(amxo_parser_t* parser) {
+    int retval = 0;
+    const amxc_llist_t* uris = amxc_var_constcast(amxc_llist_t, GET_ARG(&parser->config, COPT_URIS));
+
+    amxc_llist_for_each(it, uris) {
+        amxb_bus_ctx_t* bus_ctx = NULL;
+        int fd = -1;
+        const char* uri = GET_CHAR(amxc_var_from_llist_it(it), NULL);
+
+        retval = amxb_connect(&bus_ctx, uri);
+        if(retval != 0) {
+            log_err("failed amxb_connect %s", uri);
+            break;
+        }
+
+        fd = amxb_get_fd(bus_ctx);
+        amxo_connection_add(parser, fd, connection_read, uri, AMXO_BUS, bus_ctx);
+    }
+
+    return retval;
+}
+
+static int connection_register_dm(amxo_parser_t* parser, amxd_dm_t* dm) {
+    int retval = 0;
+    amxc_llist_t* connections = amxo_parser_get_connections(parser);
+
+    amxc_llist_for_each(it, connections) {
+        amxo_connection_t* con = amxc_llist_it_get_data(it, amxo_connection_t, it);
+        amxb_bus_ctx_t* bus_ctx = (amxb_bus_ctx_t*) con->priv;
+        if(con->type != AMXO_BUS) {
+            continue;
+        }
+        retval = amxb_register(bus_ctx, dm);
+        if(retval != 0) {
+            log_err("failed amxb_register %s", con->uri);
+            goto leave;
+        }
+    }
+
+leave:
+    return retval;
+}
+
+void el_connection_read_cb(int fd, short ATTR_UNUSED(flags), void* arg) {
+    amxo_connection_t* con = (amxo_connection_t*) arg;
+    con->reader(fd, con->priv);
+}
+
+static void el_add_read_fd(struct ub_event_base* base, amxc_llist_t* connections) {
+    amxc_llist_for_each(it, connections) {
+        amxo_connection_t* con = amxc_llist_it_get_data(it, amxo_connection_t, it);
+        el_data_t* el_data = (el_data_t*) calloc(1, sizeof(el_data_t));
+        if(el_data != NULL) {
+            el_data->read = ub_event_new(base, con->fd, UB_EV_READ | UB_EV_PERSIST,
+                                         el_connection_read_cb, con);
+
+            ub_event_add(el_data->read, NULL);
+            con->el_data = el_data;
+        }
+    }
+}
+
+void el_amxp_signal_read_cb(int ATTR_UNUSED(fd), short ATTR_UNUSED(flags), void* ATTR_UNUSED(arg)) {
+    amxp_signal_read();
+}
+
+static int el_create_events(struct ub_event_base* base, amxo_parser_t* parser) {
+    int retval = -1;
+
+    amxp_sig = ub_event_new(base, amxp_signal_fd(), UB_EV_READ | UB_EV_PERSIST,
+                            el_amxp_signal_read_cb, NULL);
+    if(!amxp_sig) {
+        log_err("could not ub_event_new");
+        goto exit;
+    }
+    if(ub_event_add(amxp_sig, NULL) != 0) {
+        log_err("could not ub_event_add");
+        goto exit;
+    }
+
+    el_add_read_fd(base, parser->connections);
+
+    retval = 0;
+exit:
+    return retval;
+}
+
+static int el_destroy(amxo_parser_t* parser) {
+    if(amxp_sig != NULL) {
+        ub_event_del(amxp_sig);
+        free(amxp_sig);
+        amxp_sig = NULL;
+    }
+
+    amxc_llist_for_each(it, parser->connections) {
+        amxo_connection_t* con = amxc_llist_it_get_data(it, amxo_connection_t, it);
+        el_data_t* el_data = (el_data_t*) con->el_data;
+        if(el_data != NULL) {
+            if(el_data->read != NULL) {
+                ub_event_del(el_data->read);
+                free(el_data->read);
+            }
+            free(el_data);
+            con->el_data = NULL;
+        }
+    }
+
+    return 0;
+}
+
+int connect_with_amx(size_t msg_buffer_size, struct ub_event_base* base, int (* rpc_cb)(amxc_var_t* args, amxc_var_t* ret, void* priv), void* priv) {
+    int retval = -1;
+    const char* odl =
+        "%config {"
+        "}"
+        "%define {"
+        "    object Unbound {"
+        "        void UnboundControl(%in %mandatory string cmd);"
+        "        event \"unbound:client-response\";"
+        "    }"
+        "}"
+        "%populate {"
+        "}";
+
+    scratch = regional_create_custom(msg_buffer_size);
+
+    handle_rpc = rpc_cb;
+    handle_rpc_priv = priv;
+
+    amxd_dm_init(&dm);
+    amxo_parser_init(&parser);
+    config_build(&parser);
+    root = amxd_dm_get_root(&dm);
+    amxo_resolver_ftab_add(&parser, "UnboundControl", AMXO_FUNC(_UnboundControl));
+    retval = amxo_parser_parse_string(&parser, odl, root);
+    if(retval != 0) {
+        log_err("failed to parse odl");
+        return 0;
+    }
+    amxp_sigmngr_enable(&dm.sigmngr, true);
+
+    connection_load_backends(&parser.config);
+    retval = connection_connect_all(&parser);
+    if(retval != 0) {
+        return 0;
+    }
+
+    el_create_events(base, &parser);
+    connection_register_dm(&parser, &dm);
+
+    return 1;
+}
+
+void delete_amx(void) {
+    el_destroy(&parser);
+    amxd_dm_clean(&dm);
+    amxo_parser_clean(&parser);
+    amxb_be_remove_all();
+}
+
+void send_amx_event_for_buffer(struct sockaddr_storage* addr, struct sldns_buffer* pkt) {
+    struct msg_parse* prs = NULL;
+    uint32_t rcode = 0;
+    amxd_object_t* object = amxd_dm_findf(get_dm(), "Unbound.");
+
+    prs = (struct msg_parse*) regional_alloc(scratch, sizeof(struct msg_parse));
+    memset(prs, 0, sizeof(*prs));
+    parse_packet(pkt, prs, scratch);
+    rcode = FLAGS_GET_RCODE(prs->flags);
+
+    if(rcode == LDNS_RCODE_SERVFAIL) { // to avoid events for each query response
+        char qname_buf[LDNS_MAX_DOMAINLEN + 1];
+        amxc_var_t data;
+        char buf[100];
+
+        amxc_var_init(&data);
+        amxc_var_set_type(&data, AMXC_VAR_ID_HTABLE);
+        amxc_var_add_key(uint32_t, &data, "rcode", rcode);
+        dname_str(prs->qname, qname_buf);
+        amxc_var_add_key(cstring_t, &data, "qname", qname_buf);
+        addrtostr(addr, buf, sizeof(buf));
+        amxc_var_add_key(cstring_t, &data, "addr", buf);
+
+        amxd_object_emit_signal(object, "unbound:client-response", &data);
+
+        amxc_var_clean(&data);
+    }
+
+    regional_free_all(scratch);
+}
