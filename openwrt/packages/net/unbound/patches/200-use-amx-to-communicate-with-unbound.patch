+/** Do the local_datas command */
+static void
+do_datas_add2(RES* ssl, struct local_zones* zones)
+{
+	int num = 0, line = 0;
+	char* rr;
+	while((rr = strtok(NULL, ","))) {
+		line++;
+		if(perform_data_add(ssl, zones, rr, line))
+			num++;
+	}
+	(void)ssl_printf(ssl, "added %d datas\n", num);
+}
+
 /** Remove RR data */
 static int
 perform_data_remove(RES* ssl, struct local_zones* zones, char* arg)
@@ -1513,6 +1531,37 @@ do_view_datas_add(RES* ssl, struct worker* worker, char* arg)
 	lock_rw_unlock(&v->lock);
 }
 
+/** Add new RR data to view */
+static void
+do_view_datas_add2(RES* ssl, struct worker* worker, char* arg)
+{
+	struct view* v;
+	char* view_name;
+	char* copy = strdup(arg);
+	view_name = strtok(copy, ",");
+	if(!view_name) {
+		ssl_printf(ssl,"no view name\n");
+		return;
+	}
+	v = views_find_view(worker->daemon->views,
+		view_name, 1 /* get write lock*/);
+	if(!v) {
+		ssl_printf(ssl,"no view with name: %s\n", view_name);
+		return;
+	}
+	if(!v->local_zones) {
+		if(!(v->local_zones = local_zones_create())){
+			lock_rw_unlock(&v->lock);
+			ssl_printf(ssl,"error out of memory\n");
+			free(copy);
+			return;
+		}
+	}
+	do_datas_add2(ssl, v->local_zones);
+	lock_rw_unlock(&v->lock);
+	free(copy);
+}
