From ba598507b57684d9ac8a8c142173b9dd48fe35c3 Mon Sep 17 00:00:00 2001
From: Mykyta Diachyna <m.diachyna@inango-systems.com>
Date: Fri, 15 Aug 2025 15:00:31 +0300
Subject: [PATCH] miniupnpd: Make IGD and WANConnectionDevice metadata match

Replace hardcoded values for WANConnectionDevice metadata
with the same values as IGD metadata, taken from the config

References: PCF-1927
Signed-off-by: Mykyta Diachyna <m.diachyna@inango-systems.com>
---
 miniupnpd/upnpdescgen.c | 10 ++++++++++
 1 file changed, 10 insertions(+)

diff --git miniupnpd/upnpdescgen.c miniupnpd/upnpdescgen.c
index ccd45ad..13ffe1e 100644
--- miniupnpd/upnpdescgen.c
+++ miniupnpd/upnpdescgen.c
@@ -384,6 +384,15 @@ static const struct XMLElt rootDesc[] =
 	{"device", INITHELPER(39,12)},
 /* 39 */
 	{"/deviceType", DEVICE_TYPE_WANC},		/* urn:schemas-upnp-org:device:WANConnectionDevice:1 or 2 */
+#ifdef ENABLE_MANUFACTURER_INFO_CONFIGURATION
+	{"/friendlyName", friendly_name},
+	{"/manufacturer", manufacturer_name},
+	{"/manufacturerURL", manufacturer_url},
+	{"/modelDescription", model_description},
+	{"/modelName", model_name},
+	{"/modelNumber", modelnumber},
+	{"/modelURL", model_url},
+#else
 	{"/friendlyName", WANCDEV_FRIENDLYNAME},
 	{"/manufacturer", WANCDEV_MANUFACTURER},
 	{"/manufacturerURL", WANCDEV_MANUFACTURERURL},
@@ -391,6 +400,7 @@ static const struct XMLElt rootDesc[] =
 	{"/modelName", WANCDEV_MODELNAME},
 	{"/modelNumber", WANCDEV_MODELNUMBER},
 	{"/modelURL", WANCDEV_MODELURL},
+#endif
 	{"/serialNumber", serialnumber},
 	{"/UDN", uuidvalue_wcd},
 	{"/UPC", WANCDEV_UPC},					/* UPC (=12 digit Barcode) is optional */
-- 
2.34.1

