---
 miniupnpd/amx/amxmisc.c | 28 ++++++++++++++++++++++
 miniupnpd/miniupnpd.c   | 52 +++++++++++++++++++++++++++++++++++++++++
 2 files changed, 80 insertions(+)

diff --git miniupnpd/amx/amxmisc.c miniupnpd/amx/amxmisc.c
index 6f15646..072756e 100644
--- miniupnpd/amx/amxmisc.c
+++ miniupnpd/amx/amxmisc.c
@@ -598,6 +598,20 @@ int amx_is_wan_ppp(void) {
     return ppp;
 }
 
+/**
+ * @brief Checks if DSLite is enabled on the device.
+ *
+ * This function queries the AMX bus to determine if the DSLite interface
+ * is currently enabled. It searches for the interface setting with the
+ * status 'Enabled'. If found, it returns 1 indicating DSLite is enabled,
+ * otherwise returns 0.
+ *
+ * @return int
+ * - 1 if DSLite is enabled.
+ * - 0 if DSLite is not enabled or if an error occurs during the check.
+ *
+ * @note This function logs errors and debug information using syslog.
+ */
 int ext_is_dslite(void) {
     int rv = 0;
     amxc_var_t ret;
@@ -617,6 +631,20 @@ exit:
     return rv;
 }
 
+ /**
+ * @brief Retrieves the external IP address used for DSLite.
+ *
+ * This function queries the PCP (Port Control Protocol) client to obtain the
+ * external IP address assigned for DSLite. If the PCP client is enabled and
+ * the server status is 'Enabled', it copies the external IP address into
+ * the provided buffer. If the retrieval fails or the PCP client is not enabled,
+ * it sets the external IP address string to an empty string.
+ *
+ * @param ext_ip_addr A pointer to a character buffer where the external IP address
+ *                    will be stored. The buffer must be at least INET_ADDRSTRLEN bytes long.
+ *
+ * @note The function uses `strncpy` to copy the IP address and ensures null-termination.
+ */
 void get_dslite_external_ip(char* ext_ip_addr) {
     int rv = 0;
     amxc_var_t ret;
diff --git miniupnpd/miniupnpd.c miniupnpd/miniupnpd.c
index 7cab20b..f86c47c 100644
--- miniupnpd/miniupnpd.c
+++ miniupnpd/miniupnpd.c
@@ -1174,6 +1174,20 @@ void complete_uuidvalues(void)
 	}
 }
 
+/**
+ * @brief Parses a LAN address or interface name and adds it to the LAN addresses list if not already present.
+ *
+ * This function allocates memory for a new LAN address structure, parses the listening IP
+ * or interface name, and checks if the address is already in the list of LAN addresses.
+ * If not, it inserts the new address into the list.
+ *
+ * @return uint32_t
+ * - 0 on success.
+ * - 1 on failure (memory allocation failure or parsing error).
+ *
+ * @note The function uses `malloc` for memory allocation and `free` in case of errors.
+ *       It also performs string comparison to avoid duplicate addresses.
+ */
 static uint32_t parselanaddr_wrapper(void) {
 	struct lan_addr_s* lan_addr = NULL;
 	struct lan_addr_s* lan_addr2 = NULL;
@@ -2153,6 +2167,20 @@ print_usage:
 	return 1;
 }
 
+/**
+ * @brief Cleans up and releases resources associated with snotify addresses.
+ *
+ * This function closes all socket descriptors stored in the snotify array
+ * and frees the allocated memory. The number of addresses to close depends
+ * on whether IPv6 support is enabled.
+ *
+ * @param snotify_addr A pointer to the array of socket descriptors.
+ *                     The array is freed and the pointer is set to NULL.
+ * @param addr_count The number of addresses (or socket descriptors) in the array.
+ *
+ * @note The function assumes that `snotify_addr` points to a dynamically allocated array.
+ *       After calling this function, the original pointer is set to NULL.
+ */
 static void clean_snotify(int **snotify_addr, int addr_count) {
 	int32_t i;
 	int *snotify = *snotify_addr;
@@ -2168,6 +2196,21 @@ static void clean_snotify(int **snotify_addr, int addr_count) {
 	snotify = NULL;
 }
 
+/**
+ * @brief Cleans up and releases resources associated with SNAT-PMP addresses.
+ *
+ * This function closes all socket descriptors stored in the snatpmp array
+ * where the descriptor is non-negative, then frees the allocated memory.
+ * It also sets the local pointer to NULL (note: does not modify the caller's pointer).
+ *
+ * @param snatpmp_addr A pointer to the array of socket descriptors.
+ *                     The array is freed and the pointer is set to NULL.
+ * @param addr_count The number of addresses (or socket descriptors) in the array.
+ *
+ * @note The function assumes that `snatpmp_addr` points to a dynamically allocated array.
+ *       After calling this function, the local pointer `snatpmp` is set to NULL,
+ *       but the caller's pointer remains unchanged unless explicitly modified.
+ */
 static void clean_snatpmp(int **snatpmp_addr, int addr_count) {
 	int32_t i;
 	int *snatpmp = *snatpmp_addr;
@@ -2183,6 +2226,15 @@ static void clean_snatpmp(int **snatpmp_addr, int addr_count) {
 	snatpmp = NULL;
 }
 
+/**
+ * @brief Clears and frees all LAN address entries from the list.
+ *
+ * This function iterates through the linked list of LAN addresses,
+ * removes each entry from the list, and frees the associated memory.
+ * After execution, the list will be empty.
+ *
+ * @note The list `lan_addrs` is assumed to be a global or externally defined list head.
+ */
 static void clear_lan_addrs(void) {
 	struct lan_addr_s* lan_addr = NULL;
 
