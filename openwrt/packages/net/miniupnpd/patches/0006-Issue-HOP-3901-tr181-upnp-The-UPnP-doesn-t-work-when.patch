From 1747a8a33e0d5a134a088f617f5e6d38ee13b4fa Mon Sep 17 00:00:00 2001
From: sahbot <support.opensource@softathome.com>
Date: Thu, 24 Aug 2023 15:41:16 +0200
Subject: [PATCH] Issue: HOP-3901 [tr181-upnp] The UPnP doesn't work when
 behind a CG-NAT or double NAT network [fix]

GitOrigin-RevId: cd15cbfc0df7c0a143ea0855e63dcb1dbd7da319
---
 miniupnpd/miniupnpd.c | 16 ++++++++++++++++
 miniupnpd/upnpsoap.c  |  4 ++++
 2 files changed, 20 insertions(+)

diff --git miniupnpd/miniupnpd.c miniupnpd/miniupnpd.c
index 3a969df..dcac3c9 100644
--- miniupnpd/miniupnpd.c
+++ miniupnpd/miniupnpd.c
@@ -1021,7 +1021,11 @@ parselanaddr(struct lan_addr_s * lan_addr, const char * str, int debug_flag)
 				INIT_PRINT_ERR("Error parsing address : %s\n", lan_addr->ext_ip_str);
 				return -1;
 			}
+#ifdef ALLOW_RESERVED_ADDR
+			if(false) {
+#else
 			if(addr_is_reserved(&lan_addr->ext_ip_addr)) {
+#endif
 				/* error */
 				INIT_PRINT_ERR("Error: option ext_ip address contains reserved / private address : %s\n", lan_addr->ext_ip_str);
 				return -1;
@@ -1880,7 +1884,11 @@ init(int argc, char * * argv, struct runtime_vars * v)
 			INIT_PRINT_ERR("Error: option ext_ip contains invalid address %s\n", use_ext_ip_addr);
 			return 1;
 		}
+#ifdef ALLOW_RESERVED_ADDR
+		if(false) {
+#else
 		if (addr_is_reserved(&addr)) {
+#endif
 			INIT_PRINT_ERR("Error: option ext_ip contains reserved / private address %s, not public routable\n", use_ext_ip_addr);
 			return 1;
 		}
@@ -2331,7 +2339,11 @@ main(int argc, char * * argv)
 		if (getifaddr(ext_if_name, if_addr, INET_ADDRSTRLEN, &addr, NULL) < 0) {
 			syslog(LOG_WARNING, "Cannot get IP address for ext interface %s. Network is down", ext_if_name);
 			disable_port_forwarding = 1;
+#ifdef ALLOW_RESERVED_ADDR
+		} else if(false) {
+#else
 		} else if (addr_is_reserved(&addr)) {
+#endif
 			syslog(LOG_INFO, "Reserved / private IP address %s on ext interface %s: Port forwarding is impossible", if_addr, ext_if_name);
 			syslog(LOG_INFO, "You are probably behind NAT, enable option ext_perform_stun=yes to detect public IP address");
 			syslog(LOG_INFO, "Or use ext_ip= / -o option to declare public IP address");
@@ -2644,7 +2656,11 @@ main(int argc, char * * argv)
 					syslog(LOG_WARNING, "Cannot get IP address for ext interface %s. Network is down", ext_if_name);
 					disable_port_forwarding = 1;
 				} else {
+#ifdef ALLOW_RESERVED_ADDR
+					int reserved = 0;
+#else
 					int reserved = addr_is_reserved(&addr);
+#endif
 					if (!disable_port_forwarding && reserved) {
 						syslog(LOG_INFO, "Reserved / private IP address %s on ext interface %s: Port forwarding is impossible", if_addr, ext_if_name);
 						syslog(LOG_INFO, "You are probably behind NAT, enable option ext_perform_stun=yes to detect public IP address");
diff --git miniupnpd/upnpsoap.c miniupnpd/upnpsoap.c
index 567b39d..5c8790e 100644
--- miniupnpd/upnpsoap.c
+++ miniupnpd/upnpsoap.c
@@ -346,7 +346,11 @@ GetExternalIPAddress(struct upnphttp * h, const char * action, const char * ns)
 			syslog(LOG_ERR, "Failed to get ip address for interface %s",
 				ext_if_name);
 			ext_ip_addr[0] = '\0';
+#ifdef ALLOW_RESERVED_ADDR
+		} else if (0) {
+#else
 		} else if (addr_is_reserved(&addr)) {
+#endif
 			syslog(LOG_NOTICE, "private/reserved address %s is not suitable for external IP", ext_ip_addr);
 			ext_ip_addr[0] = '\0';
 		}
-- 
2.34.1

