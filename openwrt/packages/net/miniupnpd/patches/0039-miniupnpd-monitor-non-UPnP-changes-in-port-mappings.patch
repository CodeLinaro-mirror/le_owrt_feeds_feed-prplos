 		echo "CPPFLAGS += -I." >> config.mk
-		echo "LDLIBS += -lsahtrace -lamxc -lamxp -lamxd -lamxb -lamxo -lnetmodel" >> config.mk
+		echo "LDLIBS += -lsahtrace -lamxrt -lamxc -lamxp -lamxd -lamxb -lamxo -lnetmodel" >> config.mk
 		echo 'STAGING_LIBDIR = $(if $(STAGING_DIR), -L$(STAGING_DIR)/lib) $(if $(STAGING_DIR), -L$(STAGING_DIR)/usr/lib)' >> config.mk
 		echo 'LDFLAGS += $(STAGING_LIBDIR)' >> config.mk
