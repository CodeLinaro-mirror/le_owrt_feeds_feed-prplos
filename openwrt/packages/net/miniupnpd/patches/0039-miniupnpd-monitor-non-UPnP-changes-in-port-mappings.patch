diff --git miniupnpd/miniupnpd.c miniupnpd/miniupnpd.c
index 0c89bfa..2a40298 100644
--- miniupnpd/miniupnpd.c
+++ miniupnpd/miniupnpd.c
@@ -2654,6 +2654,9 @@ main(int argc, char * * argv)
 	/* main loop */
 	while(!quitting)
 	{
+#ifdef USE_AMX
+		bool should_send_upnp_notify = exchange_upnp_notify_needed(false);
+#endif /* USE_AMX */
 #ifdef USE_TIME_AS_BOOTID
 		/* Correct startup_time if it was set with a RTC close to 0 */
 		if((upnp_bootid<60*60*24) && (time(NULL)>60*60*24))
@@ -2716,6 +2719,12 @@ main(int argc, char * * argv)
 			if(GETFLAG(ENABLEUPNPMASK))
 			{
 				upnp_event_var_change_notify(EWanIPC);
+#ifdef USE_AMX
+				/* If notify is sent, then
+				 * we can skip sending notify messages
+				 * in this loop iteration */
+				should_send_upnp_notify = false;
+#endif /* USE_AMX */
 			}
 #endif
 #ifdef ENABLE_PCP
@@ -2923,6 +2932,13 @@ main(int argc, char * * argv)
 #endif
 
 #ifdef ENABLE_EVENTS
+#ifdef USE_AMX
+		if(should_send_upnp_notify)
+		{
+			syslog(LOG_INFO, "should_send_upnp_notify is set, sending notifications");
+			upnp_event_var_change_notify(EWanIPC);
+		}
+#endif /* USE_AMX */
 		upnpevents_selectfds(&readset, &writeset, &max_fd);
 #endif
 
diff --git miniupnpd/upnpevents.c miniupnpd/upnpevents.c
index dc609ec..9e81114 100644
--- miniupnpd/upnpevents.c
+++ miniupnpd/upnpevents.c
@@ -233,6 +233,7 @@ void
 upnp_event_var_change_notify(enum subscriber_service_enum service)
 {
 	struct subscriber * sub;
+	
 	for(sub = subscriberlist.lh_first; sub != NULL; sub = sub->entries.le_next) {
 		if(sub->service == service && sub->notify == NULL)
 			upnp_event_create_notify(sub);
@@ -670,6 +671,13 @@ void upnpevents_processfds(fd_set *readset, fd_set *writeset)
 		}
 		sub = subnext;
 	}
+#ifdef USE_AMX
+	/* Perform request to the bus to force Ambiorix event loop
+	 * to process bus notification. This is workaround because
+	 * now event loop does not process bus notification
+	 * if there is no request to the bus. */
+	amx_get_dummy();
+#endif /* USE_AMX */
 }
 
 #ifdef USE_MINIUPNPDCTL
diff --git miniupnpd/upnpredirect.c miniupnpd/upnpredirect.c
index da47725..e192d3d 100644
--- miniupnpd/upnpredirect.c
+++ miniupnpd/upnpredirect.c
@@ -475,10 +475,16 @@ upnp_redirect_internal(const char * rhost, unsigned short eport,
 		if(!nextruletoclean_timestamp || (timestamp < nextruletoclean_timestamp))
 			nextruletoclean_timestamp = timestamp;
 	}
+
 #ifdef ENABLE_EVENTS
+	/* We do not need to notify the subscribers
+	 * in AMX mode, because the notify will be
+	 * send from AMX event loop */
+#ifndef USE_AMX
 	/* the number of port mappings changed, we must
 	 * inform the subscribers */
 	upnp_event_var_change_notify(EWanIPC);
+#endif /* !USE_AMX */
 #endif
 	return 0;
 }
@@ -575,7 +581,14 @@ _upnp_delete_redir(unsigned short eport, int proto)
 #endif
 
 #ifdef ENABLE_EVENTS
+	/* We do not need to notify the subscribers
+	 * in AMX mode, because the notify will be
+	 * send from AMX event loop */
+#ifndef USE_AMX
+	/* the number of port mappings changed, we must
+	 * inform the subscribers */
 	upnp_event_var_change_notify(EWanIPC);
+#endif /* !USE_AMX */
 #endif
 	return r;
 }
