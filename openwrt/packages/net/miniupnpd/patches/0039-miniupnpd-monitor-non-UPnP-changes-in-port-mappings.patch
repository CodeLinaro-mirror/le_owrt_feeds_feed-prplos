From 89131eb21643f326a91fc74837cb73b599b33d0c Mon Sep 17 00:00:00 2001
From: Mykola Hlukhenkyi <m.hlukhenkyi@inango-systems.com>
Date: Tue, 5 Aug 2025 13:30:09 +0300
Subject: [PATCH] miniupnpd: monitor non-UPnP changes in port mappings

miniupnpd tracks changes to the PortMapping object only from internal
functions when processing add and delete rules. Therefore,
when a user changes the model via the bus, miniupnd does not
receive any information about this change.

Solution:
* Add start of ambiorix event loop in separate thread to handle bus
  notifications
* Add subscription to NAT object changes to generate notify event when
  changes are performed not over UPnP
* Add dummy request into bus in miniupnd main loop to force the ambiorix
  loop to process bus notifications

References: PCF-1996
Signed-Off-By: Mykola Hlukhenkyi <m.hlukhenkyi@inango-systems.com>
---
 miniupnpd/amx/amxmisc.c  | 141 +++++++++++++++++++++++++++++++++++++--
 miniupnpd/amx/amxmisc.h  |  44 ++++++++++++
 miniupnpd/amx/amxpmp.c   |   1 +
 miniupnpd/configure      |   2 +-
 miniupnpd/miniupnpd.c    |  16 +++++
 miniupnpd/upnpevents.c   |   8 +++
 miniupnpd/upnpredirect.c |  13 ++++
 7 files changed, 217 insertions(+), 8 deletions(-)

diff --git miniupnpd/amx/amxmisc.c miniupnpd/amx/amxmisc.c
index f68f0fc..0497629 100644
--- miniupnpd/amx/amxmisc.c
+++ miniupnpd/amx/amxmisc.c
@@ -3,6 +3,7 @@
 ** SPDX-License-Identifier: BSD-2-Clause-Patent
 **
 ** SPDX-FileCopyrightText: Copyright (c) 2023 SoftAtHome
+** SPDX-FileCopyrightText: Copyright (c) 2025 Inango
 **
 ** Redistribution and use in source and binary forms, with or
 ** without modification, are permitted provided that the following
@@ -62,16 +63,24 @@
 
 #include <string.h>
 #include <syslog.h>
-#include <netmodel/client.h>
+#include <amxrt/amxrt.h>
 #include <amxc/amxc.h>
 #include <amxc/amxc_macros.h>
 #include <amxp/amxp.h>
 #include <amxd/amxd_object.h>
 #include <amxd/amxd_path.h>
 #include <amxb/amxb.h>
+#include <netmodel/client.h>
+#include <pthread.h>
+#include <stdatomic.h>
 #include "config.h"
 #include "../upnpglobalvars.h"
 
+#define NAT_OBJECT_PATH "NAT."
+
+pthread_t amxrt_thread_id;
+atomic_bool upnp_notify_needed = false;
+
 static amxb_bus_ctx_t* bus_ctx = NULL;
 
 static void init_loglevel(void) {
@@ -99,24 +108,142 @@ static void init_loglevel(void) {
     amxc_var_clean(&arg);
 }
 
+/**
+ * @brief Get the current state of the UPnP notification needed flag
+ * and set it to the new value.
+ *
+ * This function atomically exchanges the value of the `upnp_notify_needed`
+ * flag. Used to check if a UPnP notification is needed and set it to a new value.
+ *
+ * @param needed The new value to set the `upnp_notify_needed` flag to.
+ * @return The current value of the `upnp_notify_needed` flag before the exchange.
+ */
+bool exchange_upnp_notify_needed(bool needed) {
+    return atomic_exchange(&upnp_notify_needed, needed);
+}
+
+/**
+ * @brief Callback function for port mapping entries change event.
+ *
+ * This function is called when the number of port mappings
+ * changes in the bus. It creates a notification
+ * to inform the subscribers about the change.
+ */
+static void portmapping_entries_changed(const char* const sig_name,
+                                        const amxc_var_t* const data,
+                                        void* const priv) {
+    /* Raise a flag to indicate that a UPnP notification is needed.
+     * Notification will be processed in the main loop */
+    exchange_upnp_notify_needed(true);
+    syslog(LOG_INFO, "Port mapping entries changed, notification needed");
+}
+
+int amx_add_portmapping_sub(amxb_bus_ctx_t* bus_ctx) {
+    int res = amxb_subscribe(bus_ctx, NAT_OBJECT_PATH,
+                             "(notification == 'dm:object-changed') && \
+                                (contains('parameters.PortMappingNumberOfEntries'))",
+                             portmapping_entries_changed, NULL);
+    if (res != 0) {
+        syslog(LOG_ERR,
+               "Failed to subscribe to object-changed event for "
+               "'%s' object: res '%d'",
+               NAT_OBJECT_PATH, res);
+        return res;
+    }
+    syslog(LOG_INFO, "Subscribed to portmapping notifications");
+    return res;
+}
+
+int amx_del_portmapping_sub(amxb_bus_ctx_t* bus_ctx) {
+    int res = amxb_unsubscribe(bus_ctx, NAT_OBJECT_PATH,
+                               portmapping_entries_changed, NULL);
+    if (res != 0) {
+        syslog(LOG_ERR,
+               "Failed to unsubscribe from object-changed event for "
+               "'%s' object: res '%d'",
+               NAT_OBJECT_PATH, res);
+    }
+
+    syslog(LOG_INFO, "Unsubscribed from portmapping notifications");
+    return res;
+}
+
+void* amxrt_thread(void* arg) {
+    int r = -1;
+
+    amxrt_new();
+
+    r = amxb_be_load(ubus_backend_url);
+    if (r != 0) {
+        syslog(LOG_ERR, "Failed to load AMX backend at %s: %d",
+               ubus_backend_url, r);
+        return r;
+    }
+    r = amxb_connect(&bus_ctx, ubus_sock_url);
+    if (r != 0) {
+        syslog(LOG_ERR, "Failed to connect to AMX bus at %s: %d", ubus_sock_url,
+               r);
+        return r;
+    }
+
+    r = amxrt_el_create();
+    if (r != 0) {
+        syslog(LOG_ERR, "Failed to create AMX event loop: %d", r);
+        return NULL;
+    }
+
+    r = amx_add_portmapping_sub(bus_ctx);
+    if (r != 0) {
+        syslog(LOG_ERR, "Failed to add portmapping subscription: %d", r);
+        return NULL;
+    }
+
+    r = amxrt_el_start();  // will block until amxrt_el_stop is called
+    if (r != 0) {
+        syslog(LOG_ERR, "AMX event loop failed to start: %d", r);
+    } else {
+        syslog(LOG_INFO, "AMX event loop stopped successfully");
+    }
+    amxb_disconnect(bus_ctx);
+    amxrt_stop();
+    amxrt_delete();
+    return NULL;
+}
+
+int amx_get_dummy(void) {
+    return amxb_get(bus_ctx, "NAT.PortMappingNumberOfEntries", 0, NULL, 0);
+}
+
 int init_amx(void) {
     int r = -1;
+    int count = 0;
     if(bus_ctx != NULL) {
         r = 0;
     } else {
-        r = amxb_be_load(ubus_backend_url);
-        if(r == 0) {
-            r = amxb_connect(&bus_ctx, ubus_sock_url);
-            netmodel_initialize();
-            init_loglevel();
+        r = pthread_create(&amxrt_thread_id, NULL, amxrt_thread, NULL);
+        if (r != 0) {
+            syslog(LOG_ERR, "Failed to create AMX event loop thread: %d", r);
+            return r;
         }
+        while (bus_ctx == NULL) {
+            // Wait for the bus context to be initialized
+            sleep(1);  // Sleep for 1 second
+            if (++count > 10) {
+                syslog(LOG_ERR,
+                       "AMX bus context not initialized after 10 seconds");
+                return -1;
+            }
+        }
+        netmodel_initialize();
+        init_loglevel();
     }
     return r;
 }
 
 void shutdown_amx(void) {
     netmodel_cleanup();
-    amxb_disconnect(bus_ctx);
+    amxrt_el_stop();
+    pthread_join(amxrt_thread_id, NULL);
     bus_ctx = NULL;
     return;
 }
