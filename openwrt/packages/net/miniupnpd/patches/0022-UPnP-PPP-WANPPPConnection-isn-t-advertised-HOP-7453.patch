+					if ((strcmp("urn:schemas-upnp-org:service:WANPPPConnection:", known_service_types[i].s) == 0 && !ext_is_ppp) ||
+						(strcmp("urn:schemas-upnp-org:service:WANIPConnection:", known_service_types[i].s) == 0 && ext_is_ppp)) {
+						continue;
+					}
 #ifdef DELAY_MSEARCH_RESPONSE
 					delay += delay_increment;
 #endif
@@ -1480,6 +1492,10 @@ SendSSDPGoodbye(int * sockets, int n_sockets)
 #endif
 	    for(i=0; known_service_types[i].s; i++)
 	    {
+			if ((strcmp("urn:schemas-upnp-org:service:WANPPPConnection:", known_service_types[i].s) == 0 && !ext_is_ppp) ||
+				(strcmp("urn:schemas-upnp-org:service:WANIPConnection:", known_service_types[i].s) == 0 && ext_is_ppp)) {
+				continue;
+			}
 			if(i==0)
 				ver_str[0] = '\0';
 			else
@@ -1540,6 +1556,10 @@ SubmitServicesToMiniSSDPD(const char * host, unsigned short port) {
 		return -1;
 	}
 	for(i = 0; known_service_types[i].s; i++) {
+		if ((strcmp("urn:schemas-upnp-org:service:WANPPPConnection:", known_service_types[i].s) == 0 && !ext_is_ppp) ||
+			(strcmp("urn:schemas-upnp-org:service:WANIPConnection:", known_service_types[i].s) == 0 && ext_is_ppp)) {
+			continue;
+		}
 		buffer[0] = 4;	/* request type 4 : submit service */
 		if(i==0)
