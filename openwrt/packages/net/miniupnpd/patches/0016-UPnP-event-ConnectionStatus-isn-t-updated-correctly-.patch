From a32cc79cf999f4fe780677f8fd40b02981e85c87 Mon Sep 17 00:00:00 2001
From: sahbot <support.opensource@softathome.com>
Date: Thu, 6 Jun 2024 15:32:57 +0200
Subject: [PATCH] UPnP event: ConnectionStatus isn't updated correctly
 (HOP-3580)[change]

Problem: When losing WAN the ConnectionStatus event isn't sent correctly
When IPv6 isn't start at boot IPv6 is disable and reboot is needed loosing
notify socket

Cause: Miniupnpd is using interface addr to know if WAN is lost

Solution: Use amx to verify WAN status when configuration is reloaded
Do not disable IPv6, since we use so_bindtodevice to prevent having to
restart

Issue: HOP-3580 - [CDROUTER][UPnP] ConnectionStatus value in NOTIFY event is
NOT correctly updated after WAN connectivity Loss
GitOrigin-RevId: f68e2147e30aca560e8419be3f4b90a00f03b159
---
 miniupnpd/amx/amxmisc.c    | 64 ++++++++++++++++++++++++++++++++++++++
 miniupnpd/amx/amxmisc.h    |  1 +
 miniupnpd/amx/amxpinhole.c |  2 +-
 miniupnpd/configure        |  8 +++--
 miniupnpd/getconnstatus.c  | 10 ++++++
 miniupnpd/miniupnpd.c      |  7 +++++
 6 files changed, 89 insertions(+), 3 deletions(-)

diff --git miniupnpd/amx/amxmisc.c miniupnpd/amx/amxmisc.c
index eedbece..f57307b 100644
--- miniupnpd/amx/amxmisc.c
+++ miniupnpd/amx/amxmisc.c
@@ -62,16 +62,43 @@
 
 #include <string.h>
 #include <syslog.h>
+#include <netmodel/client.h>
 #include <amxc/amxc.h>
 #include <amxc/amxc_macros.h>
 #include <amxp/amxp.h>
 #include <amxd/amxd_object.h>
+#include <amxd/amxd_path.h>
 #include <amxb/amxb.h>
 #include "config.h"
 #include "../upnpglobalvars.h"
 
 static amxb_bus_ctx_t* bus_ctx = NULL;
 
+static void init_loglevel(void) {
+    amxc_var_t ret;
+    amxc_var_t arg;
+    uint32_t level = 200;
+
+    amxc_var_init(&arg);
+    amxc_var_init(&ret);
+    amxc_var_set_type(&arg, AMXC_VAR_ID_HTABLE);
+    amxb_call(bus_ctx, "UPnP.", "list_trace_zones", &arg, &ret, 1);
+    if(amxc_var_type_of(&ret) != AMXC_VAR_ID_NULL) {
+        level = GETP_UINT32(&ret, "0.upnp");
+    }
+    if(level >= 500) {
+        setlogmask(LOG_UPTO(LOG_DEBUG));
+    } else if(level >= 400) {
+        setlogmask(LOG_UPTO(LOG_INFO));
+    } else if(level >= 300) {
+        setlogmask(LOG_UPTO(LOG_NOTICE));
+    } else {
+        setlogmask(LOG_UPTO(LOG_WARNING));
+    }
+    amxc_var_clean(&ret);
+    amxc_var_clean(&arg);
+}
+
 int init_amx(void) {
     int r = -1;
     if(bus_ctx != NULL) {
@@ -80,12 +107,15 @@ int init_amx(void) {
         r = amxb_be_load(ubus_backend_url);
         if(r == 0) {
             r = amxb_connect(&bus_ctx, ubus_sock_url);
+            netmodel_initialize();
+            init_loglevel();
         }
     }
     return r;
 }
 
 void shutdown_amx(void) {
+    netmodel_cleanup();
     amxb_disconnect(bus_ctx);
     bus_ctx = NULL;
     return;
@@ -145,4 +175,38 @@ exit:
     amxc_var_clean(&ret_a);
     amxc_var_clean(&ret_b);
     return rv;
+}
+
+int amx_is_wan_up(void) {
+    int rv = -1;
+    amxc_var_t ret;
+    amxc_var_t wan_obj;
+    amxc_string_t wan_ip_path;
+    amxd_path_t path;
+
+    amxc_var_init(&ret);
+    amxc_var_init(&wan_obj);
+    amxc_string_init(&wan_ip_path, 0);
+    amxd_path_init(&path, "Device.Logical.Interface.[Alias=='wan'].X_PRPL-COM_WAN.");
+    rv = amxb_resolve(bus_ctx, &path, &ret);
+    when_failed_status(rv, exit, syslog(LOG_ERR, "Couldn't resolve Device.Logical.Interface.[Alias=='wan'].X_PRPL-COM_WAN. to a fix path (%d)", rv));
+    when_false(amxc_var_type_of(&ret) != AMXC_VAR_ID_NULL, exit);
+    rv = amxb_get(bus_ctx, GETI_CHAR(&ret, 0), 0, &wan_obj, 1);
+    when_failed_status(rv, exit, syslog(LOG_ERR, "Couldn't get Logical interface %s data (%d))", GETI_CHAR(&ret, 0), rv));
+    rv = -1;
+    amxc_string_setf(&wan_ip_path, "0.'%s'.IPv4Address", GETI_CHAR(&ret, 0));
+    if(strcmp(GETP_CHAR(&wan_obj, amxc_string_get(&wan_ip_path, 0)), "") != 0) {
+        rv = 0;
+    }
+    amxc_string_setf(&wan_ip_path, "0.'%s'.IPv6Address", GETI_CHAR(&ret, 0));
+    if(strcmp(GETP_CHAR(&wan_obj, amxc_string_get(&wan_ip_path, 0)), "") != 0) {
+        rv = 0;
+    }
+exit:
+    syslog(LOG_INFO, "amx_is_wan_up: %d (%s)", rv, GETI_CHAR(&ret, 0));
+    amxc_string_clean(&wan_ip_path);
+    amxc_var_clean(&ret);
+    amxc_var_clean(&wan_obj);
+    amxd_path_clean(&path);
+    return rv;
 }
\ No newline at end of file
