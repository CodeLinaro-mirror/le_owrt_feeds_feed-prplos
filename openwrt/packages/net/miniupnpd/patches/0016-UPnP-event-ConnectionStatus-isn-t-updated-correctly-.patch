 		MAKEFILE=Makefile.linux_nft
diff --git miniupnpd/getconnstatus.c miniupnpd/getconnstatus.c
index 332784c..6cde725 100644
--- miniupnpd/getconnstatus.c
+++ miniupnpd/getconnstatus.c
@@ -8,8 +8,13 @@
 #include <stdio.h>
 #include <sys/types.h>
 #include <netinet/in.h>
+#include <syslog.h>
+#include "config.h"
 #include "getconnstatus.h"
 #include "getifaddr.h"
+#ifdef USE_AMX
+#include "amx/amxmisc.h"
+#endif
 
 #define STATUS_UNCONFIGURED (0)
 #define STATUS_CONNECTING (1)
@@ -30,6 +35,10 @@
 int
 get_wan_connection_status(const char * ifname)
 {
+#ifdef USE_AMX
+	(void) ifname;
+	return (amx_is_wan_up() == 0 ? STATUS_CONNECTED : STATUS_DISCONNECTED);
+#else
 	char addr[INET_ADDRSTRLEN];
 	int r;
 
@@ -37,6 +46,7 @@ get_wan_connection_status(const char * ifname)
 	 * I'm afraid it should be device specific */
 	r = getifaddr(ifname, addr, INET_ADDRSTRLEN, NULL, NULL);
 	return (r < 0) ? STATUS_DISCONNECTED : STATUS_CONNECTED;
+#endif
 }
 
