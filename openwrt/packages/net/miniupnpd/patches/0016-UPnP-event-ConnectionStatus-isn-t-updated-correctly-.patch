diff --git miniupnpd/configure miniupnpd/configure
index aa172b4..4081a5e 100755
--- miniupnpd/configure
+++ miniupnpd/configure
@@ -437,7 +437,9 @@ case $OS_NAME in
 		;;
 	OpenWrt)
 		OS_URL=http://www.openwrt.org/
-		echo "#define USE_IFACEWATCHER 1" >> ${CONFIGFILE}
+		if [ 1"$FW" != 1"amx" ] ; then
+			echo "#define USE_IFACEWATCHER 1" >> ${CONFIGFILE}
+		fi
 		GETIFADDRS=1
 		if [ -z "$FW" ] ; then
 			FW=iptables
@@ -598,7 +600,9 @@ case $FW in
 		echo "# generated by $0 on `date`" > config.mk
 		echo "SRCDIR = ${BASEDIR}" >> config.mk
 		echo "CPPFLAGS += -I." >> config.mk
-		echo "LDLIBS += -lamxc -lamxp -lamxd -lamxb -lamxo" >> config.mk
