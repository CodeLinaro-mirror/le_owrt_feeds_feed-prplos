From d6668b4e1223404fefc89db0a6654d77e0074d82 Mon Sep 17 00:00:00 2001
From: Toon Caeyers <toon.caeyers_ext@softathome.com>
Date: Tue, 13 May 2025 14:38:40 +0200
Subject: [PATCH] PROVISORY: Switch vendor prefix to X_PRPLWARE-COM_

Everything is switching to a globally defined vendor prefix. The method used for other plugins, including a global_variables.odl in the main odl doesn't work for this plugin as there is no global ODL. So to continue with the switch to the new vendor prefix, we will for now switch to the new prefix in a hardcoded fashion.

References: PPW-554
Signed-off-by: Toon Caeyers <toon.caeyers_ext@softathome.com>
---
 miniupnpd/amx/amxmisc.c | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git miniupnpd/amx/amxmisc.c miniupnpd/amx/amxmisc.c
index 3412fec..f68f0fc 100644
--- miniupnpd/amx/amxmisc.c
+++ miniupnpd/amx/amxmisc.c
@@ -190,9 +190,9 @@ int amx_is_wan_up(void) {
     amxc_var_init(&ret);
     amxc_var_init(&wan_obj);
     amxc_string_init(&wan_ip_path, 0);
-    amxd_path_init(&path, "Device.Logical.Interface.[Alias=='wan'].X_PRPL-COM_WAN.");
+    amxd_path_init(&path, "Device.Logical.Interface.[Alias=='wan'].X_PRPLWARE-COM_WAN.");
     rv = amxb_resolve(bus_ctx, &path, &ret);
-    when_failed_status(rv, exit, syslog(LOG_ERR, "Couldn't resolve Device.Logical.Interface.[Alias=='wan'].X_PRPL-COM_WAN. to a fix path (%d) bus_ctx: %p", rv, bus_ctx));
+    when_failed_status(rv, exit, syslog(LOG_ERR, "Couldn't resolve Device.Logical.Interface.[Alias=='wan'].X_PRPLWARE-COM_WAN. to a fix path (%d) bus_ctx: %p", rv, bus_ctx));
     when_false(amxc_var_type_of(&ret) != AMXC_VAR_ID_NULL, exit);
     rv = amxb_get(bus_ctx, GETI_CHAR(&ret, 0), 0, &wan_obj, 1);
     when_failed_status(rv, exit, syslog(LOG_ERR, "Couldn't get Logical interface %s data (%d))", GETI_CHAR(&ret, 0), rv));
-- 
