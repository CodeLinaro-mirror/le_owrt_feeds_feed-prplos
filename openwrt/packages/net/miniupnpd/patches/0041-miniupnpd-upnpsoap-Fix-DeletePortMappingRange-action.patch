From 142fabcc4eea9782b1896008572ba34cca78757d Mon Sep 17 00:00:00 2001
From: Mykyta Diachyna <m.diachyna@inango-systems.com>
Date: Tue, 26 Aug 2025 20:28:05 +0300
Subject: [PATCH] miniupnpd: upnpsoap: Fix DeletePortMappingRange action
 permissions

DeletePortMappingRange now returns error 730 if all mappings
in range are not able to be deleted. NewManage is always
assumed to be 0 and DeletePortMappingRange behaves accordingly.

References: PCF-2014
Signed-off-by: Mykyta Diachyna <m.diachyna@inango-systems.com>
---
 miniupnpd/upnpsoap.c | 45 ++++++++++++++++++++++++++++++++++++++++++++
 1 file changed, 45 insertions(+)

diff --git miniupnpd/upnpsoap.c miniupnpd/upnpsoap.c
index c91f685..a7255e5 100644
--- miniupnpd/upnpsoap.c
+++ miniupnpd/upnpsoap.c
@@ -1096,6 +1096,12 @@ DeletePortMappingRange(struct upnphttp * h, const char * action, const char * ns
 	/*int manage;*/
 	unsigned short * port_list;
 	unsigned int i, number = 0;
+	unsigned int deleted_number = 0;
+	char ip_str[INET6_ADDRSTRLEN] = {0};
+	char int_ip[INET6_ADDRSTRLEN] = {0};
+	unsigned short a;
+	unsigned int b;
+	char * inet_ntop_ret = NULL;
 
 	ParseNameValue(h->req_buf + h->req_contentoff, h->req_contentlen, &data);
 	startport_s = GetValueFromNameValueList(&data, "NewStartPort");
@@ -1136,13 +1142,52 @@ DeletePortMappingRange(struct upnphttp * h, const char * action, const char * ns
 		return;
 	}
 
+	int mismatched_control_point = 0;
 	for(i = 0; i < number; i++)
 	{
+		r = upnp_get_redirection_infos(port_list[i], protocol, &a,
+		                               int_ip, sizeof(int_ip),
+		                               NULL, 0,
+		                               NULL, 0,
+		                               &b);
+		if(r != 0) {
+			syslog(LOG_ERR, "%s: failed to get PortMapping information for port %d (%d)", action, port_list[i], r);
+			continue;
+		}
+
+		inet_ntop_ret = inet_ntop((h->ipv6) ? AF_INET6 : AF_INET, (h->ipv6) ? (void*)&h->clientaddr_v6 : (void*)&h->clientaddr, ip_str, INET6_ADDRSTRLEN);
+		if(inet_ntop_ret == NULL) {
+			syslog(LOG_ERR, "%s: failed to convert client address to string: %s", action, strerror(errno));
+			continue;
+		}
+
+		if(strncmp(ip_str, int_ip, INET6_ADDRSTRLEN) != 0) {
+			syslog(LOG_INFO,
+			       "%s: NOT deleting external port: %hu, protocol: %s: NewManage=0 and InternalAddress does not match ClientAddress",
+			       action, port_list[i], protocol);
+			mismatched_control_point = 1;
+			continue;
+		}
+
 		r = upnp_delete_redirection(port_list[i], protocol);
+		if (r == 0) {
+			deleted_number += 1;
+		}
 		syslog(LOG_INFO, "%s: deleting external port: %hu, protocol: %s: %s",
 		       action, port_list[i], protocol, r < 0 ? "failed" : "ok");
 	}
 	free(port_list);
+
+	if(deleted_number == 0) {
+		if (mismatched_control_point) {
+			SoapError(h, 606, "Action not authorized");
+		} else {
+			SoapError(h, 730, "PortMappingNotFound");
+		}
+		ClearNameValueList(&data);
+		return;
+	}
+
 	bodylen = snprintf(body, sizeof(body), resp,
 	                   action, ns, action);
 	BuildSendAndCloseSoapResp(h, body, bodylen);
-- 
2.34.1

