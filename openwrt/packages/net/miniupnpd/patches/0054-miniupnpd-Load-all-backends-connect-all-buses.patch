-void* amxrt_thread(void* arg) {
+void* amxrt_thread(UNUSED void* arg) {
     int r = -1;
+    amxc_var_t csv_list;
+
+    when_not_null_status(get_amx_bus_ctx("UPnP."), exit, r = 0);
 
     amxrt_new();
 
-    r = amxb_be_load(ubus_backend_url);
-    if (r != 0) {
-        syslog(LOG_ERR, "Failed to load AMX backend at %s: %d",
-               ubus_backend_url, r);
-        return r;
+    amxc_var_init(&csv_list);
+    amxc_var_set_csv_string_t(&csv_list, amx_backend_urls);
+    amxc_var_cast(&csv_list, AMXC_VAR_ID_LIST);
+    amxc_var_for_each(backend, &csv_list) {
+        if((r = amxb_be_load(amxc_var_constcast(cstring_t, backend))) != 0) {
+            syslog(LOG_WARNING, "Couldn't open backend %s (%d)", amxc_var_constcast(cstring_t, backend), r);
+        }
     }
-    r = amxb_connect(&bus_ctx, ubus_sock_url);
-    if (r != 0) {
-        syslog(LOG_ERR, "Failed to connect to AMX bus at %s: %d", ubus_sock_url,
-               r);
-        return r;
+
+    amxc_var_set_csv_string_t(&csv_list, amx_sock_urls);
+    amxc_var_cast(&csv_list, AMXC_VAR_ID_LIST);
+    amxc_var_for_each(sock, &csv_list) {
+        amxb_bus_ctx_t* tmp = NULL;
+        if((r = amxb_connect(&tmp, amxc_var_constcast(cstring_t, sock))) != 0) {
+            syslog(LOG_WARNING, "Couldn't open sock %s (%d)", amxc_var_constcast(cstring_t, sock), r);
+        }
     }
 
+    amxc_var_clean(&csv_list);
+
+    bus_ctx = get_amx_bus_ctx(NAT_OBJECT_PATH);
+
     r = amxrt_el_create();
-    if (r != 0) {
+    if(r != 0) {
         syslog(LOG_ERR, "Failed to create AMX event loop: %d", r);
         return NULL;
     }
 
     r = amx_add_portmapping_sub(bus_ctx);
-    if (r != 0) {
+    if(r != 0) {
         syslog(LOG_ERR, "Failed to add portmapping subscription: %d", r);
         return NULL;
     }
 
     r = amxrt_el_start();  // will block until amxrt_el_stop is called
-    if (r != 0) {
+    if(r != 0) {
         syslog(LOG_ERR, "AMX event loop failed to start: %d", r);
     } else {
         syslog(LOG_INFO, "AMX event loop stopped successfully");
     }
-    amxb_disconnect(bus_ctx);
+
     amxrt_stop();
     amxrt_delete();
+exit:
     return NULL;
 }
 
@@ -363,14 +375,14 @@ int init_amx(void) {
         r = 0;
