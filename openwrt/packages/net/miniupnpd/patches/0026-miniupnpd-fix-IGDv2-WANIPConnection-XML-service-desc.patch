From 4123aaef8bf7e4dbcc1c40e91394bd7874e491cd Mon Sep 17 00:00:00 2001
From: Thomas Bernard <miniupnp@free.fr>
Date: Sun, 25 Feb 2024 01:29:54 +0100
Subject: [PATCH] miniupnpd: fix IGDv2 WANIPConnection XML service description

was :

<argument>
  <name>NewExternalPort</name>
  <direction>out</direction>
  <relatedStateVariable>ExternalPort</relatedStateVariable>
</argument>

Should be:

<argument>
  <name>NewReservedPort</name>
  <direction>out</direction>
  <relatedStateVariable>ExternalPort</relatedStateVariable>
</argument>

ExternalPort is 12 characters long !
fixes #708

(cherry picked from commit f79e20d17d8fcdb295af60b741b51693ab5a271c)
Signed-off-by: Mykola Hlukhenkyi <m.hlukhenkyi@inango-systems.com>
---
 miniupnpd/upnpdescgen.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git miniupnpd/upnpdescgen.c miniupnpd/upnpdescgen.c
index a7af7a1..64c1de3 100644
--- miniupnpd/upnpdescgen.c
+++ miniupnpd/upnpdescgen.c
@@ -1273,7 +1273,7 @@ genServiceDesc(int * len, const struct serviceDesc * s, int force_igd1)
 #ifdef IGD_V2
 				} else if(plen >= 11 && 0 == memcmp(p, "A_ARG_TYPE_", 11)) {
 					str = strcat_str(str, len, &tmplen, p + 11);
-				} else if(plen == 12 && 0 == memcmp(p, "ExternalPort", 12)
+				} else if(plen >= 12 && 0 == memcmp(p, "ExternalPort", 12)
 				          && args[j].dir == 2
 				          && 0 == memcmp(acts[i].name, "AddAnyPortMapping", 18)) {
 					str = strcat_str(str, len, &tmplen, "ReservedPort");
-- 
2.34.1

