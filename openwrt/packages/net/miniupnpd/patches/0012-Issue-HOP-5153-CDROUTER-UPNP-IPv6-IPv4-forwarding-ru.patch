From 49421d030f4662c0473c6b48554fe171f53dc44f Mon Sep 17 00:00:00 2001
From: sahbot <support.opensource@softathome.com>
Date: Tue, 28 Nov 2023 17:14:46 +0100
Subject: [PATCH] Issue: HOP-5153 [CDROUTER][UPNP][IPv6] IPv4 forwarding rule
 cannot be deleted via UPnP [fix]

GitOrigin-RevId: 23ba598ae285ca5cc47c6376cb9324f360f719f5
---
 miniupnpd/upnpsoap.c | 20 +++++++++++++++++---
 1 file changed, 17 insertions(+), 3 deletions(-)

diff --git miniupnpd/upnpsoap.c miniupnpd/upnpsoap.c
index 8fc4a9e..4550dc9 100644
--- miniupnpd/upnpsoap.c
+++ miniupnpd/upnpsoap.c
@@ -496,8 +496,8 @@ AddPortMapping(struct upnphttp * h, const char * action, const char * ns)
 	{
 		if(h->clientaddr.s_addr != result_ip.s_addr)
 		{
-#endif /* !USE_AMX */
-			syslog(LOG_INFO, "Client %s tried to redirect port to %s",
+#endif /* USE_AMX */
+			syslog(LOG_WARNING, "Client %s tried to redirect port to %s",
 			       inet_ntoa(h->clientaddr), int_ip);
 			ClearNameValueList(&data);
 			SoapError(h, 718, "ConflictInMappingEntry");
@@ -690,8 +690,15 @@ AddAnyPortMapping(struct upnphttp * h, const char * action, const char * ns)
 	/* check if NewInternalAddress is the client address */
 	if(GETFLAG(SECUREMODEMASK))
 	{
+#ifdef USE_AMX
+		char ip_str[INET6_ADDRSTRLEN] = {0};
+
+		inet_ntop((h->ipv6) ? AF_INET6 : AF_INET, (h->ipv6) ? (void*)&h->clientaddr_v6 : (void*)&h->clientaddr, ip_str, INET6_ADDRSTRLEN);
+		if(are_addresses_from_same_host(int_ip, ip_str) == 0)
+#else
 		if(h->clientaddr.s_addr != result_ip.s_addr)
-		{
+#endif /* USE_AMX */
+ 		{
 			syslog(LOG_INFO, "Client %s tried to redirect port to %s",
 			       inet_ntoa(h->clientaddr), int_ip);
 			ClearNameValueList(&data);
@@ -931,7 +938,14 @@ DeletePortMapping(struct upnphttp * h, const char * action, const char * ns)
 		{
 			if(inet_pton(AF_INET, int_ip, &int_ip_addr) > 0)
 			{
+#ifdef USE_AMX
+				char ip_str[INET6_ADDRSTRLEN] = {0};
+
+				inet_ntop((h->ipv6) ? AF_INET6 : AF_INET, (h->ipv6) ? (void*)&h->clientaddr_v6 : (void*)&h->clientaddr, ip_str, INET6_ADDRSTRLEN);
+				if(are_addresses_from_same_host(int_ip, ip_str) == 0)
+#else
 				if(h->clientaddr.s_addr != int_ip_addr.s_addr)
+#endif /* USE_AMX */
 				{
 					SoapError(h, 606, "Action not authorized");
 					/*SoapError(h, 714, "NoSuchEntryInArray");*/
-- 
