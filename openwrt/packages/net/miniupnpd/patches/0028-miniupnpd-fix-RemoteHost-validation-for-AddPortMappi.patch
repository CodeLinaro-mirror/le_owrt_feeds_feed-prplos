From f64a88638a7eab03c7469047105a17ae48c31e45 Mon Sep 17 00:00:00 2001
From: Mykola Hlukhenkyi <m.hlukhenkyi@inango-systems.com>
Date: Fri, 25 Jul 2025 21:10:38 +0300
Subject: [PATCH] miniupnpd: fix RemoteHost validation for AddPortMapping
 action

Input validation for RemoteHost is not implemented in miniupnp, so no
error was returned for hostname value

Add check for RemoteHost is not contain DNS host name

References: PCF-1954
Signed-Off-By: Mykola Hlukhenkyi <m.hlukhenkyi@inango-systems.com>
---
 miniupnpd/upnpsoap.c | 16 ++++++++++++++++
 1 file changed, 16 insertions(+)

diff --git miniupnpd/upnpsoap.c miniupnpd/upnpsoap.c
index a9962c8..9febd4a 100644
--- miniupnpd/upnpsoap.c
+++ miniupnpd/upnpsoap.c
@@ -442,6 +442,14 @@ AddPortMapping(struct upnphttp * h, const char * action, const char * ns)
 	/* IGD 2 MUST support both wildcard and specific IP address values
 	 * for RemoteHost (only the wildcard value was REQUIRED in release 1.0) */
 	r_host = GetValueFromNameValueList(&data, "NewRemoteHost");
+	
+	if (r_host && (r_host[0] != '\0') &&
+		(0 != strcmp(r_host, "*") &&
+		(inet_pton(AF_INET, r_host, &result_ip) <= 0)))
+	{
+		ClearNameValueList(&data);
+		SoapError(h, 600, "Argument Value Invalid");
+	}
 #ifndef SUPPORT_REMOTEHOST
 #ifdef UPNP_STRICT
 	if (r_host && (r_host[0] != '\0') && (0 != strcmp(r_host, "*")))
@@ -666,6 +674,14 @@ AddAnyPortMapping(struct upnphttp * h, const char * action, const char * ns)
 		ClearNameValueList(&data);
 		SoapError(h, 600, "Argument Value Invalid");
 	}
+	
+	if (r_host && (r_host[0] != '\0') &&
+		(0 != strcmp(r_host, "*") &&
+		(inet_pton(AF_INET, r_host, &result_ip) <= 0)))
+	{
+		ClearNameValueList(&data);
+		SoapError(h, 600, "Argument Value Invalid");
+	}
 #endif
 
 	if (!int_ip || !ext_port || !int_port || !protocol)
-- 
2.34.1

