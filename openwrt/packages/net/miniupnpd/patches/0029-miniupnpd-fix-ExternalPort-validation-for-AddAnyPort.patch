From dbaca4e603655d86c15de2bd1560ef5486a23f18 Mon Sep 17 00:00:00 2001
From: Mykola Hlukhenkyi <m.hlukhenkyi@inango-systems.com>
Date: Mon, 28 Jul 2025 16:48:00 +0300
Subject: [PATCH] miniupnpd: fix ExternalPort validation for AddAnyPortMapping
 action

miniupnpd does not return an error but selects a random port if
NewExternalPort is equal to 0.

Modify case when ExtPort is zero, return error 716 instead of
  selection a random free port

References: PCF-1956
Signed-Off-By: Mykola Hlukhenkyi <m.hlukhenkyi@inango-systems.com>
---
 miniupnpd/upnpsoap.c | 14 +++++---------
 1 file changed, 5 insertions(+), 9 deletions(-)

diff --git miniupnpd/upnpsoap.c miniupnpd/upnpsoap.c
index 9febd4a..6599c3e 100644
--- miniupnpd/upnpsoap.c
+++ miniupnpd/upnpsoap.c
@@ -691,17 +691,13 @@ AddAnyPortMapping(struct upnphttp * h, const char * action, const char * ns)
 		return;
 	}
 
-	/* If ext_port is not a number, it must be a "*" */
-	if (!is_numeric(ext_port) && 0 != strcmp(ext_port, "*"))
-	{
-		ClearNameValueList(&data);
-		SoapError(h, 402, "Invalid Args");
-		return;
-	}
-
+	/* If ext_port is "*" or "0", then return an error,
+	 * if ext_port is not numeric, atoi() will return 0 */
 	eport = (0 == strcmp(ext_port, "*")) ? 0 : (unsigned short)atoi(ext_port);
 	if (eport == 0) {
-		eport = 1024 + ((random() & 0x7ffffffL) % (65536-1024));
+		ClearNameValueList(&data);
+		SoapError(h, 716, "Wildcard not permited in ExtPort");
+		return;
 	}
 
 	iport = (unsigned short)atoi(int_port);
-- 
2.34.1

