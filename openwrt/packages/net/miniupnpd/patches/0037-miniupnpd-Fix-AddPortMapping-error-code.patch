+** SPDX-FileCopyrightText: Copyright (c) 2025 Inango
 **
 ** Redistribution and use in source and binary forms, with or
 ** without modification, are permitted provided that the following
@@ -62,6 +63,7 @@
 #ifndef AMXRDR_H_INCLUDED
 #define AMXRDR_H_INCLUDED
 
+#include <stdbool.h>
 #include <sys/types.h>
 #include "../commonrdr.h"
 
@@ -94,5 +96,6 @@ clear_redirect_rules(void);
 
 int delete_redirect_and_filter_rules(unsigned short eport, int proto);
 
+bool is_redirect_rule_with_other_origin(unsigned short eport, int proto);
 #endif
 
diff --git miniupnpd/upnpredirect.c miniupnpd/upnpredirect.c
index 65d6508..0da114f 100644
--- miniupnpd/upnpredirect.c
+++ miniupnpd/upnpredirect.c
@@ -430,6 +430,11 @@ upnp_redirect(const char * rhost, unsigned short eport,
 		       eport, protocol);
 		return -4;
 #endif /* CHECK_PORTINUSE */
+#ifdef USE_AMX
+        } else if (is_redirect_rule_with_other_origin(eport, proto)) {
+            syslog(LOG_INFO, "redirecting already exists but with different origin");
+            return -2;
+#endif
 	} else {
 		timestamp = (leaseduration > 0) ? upnp_time() + leaseduration : 0;
 		syslog(LOG_INFO, "redirecting port %hu to %s:%hu protocol %s for: %s",
-- 
