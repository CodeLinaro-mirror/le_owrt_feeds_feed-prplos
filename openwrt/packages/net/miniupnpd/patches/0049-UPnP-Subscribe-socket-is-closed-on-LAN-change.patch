+			{
+				snprintf(presentationurl, PRESENTATIONURL_MAX_LEN,
+		        	"http://%s/", lan_addrs.lh_first->str);
+			}
 			if(GETFLAG(PERFORMSTUNMASK))
 			{
 				if (update_ext_ip_addr_from_stun(0) != 0) {
@@ -3319,13 +3400,7 @@ shutdown:
