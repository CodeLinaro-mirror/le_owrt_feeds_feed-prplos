+static uint32_t parselanaddr_wrapper(void) {
+	struct lan_addr_s* lan_addr = NULL;
+	struct lan_addr_s* lan_addr2 = NULL;
+	int debug_flag = _debug_flag;
+
+	lan_addr = (struct lan_addr_s *) malloc(sizeof(struct lan_addr_s));
+	if (lan_addr == NULL)
+	{
+		INIT_PRINT_ERR("malloc(sizeof(struct lan_addr_s)): %m");
+		return 1;
+	}
+	if(parselanaddr(lan_addr, _listening_ip, debug_flag) != 0)
+	{
+		INIT_PRINT_ERR("can't parse \"%s\" as a valid "
+#ifndef ENABLE_IPV6
+				"LAN address or "
+#endif
+				"interface name\n", _listening_ip);
+		free(lan_addr);
+		return 1;
+	}
+	/* check if we already have this address */
+	for(lan_addr2 = lan_addrs.lh_first; lan_addr2 != NULL; lan_addr2 = lan_addr2->list.le_next)
+	{
+		if (0 == strncmp(lan_addr2->str, lan_addr->str, 15))
+			break;
+	}
+	if (lan_addr2 == NULL)
+		LIST_INSERT_HEAD(&lan_addrs, lan_addr, list);
+	return 0;
+}
