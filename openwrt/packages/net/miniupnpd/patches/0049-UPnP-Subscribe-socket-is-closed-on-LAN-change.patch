+				}
+#else
+				{
+					syslog(LOG_ERR, "Failed to open sockets for NAT PMP.");
+				} else {
+					syslog(LOG_NOTICE, "Listening for NAT-PMP traffic on port %u",
+						NATPMP_PORT);
+				}
+#endif
+			}
+#endif
