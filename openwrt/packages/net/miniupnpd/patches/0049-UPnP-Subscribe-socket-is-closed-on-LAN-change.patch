+static void clean_snotify(int **snotify_addr, int addr_count) {
+	int32_t i;
+	int *snotify = *snotify_addr;
+
+#ifndef ENABLE_IPV6
+	for(i = 0; i < addr_count; i++) {
+#else
+	for(i = 0; i < addr_count * 2; i++) {
+#endif
+		close(snotify[i]);
+	}
+	free(snotify);
+	snotify = NULL;
+}
+
+static void clean_snatpmp(int **snatpmp_addr, int addr_count) {
+	int32_t i;
+	int *snatpmp = *snatpmp_addr;
+
+	for(i=0; i<addr_count; i++) {
+		if(snatpmp[i]>=0)
+		{
+			close(snatpmp[i]);
+			snatpmp[i] = -1;
+		}
+	}
+	free(snatpmp);
+	snatpmp = NULL;
+}
+
+static void clear_lan_addrs(void) {
+	struct lan_addr_s* lan_addr = NULL;
+
+	while(lan_addrs.lh_first != NULL) {
+		lan_addr = lan_addrs.lh_first;
+		LIST_REMOVE(lan_addrs.lh_first, list);
+		free(lan_addr);
+	}
+}
