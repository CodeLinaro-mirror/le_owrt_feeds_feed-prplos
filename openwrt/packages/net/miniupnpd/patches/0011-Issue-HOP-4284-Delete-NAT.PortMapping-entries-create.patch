 		syslog(LOG_WARNING, "Port forwarding is now disabled");
+#endif
 	} else {
 		syslog(LOG_INFO, "STUN: ... done");
 	}
 
 	use_ext_ip_addr = ext_addr_str;
+#ifndef ALLOW_RESERVED_ADDR
 	disable_port_forwarding = restrictive_nat;
+#endif
 	return 0;
 }
 
