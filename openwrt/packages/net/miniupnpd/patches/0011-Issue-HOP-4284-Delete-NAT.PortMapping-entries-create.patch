+++ miniupnpd/amx/amxpmp.h
@@ -101,5 +101,7 @@ int update_portmapping_desc_timestamp_pm(amxb_bus_ctx_t* bus_ctx, const char* if
                                          unsigned short eport, int proto,
                                          const char* desc, unsigned int timestamp);
 
