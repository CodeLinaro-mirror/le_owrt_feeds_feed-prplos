From 38733a0fdc20c20a6eac3cb278464260db83fa9c Mon Sep 17 00:00:00 2001
From: alexandre fiset <alexandre.fiset_ext@softathome.com>
Date: Tue, 25 Apr 2023 11:10:38 +0200
Subject: [PATCH] odhcpd can't find physical interface name of lan

    To translate the logical interface name (e.g. lan) to the physical name (e.g. br-lan)
     - first odhcpd will look in /etc/config/dhcp for dhcp.lan.ifname or dhcp.lan.networkid
     - then, if compiled with WITH_UBUS, odhcpd will look at /etc/config/network and the interface name is overruled even if not found
---
 src/config.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/src/config.c b/src/config.c
index 4e3db86..1f39dd6 100644
--- a/src/config.c
+++ b/src/config.c
@@ -565,7 +565,7 @@ int config_parse_interface(void *data, size_t len, const char *name, bool overwr
 	}
 
 #ifdef WITH_UBUS
-	if (overwrite || !iface->ifname)
+	if (!iface->ifname && !ifname)
 		ifname = ubus_get_ifname(name);
 #endif
 
-- 
2.39.2

