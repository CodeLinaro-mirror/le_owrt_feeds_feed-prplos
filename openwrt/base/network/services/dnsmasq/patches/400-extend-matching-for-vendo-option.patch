From e68cd84336564daac1c67c2803f614edf09faccd Mon Sep 17 00:00:00 2001
From: Alexandre FISET <alexandre.fiset_ext@softathome.com>
Date: Fri, 29 Sep 2023 09:15:17 +0200
Subject: [PATCH] Extend matching for vendo option in dnsmasq
 [new]

Add prefix, suffix and exact matching to dnsmasq vendorclassID option when it was previously only supporting substring matching.
As a consequence, wildcard at the beginning of the string to match are no more use as a matching character, but as a type matching option.
ex :

prefix matching : test*
suffix matching : *test
Substring matching : *test*
Exact matching : test

before :
Substring matching : test

will only work for argument : dhcp-vendorclass, using argument dhcp-match with dhcp option 60 will still keep previous definition to avoid collision with other options when matching
---
 src/rfc2131.c | 40 ++++++++++++++++++++++++++++++----------
 1 file changed, 30 insertions(+), 10 deletions(-)

diff --git a/src/rfc2131.c b/src/rfc2131.c
index 937afb43..335c4491 100644
--- a/src/rfc2131.c
+++ b/src/rfc2131.c
@@ -492,16 +492,36 @@ size_t dhcp_reply(struct dhcp_context *context, char *iface_name, int int_index,
 	continue;
 
       if ((opt = option_find(mess, sz, mopt, 1)))
-	{
-	  int i;
-	  for (i = 0; i <= (option_len(opt) - vendor->len); i++)
-	    if (memcmp(vendor->data, option_ptr(opt, i), vendor->len) == 0)
-	      {
-		vendor->netid.next = netid;
-		netid = &vendor->netid;
-		break;
-	      }
-	}
+	    {
+	      char* o_curs = vendor->data;
+          int o_len = vendor->len;
+          int prefix = 0;
+          int suffix = 0;
+	      if(*(vendor->data) == '*')
+            {
+              o_curs++;
+              suffix = 1;
+              o_len--;
+            }
+          if(*(o_curs+o_len-1) == '*')
+            {
+              prefix = 1;
+              o_len--;
+            }
+	      for (int i = 0; i <= (option_len(opt) - o_len);)
+	        {
+		      if (memcmp(o_curs, option_ptr(opt, i), o_len) == 0 && (o_len == (option_len(opt) - i) || prefix))
+	            {
+		          vendor->netid.next = netid;
+		          netid = &vendor->netid;
+		          break;
+	            }
+		      if (suffix)
+            i++;
+              else
+            i += option_len(opt);
+	        }
+	    }
     }
 
   /* mark vendor-encapsulated options which match the client-supplied vendor class,
