 	    state->tags = &mac_opt->netid;
diff --git a/src/util.c b/src/util.c
index d2ff72f..ad1597f 100644
--- a/src/util.c
+++ b/src/util.c
@@ -655,6 +655,18 @@ int memcmp_masked(unsigned char *a, unsigned char *b, int len, unsigned int mask
   return count;
 }
 
+/* return 0 for no match, or nb matched*/
+int memcmp_masked_bytes(unsigned char *a, unsigned char *b, int len, unsigned char *mask)
+{
+  int i, count;
+  for (count = 1, i = len - 1; i >= 0; i--)
+    if ((a[i] & mask[i]) == (b[i] & mask[i]))
+      count ++;
+    else
+      return 0;
+  return count;
+}
+
 /* _note_ may copy buffer */
 int expand_buf(struct iovec *iov, size_t size)
 {
