-          int prefix = 0;
-          int suffix = 0;
+	      int o_len = vendor->len;
+	      int prefix = 0;
+	      int suffix = 0;
 	      if(*(vendor->data) == '*')
-            {
-              o_curs++;
-              suffix = 1;
-              o_len--;
-            }
-          if(*(o_curs+o_len-1) == '*')
-            {
-              prefix = 1;
-              o_len--;
-            }
