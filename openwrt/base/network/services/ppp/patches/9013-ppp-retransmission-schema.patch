diff --git a/pppd/fsm.c b/pppd/fsm.c
index 9d37e55..a7081e0 100644
--- a/pppd/fsm.c
+++ b/pppd/fsm.c
@@ -82,6 +82,8 @@ fsm_init(fsm *f)
     f->timeouttime = DEFTIMEOUT;
     f->maxconfreqtransmits = DEFMAXCONFREQS;
     f->maxtermtransmits = DEFMAXTERMREQS;
+    f->confreqschema = NULL;
+    f->termreqschema = NULL;
     f->maxnakloops = DEFMAXNAKLOOPS;
     f->term_reason_len = 0;
 }
@@ -167,6 +169,18 @@ fsm_open(fsm *f)
     switch( f->state ){
     case INITIAL:
 	f->state = STARTING;
+	if (f->confreqschema  == NULL) {
+	    notice("Not using confreq schema, converting standard parameters to a schema...");
+	    /* timeouttime is in seconds whereas the timepoints are in milliseconds */
+	    f->confreqschema = generate_timepoints(f->timeouttime * 1000, f->maxconfreqtransmits);
+	}
+   reset(f->confreqschema);
+	if (f->termreqschema  == NULL) {
+	    notice("Not using termreq schema, converting standard parameters to a schema...");
+	    /* timeouttime is in seconds whereas the timepoints are in milliseconds */
+	    f->termreqschema = generate_timepoints(f->timeouttime * 1000, f->maxtermtransmits);
+   reset(f->termreqschema);
+	}
 	if( f->callbacks->starting )
 	    (*f->callbacks->starting)(f);
 	break;
@@ -208,12 +222,12 @@ terminate_layer(fsm *f, int nextstate)
     else if( f->callbacks->down )
 	(*f->callbacks->down)(f);	/* Inform upper layers we're down */
 
-    /* Init restart counter and send Terminate-Request */
-    f->retransmits = f->maxtermtransmits;
+    /* Send Terminate-Request */
+    int timeout_value = next(f->termreqschema);
     fsm_sdata(f, TERMREQ, f->reqid = ++f->id,
 	      (u_char *) f->term_reason, f->term_reason_len);
 
-    if (f->retransmits == 0) {
+    if (timeout_value == ERROR_NO_TIMEPOINT_LEFT) {
 	/*
 	 * User asked for no terminate requests at all; just close it.
 	 * We've already fired off one Terminate-Request just to be nice
@@ -225,8 +239,8 @@ terminate_layer(fsm *f, int nextstate)
 	return;
     }
 
-    TIMEOUT(fsm_timeout, f, f->timeouttime);
-    --f->retransmits;
+    dbglog("Next Term Req timeout: %dms", timeout_value);
+    timeout(fsm_timeout, f, timeout_value / 1000, timeout_value % 1000);
 
     f->state = nextstate;
 }
@@ -274,7 +288,9 @@ fsm_timeout(void *arg)
     switch (f->state) {
     case CLOSING:
     case STOPPING:
-	if( f->retransmits <= 0 ){
+	{
+	int timeout_value = next(f->termreqschema);
+	if( timeout_value == ERROR_NO_TIMEPOINT_LEFT ){
 	    /*
 	     * We've waited for an ack long enough.  Peer probably heard us.
 	     */
@@ -285,15 +301,16 @@ fsm_timeout(void *arg)
 	    /* Send Terminate-Request */
 	    fsm_sdata(f, TERMREQ, f->reqid = ++f->id,
 		      (u_char *) f->term_reason, f->term_reason_len);
-	    TIMEOUT(fsm_timeout, f, f->timeouttime);
-	    --f->retransmits;
+	    dbglog("Next Term Req timeout: %dms", timeout_value);
+	    timeout(fsm_timeout, f, timeout_value / 1000, timeout_value % 1000);
+	}
 	}
 	break;
 
     case REQSENT:
     case ACKRCVD:
     case ACKSENT:
-	if (f->retransmits <= 0) {
+	if (peek(f->confreqschema) == ERROR_NO_TIMEPOINT_LEFT) {
 	    warn("%s: timeout sending Config-Requests\n", PROTO_NAME(f));
 	    f->state = STOPPED;
 	    if( (f->flags & OPT_PASSIVE) == 0 && f->callbacks->finished )
@@ -483,7 +500,7 @@ fsm_rconfack(fsm *f, int id, u_char *inp, int len)
 
     case REQSENT:
 	f->state = ACKRCVD;
-	f->retransmits = f->maxconfreqtransmits;
+	reset(f->confreqschema);
 	break;
 
     case ACKRCVD:
@@ -496,7 +513,7 @@ fsm_rconfack(fsm *f, int id, u_char *inp, int len)
     case ACKSENT:
 	UNTIMEOUT(fsm_timeout, f);	/* Cancel timeout */
 	f->state = OPENED;
-	f->retransmits = f->maxconfreqtransmits;
+	reset(f->confreqschema);
 	if (f->callbacks->up)
 	    (*f->callbacks->up)(f);	/* Inform upper layers */
 	break;
@@ -594,7 +611,7 @@ fsm_rtermreq(fsm *f, int id, u_char *p, int len)
 	    info("%s terminated by peer (%0.*v)", PROTO_NAME(f), len, p);
 	} else
 	    info("%s terminated by peer", PROTO_NAME(f));
-	f->retransmits = 0;
+	f->termreqschema->next = NULL;
 	f->state = STOPPING;
 	if (f->callbacks->down)
 	    (*f->callbacks->down)(f);	/* Inform upper layers */
@@ -721,7 +738,7 @@ fsm_sconfreq(fsm *f, int retransmit)
 
     if( !retransmit ){
 	/* New request - reset retransmission counter, use new ID */
-	f->retransmits = f->maxconfreqtransmits;
+	reset(f->confreqschema);
 	f->reqid = ++f->id;
     }
 
@@ -744,8 +761,11 @@ fsm_sconfreq(fsm *f, int retransmit)
     fsm_sdata(f, CONFREQ, f->reqid, outp, cilen);
 
     /* start the retransmit timer */
-    --f->retransmits;
-    TIMEOUT(fsm_timeout, f, f->timeouttime);
+    int timeout_value = next(f->confreqschema);
+    if (timeout_value != ERROR_NO_TIMEPOINT_LEFT) {
+        dbglog("Next Conf Req timeout: %dms", timeout_value);
+        timeout(fsm_timeout, f, timeout_value / 1000, timeout_value % 1000);
+    }
 }
 
 
