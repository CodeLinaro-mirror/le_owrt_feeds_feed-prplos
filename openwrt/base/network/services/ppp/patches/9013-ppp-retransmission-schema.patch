diff --git a/pppd/auth.c b/pppd/auth.c
index bea8f54..a9db666 100644
--- a/pppd/auth.c
+++ b/pppd/auth.c
@@ -999,7 +999,9 @@ auth_peer_fail(int unit, int protocol)
     /*
      * Authentication failure: take the link down
      */
-    status = EXIT_PEER_AUTH_FAILED;
+    if (status != EXIT_PEER_AUTH_NO_REPLY) {
+        status = EXIT_PEER_AUTH_FAILED;
+    }
     lcp_close(unit, "Authentication failed");
 }
 
@@ -1074,7 +1076,9 @@ auth_withpeer_fail(int unit, int protocol)
      * is no point in persisting without any way to get updated
      * authentication secrets.
      */
-    status = EXIT_AUTH_TOPEER_FAILED;
+    if (status != EXIT_AUTH_TOPEER_NO_REPLY) {
+        status = EXIT_AUTH_TOPEER_FAILED;
+    }
     lcp_close(unit, "Failed to authenticate ourselves to peer");
 }
 
diff --git a/pppd/chap-new.c b/pppd/chap-new.c
index ea7323b..617afbe 100644
--- a/pppd/chap-new.c
+++ b/pppd/chap-new.c
@@ -36,6 +36,7 @@
 #include "session.h"
 #include "chap-new.h"
 #include "chap-md5.h"
+#include "generator.h"
 
 #ifdef CHAPMS
 #include "chap_ms.h"
@@ -45,6 +46,7 @@
 #endif
 
 int chap_mdtype_all = MDTYPE_ALL;
+timepoints_t *chap_schema = NULL;   /* Custom schema for CHAP Timeouts, takes precedence over chap_timeout_time and chap_max_transmits */
 
 /* Hook for a plugin to validate CHAP challenge */
 int (*chap_verify_hook)(char *name, char *ourname, int id,
@@ -64,11 +66,14 @@ int chapms_strip_domain = 0;
 /*
  * Command-line options.
  */
+static void set_chap_interval_schema(char **argv);
 static option_t chap_option_list[] = {
 	{ "chap-restart", o_int, &chap_server_timeout_time,
 	  "Set timeout for CHAP (as server)", OPT_PRIO },
 	{ "chap-max-challenge", o_int, &chap_max_transmits,
 	  "Set max #xmits for challenge", OPT_PRIO },
+	{ "chap-interval-schema", o_special, (void *)set_chap_interval_schema,
+	  "Set a list of intervals for variable CHAP timeouts, ignores chap-restart and chap-max-challenge", OPT_PRIV | OPT_A2LIST },
 	{ "chap-interval", o_int, &chap_rechallenge_time,
 	  "Set interval for rechallenge", OPT_PRIO },
 	{ "chap-timeout", o_int, &chap_client_timeout_time,
@@ -120,6 +125,7 @@ static struct chap_server_state {
 static void chap_init(int unit);
 static void chap_lowerup(int unit);
 static void chap_lowerdown(int unit);
+void chap_open(int unit);
 static void chap_server_timeout(void *arg);
 static void chap_client_timeout(void *arg);
 static void chap_generate_challenge(struct chap_server_state *ss);
@@ -141,6 +147,13 @@ static int chap_print_pkt(unsigned char *p, int plen,
 /* List of digest types that we know about */
 static struct chap_digest_type *chap_digests;
 
+static void
+set_chap_interval_schema(char **argv)
+{
+       char *schema = *argv;
+       chap_schema = initialize_timepoints(schema);
+}
+
 /*
  * chap_init - reset to initial state.
  */
@@ -207,6 +220,16 @@ chap_lowerdown(int unit)
 	ss->flags = 0;
 }
 
+void
+chap_open(int unit)
+{
+	if (chap_schema == NULL) {
+	  notice("Not using chap schema, converting standard parameters to a schema...");
+	  /* chap_timeout_time is in seconds whereas the timepoints are in milliseconds */
+	  chap_schema = generate_timepoints(chap_server_timeout_time * 1000, chap_max_transmits);
+	}
+}
+
 /*
  * chap_auth_peer - Start authenticating the peer.
  * If the lower layer is already up, we start sending challenges,
@@ -274,15 +297,18 @@ static void
 chap_server_timeout(void *arg)
 {
 	struct chap_server_state *ss = arg;
+	int timeout_value = next(chap_schema);
 
 	ss->flags &= ~TIMEOUT_PENDING;
 	if ((ss->flags & CHALLENGE_VALID) == 0) {
 		ss->challenge_xmits = 0;
 		chap_generate_challenge(ss);
 		ss->flags |= CHALLENGE_VALID;
-	} else if (ss->challenge_xmits >= chap_max_transmits) {
+	} else if (timeout_value == ERROR_NO_TIMEPOINT_LEFT) {
 		ss->flags &= ~CHALLENGE_VALID;
 		ss->flags |= AUTH_DONE | AUTH_FAILED;
+		status = EXIT_PEER_AUTH_NO_REPLY;
+		cleanup_timepoints(&chap_schema);
 		auth_peer_fail(0, PPP_CHAP);
 		return;
 	}
@@ -290,7 +316,8 @@ chap_server_timeout(void *arg)
 	output(0, ss->challenge, ss->challenge_pktlen);
 	++ss->challenge_xmits;
 	ss->flags |= TIMEOUT_PENDING;
-	TIMEOUT(chap_server_timeout, arg, chap_server_timeout_time);
+	dbglog("Next CHAP Req timeout: %dms", timeout_value);
+	timeout(chap_server_timeout, arg, timeout_value / 1000, timeout_value % 1000);
 }
 
 /* chap_client_timeout - Authentication with peer timed out. */
@@ -426,6 +453,7 @@ chap_handle_response(struct chap_server_state *ss, int id,
 		    }
 		}
 		if (ss->flags & AUTH_FAILED) {
+			cleanup_timepoints(&chap_schema);
 			auth_peer_fail(0, PPP_CHAP);
 		} else {
 			if ((ss->flags & AUTH_DONE) == 0)
@@ -564,6 +592,7 @@ chap_handle_status(struct chap_client_state *cs, int code, int id,
 	else {
 		cs->flags |= AUTH_FAILED;
 		my_error("CHAP authentication failed");
+		cleanup_timepoints(&chap_schema);
 		auth_withpeer_fail(0, PPP_CHAP);
 	}
 }
@@ -611,11 +640,13 @@ chap_protrej(int unit)
 	}
 	if (ss->flags & AUTH_STARTED) {
 		ss->flags = 0;
+		cleanup_timepoints(&chap_schema);
 		auth_peer_fail(0, PPP_CHAP);
 	}
 	if ((cs->flags & (AUTH_STARTED|AUTH_DONE)) == AUTH_STARTED) {
 		cs->flags &= ~AUTH_STARTED;
 		my_error("CHAP authentication failed due to protocol-reject");
+		cleanup_timepoints(&chap_schema);
 		auth_withpeer_fail(0, PPP_CHAP);
 	}
 }
@@ -689,7 +720,7 @@ struct protent chap_protent = {
 	chap_protrej,
 	chap_lowerup,
 	chap_lowerdown,
-	NULL,		/* open */
+	chap_open,
 	NULL,		/* close */
 	chap_print_pkt,
 	NULL,		/* datainput */
