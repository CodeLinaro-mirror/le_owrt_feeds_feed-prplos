diff --git a/pppd/plugins/pppoe/discovery.c b/pppd/plugins/pppoe/discovery.c
index 6012fa6..6f61c1c 100644
--- a/pppd/plugins/pppoe/discovery.c
+++ b/pppd/plugins/pppoe/discovery.c
@@ -668,3 +668,143 @@ discovery(PPPoEConnection *conn)
     conn->discoveryState = STATE_SESSION;
     return;
 }
+
+/*
+ * Timeout waiting for PADO.
+ */
+void
+send_padi_timeout(void *arg)
+{
+   PPPoEConnection *conn = (PPPoEConnection *)arg;
+
+   sendPADI(conn);
+   timeout(send_padi_timeout, (void *)conn, conn->discoveryTimeout, 0);
+}
+
+/*
+ * Timeout waiting for PADS.
+ */
+void
+send_padr_timeout(void *arg)
+{
+   PPPoEConnection *conn = (PPPoEConnection *)arg;
+
+   sendPADR(conn);
+   timeout(send_padr_timeout, (void *)conn, conn->discoveryTimeout, 0);
+}
+
+void
+discovery_unblocked(PPPoEConnection *conn)
+{
+    sendPADI(conn);
+    conn->discoveryState = STATE_SENT_PADI;
+    conn->seenMaxPayload = 0;
+    conn->error = 0;
+
+    timeout(send_padi_timeout, (void *)conn, conn->discoveryTimeout, 0);
+}
+
+void
+handleDiscoveryPackets(PPPoEConnection *conn)
+{
+    PPPoEPacket packet;
+    int len;
+
+       if (conn->discoveryState == STATE_SESSION) {
+               return;
+       }
+
+       /* Get the packet */
+       receivePacket(conn->discoverySocket, &packet, &len);
+
+       /* Check length */
+       if (ntohs(packet.length) + HDR_SIZE > len) {
+           my_error("Bogus PPPoE length field (%u)",
+                  (unsigned int) ntohs(packet.length));
+           return;
+       }
+
+#ifdef USE_BPF
+       /* If it's not a Discovery packet, loop again */
+       if (etherType(&packet) != Eth_PPPOE_Discovery) return;
+#endif
+
+       /* If it's not from the AC, it's not for me */
+       if (packet.code == CODE_PADS && memcmp(packet.ethHdr.h_source, conn->peerEth, ETH_ALEN)) return;
+
+       /* If it's not for us, loop again */
+       if (!packetIsForMe(conn, &packet)) return;
+
+       if (conn->discoveryState == STATE_SENT_PADI && packet.code == CODE_PADO) {
+               struct PacketCriteria pc;
+               pc.conn          = conn;
+               pc.acNameOK      = (conn->acName)      ? 0 : 1;
+               pc.serviceNameOK = (conn->serviceName) ? 0 : 1;
+               pc.seenACName    = 0;
+               pc.seenServiceName = 0;
+
+           if (NOT_UNICAST(packet.ethHdr.h_source)) {
+               my_error("Ignoring PADO packet from non-unicast MAC address");
+               return;
+           }
+           if (conn->req_peer
+               && memcmp(packet.ethHdr.h_source, conn->req_peer_mac, ETH_ALEN) != 0) {
+               warn("Ignoring PADO packet from wrong MAC address");
+               return;
+           }
+           if (parsePacket(&packet, parsePADOTags, &pc) < 0)
+               return;
+           if (conn->error)
+               return;
+           if (!pc.seenACName) {
+               my_error("Ignoring PADO packet with no AC-Name tag");
+               return;
+           }
+           if (!pc.seenServiceName) {
+               my_error("Ignoring PADO packet with no Service-Name tag");
+               return;
+           }
+           conn->numPADOs++;
+           if (pc.acNameOK && pc.serviceNameOK) {
+               memcpy(conn->peerEth, packet.ethHdr.h_source, ETH_ALEN);
+               conn->discoveryState = STATE_RECEIVED_PADO;
+               untimeout(send_padi_timeout, (void *)conn);  /* Cancel timeout */
+
+               sendPADR(conn);
+               conn->discoveryState = STATE_SENT_PADR;
+               timeout(send_padr_timeout, (void *)conn, conn->discoveryTimeout, 0);
+               return;
+           }
+       } else if (conn->discoveryState == STATE_SENT_PADR && packet.code == CODE_PADS) {
+           /* Parse for goodies */
+           if (parsePacket(&packet, parsePADSTags, conn) < 0)
+               return;
+           if (conn->error)
+               return;
+           untimeout(send_padr_timeout, (void *)conn);  /* Cancel timeout */
+           conn->discoveryState = STATE_SESSION;
+
+           /* Don't bother with ntohs; we'll just end up converting it back... */
+           conn->session = packet.session;
+
+           info("PPP session is %d", (int) ntohs(conn->session));
+
+           /* RFC 2516 says session id MUST NOT be zero or 0xFFFF */
+           if (ntohs(conn->session) == 0 || ntohs(conn->session) == 0xFFFF) {
+               my_error("Access concentrator used a session value of %x -- the AC is violating RFC 2516", (unsigned int) ntohs(conn->session));
+           }
+
+           if (!conn->seenMaxPayload) {
+           /* RFC 4638: MUST limit MTU/MRU to 1492 */
+           if (lcp_allowoptions[0].mru > ETH_PPPOE_MTU)
+               lcp_allowoptions[0].mru = ETH_PPPOE_MTU;
+           if (lcp_wantoptions[0].mru > ETH_PPPOE_MTU)
+               lcp_wantoptions[0].mru = ETH_PPPOE_MTU;
+           }
+
+           /* We're done. */
+           conn->discoveryState = STATE_SESSION;
+           devfd = PPPOEConnectDiscoveredDevice();
+           start_ppp_link(0);
+       }
+}
\ No newline at end of file
