+static void PPPOEDisconnectDevice(void);
 static option_t Options[] = {
     { "device name", o_wild, (void *) &PPPoEDevnameHook,
       "PPPoE device name",
@@ -105,6 +106,18 @@ static option_t Options[] = {
 int (*OldDevnameHook)(char *cmd, char **argv, int doit) = NULL;
 static PPPoEConnection *conn = NULL;
 
+void
+PPPOEDiscoveryWrap(void)
+{
+    discovery_unblocked(conn);
+}
+
+void
+PPPOEHandleDiscoveryPacketsWrap(void)
+{
+    handleDiscoveryPackets(conn);
+}
+
 /**********************************************************************
  * %FUNCTION: PPPOEInitDevice
  * %ARGUMENTS:
@@ -141,9 +154,8 @@ PPPOEInitDevice(void)
  * Connects PPPoE device.
  ***********************************************************************/
 static int
-PPPOEConnectDevice(void)
+PPPOEConnectDevice(bool blocking)
 {
-    struct sockaddr_pppox sp;
     struct ifreq ifr;
     int s;
 
@@ -214,12 +226,34 @@ PPPOEConnectDevice(void)
 	    my_error("Failed to create PPPoE discovery socket: %m");
 	    goto errout;
 	}
-	discovery(conn);
-	if (conn->discoveryState != STATE_SESSION) {
+    }
+
+    if(blocking) {
+        discovery(conn);
+        return PPPOEConnectDiscoveredDevice();
+    } else {
+        return conn->discoverySocket;
+    }
+
+errout:
+    if(conn->discoverySocket >= 0) {
+        sendPADT(conn, NULL);
+        close(conn->discoverySocket);
+        conn->discoverySocket = -1;
+    }
+    close(conn->sessionSocket);
+    return -1;
+}
+
+int
+PPPOEConnectDiscoveredDevice(void)
+{
+    struct sockaddr_pppox sp;
+
+	if (!existingSession && conn->discoveryState != STATE_SESSION) {
 	    my_error("Unable to complete PPPoE Discovery");
 	    goto errout;
 	}
-    }
 
     /* Set PPPoE session-number for further consumption */
     ppp_session_number = ntohs(conn->session);
@@ -265,7 +299,8 @@ PPPOEConnectDevice(void)
 	conn->discoverySocket = -1;
     }
     close(conn->sessionSocket);
-    return -1;
+    conn->sessionSocket =-1;
+    return conn->sessionSocket;
 }
 
 static void
@@ -299,10 +334,19 @@ PPPOEDisconnectDevice(void)
     sp.sa_addr.pppoe.sid = 0;
     memcpy(sp.sa_addr.pppoe.dev, conn->ifName, IFNAMSIZ);
     memcpy(sp.sa_addr.pppoe.remote, conn->peerEth, ETH_ALEN);
-    if (connect(conn->sessionSocket, (struct sockaddr *) &sp,
-		sizeof(struct sockaddr_pppox)) < 0 && errno != EALREADY)
-	my_error("Failed to disconnect PPPoE socket: %d %m", errno);
-    close(conn->sessionSocket);
+
+    if(!existingSession && conn->discoveryState == STATE_SENT_PADI) {
+        untimeout(send_padi_timeout, (void*)conn);  /* Cancel timeout */
+    } else if (conn->discoveryState == STATE_SENT_PADR) {
+        untimeout(send_padr_timeout, (void*)conn);  /* Cancel timeout */
+    }else if(conn->sessionSocket >= 0) {
+        if (connect(conn->sessionSocket, (struct sockaddr *) &sp,
+		    sizeof(struct sockaddr_pppox)) < 0 && errno != EALREADY){
+            my_error("Failed to disconnect PPPoE socket: %d %m", errno);
+        }
+        close(conn->sessionSocket);
+    }
+
     if (conn->discoverySocket >= 0) {
         sendPADT(conn, NULL);
 	close(conn->discoverySocket);
@@ -465,5 +509,7 @@ struct channel pppoe_channel = {
     .send_config = NULL,
     .recv_config = &PPPOERecvConfig,
     .close = NULL,
-    .cleanup = NULL
+    .cleanup = NULL,
+    .discovery = &PPPOEDiscoveryWrap,
+    .handle_discovery = &PPPOEHandleDiscoveryPacketsWrap
 };
