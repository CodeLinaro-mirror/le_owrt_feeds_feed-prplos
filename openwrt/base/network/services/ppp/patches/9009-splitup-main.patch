+        add_fd(sigpipe[0]);
+        /* wait if necessary */
+        if (!(got_sighup || got_sigterm || got_sigusr2 || got_sigchld))
+        wait_input(timeleft(&timo));
+        waiting = 0;
+        remove_fd(sigpipe[0]);
