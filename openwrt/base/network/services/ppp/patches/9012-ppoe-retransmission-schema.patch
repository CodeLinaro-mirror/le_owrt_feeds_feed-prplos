diff --git a/pppd/plugins/pppoe/discovery.c b/pppd/plugins/pppoe/discovery.c
index 6f61c1c..fca42fb 100644
--- a/pppd/plugins/pppoe/discovery.c
+++ b/pppd/plugins/pppoe/discovery.c
@@ -669,16 +669,34 @@ discovery(PPPoEConnection *conn)
     return;
 }
 
+void
+discovery_finished(void)
+{
+    devfd = PPPOEConnectDiscoveredDevice();
+    start_ppp_link(0);
+}
+
 /*
  * Timeout waiting for PADO.
  */
 void
 send_padi_timeout(void *arg)
 {
-   PPPoEConnection *conn = (PPPoEConnection *)arg;
-
-   sendPADI(conn);
-   timeout(send_padi_timeout, (void *)conn, conn->discoveryTimeout, 0);
+    PPPoEConnection *conn = (PPPoEConnection *)arg;
+    sendPADI(conn);
+    
+    int timeout_value = conn->padiSchema ? next(conn->padiSchema) : conn->discoveryTimeout;
+    if (timeout_value == ERROR_NO_TIMEPOINT_LEFT)
+    {
+        warn("Timeout waiting for PADO packets");
+        close(conn->discoverySocket);
+        conn->discoverySocket = -1;
+        discovery_finished();
+        return;
+    } else {
+        dbglog("Next PADI timeout: %dms", timeout_value);
+        timeout(send_padi_timeout, (void *)conn, timeout_value / 1000, timeout_value % 1000);
+    }
 }
 
 /*
@@ -687,21 +705,30 @@ send_padi_timeout(void *arg)
 void
 send_padr_timeout(void *arg)
 {
-   PPPoEConnection *conn = (PPPoEConnection *)arg;
-
-   sendPADR(conn);
-   timeout(send_padr_timeout, (void *)conn, conn->discoveryTimeout, 0);
+    PPPoEConnection *conn = (PPPoEConnection *)arg;
+    sendPADR(conn);
+ 
+    int timeout_value = conn->padrSchema ? next(conn->padrSchema) : conn->discoveryTimeout;
+    if (timeout_value == ERROR_NO_TIMEPOINT_LEFT)
+    {
+        warn("Timeout waiting for PADS packets");
+        close(conn->discoverySocket);
+        conn->discoverySocket = -1;
+        discovery_finished();
+        return;
+    } else {
+        dbglog("Next PADR timeout: %dms", timeout_value);
+        timeout(send_padr_timeout, (void *)conn, timeout_value / 1000, timeout_value % 1000);
+    }
 }
 
 void
 discovery_unblocked(PPPoEConnection *conn)
 {
-    sendPADI(conn);
+    send_padi_timeout((void *)conn);
     conn->discoveryState = STATE_SENT_PADI;
     conn->seenMaxPayload = 0;
     conn->error = 0;
-
-    timeout(send_padi_timeout, (void *)conn, conn->discoveryTimeout, 0);
 }
 
 void
@@ -770,9 +797,8 @@ handleDiscoveryPackets(PPPoEConnection *conn)
                conn->discoveryState = STATE_RECEIVED_PADO;
                untimeout(send_padi_timeout, (void *)conn);  /* Cancel timeout */
 
-               sendPADR(conn);
+               send_padr_timeout((void *)conn);
                conn->discoveryState = STATE_SENT_PADR;
-               timeout(send_padr_timeout, (void *)conn, conn->discoveryTimeout, 0);
                return;
            }
        } else if (conn->discoveryState == STATE_SENT_PADR && packet.code == CODE_PADS) {
@@ -804,7 +830,6 @@ handleDiscoveryPackets(PPPoEConnection *conn)
 
            /* We're done. */
            conn->discoveryState = STATE_SESSION;
-           devfd = PPPOEConnectDiscoveredDevice();
-           start_ppp_link(0);
+           discovery_finished();
        }
 }
