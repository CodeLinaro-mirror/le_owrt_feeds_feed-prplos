 }
 
@@ -159,6 +170,14 @@ PPPOEConnectDevice(bool blocking)
     struct ifreq ifr;
     int s;
 
+    /* Make sure we start our retransmission schema at the beginning */
+    if(conn->padiSchema) {
+        conn->padiSchema->reset(conn->padiSchema);
+    }
+    if(conn->padrSchema) {
+        conn->padrSchema->reset(conn->padrSchema);
+    }
+
     /* Open session socket before discovery phase, to avoid losing session */
     /* packets sent by peer just after PADS packet (noted on some Cisco    */
     /* server equipment).                                                  */
@@ -453,6 +472,20 @@ plugin_init(void)
     info("PPPoE plugin from pppd %s", VERSION);
 }
 
+static void
+set_padi_interval_schema(char **argv)
+{
+    char *schema = *argv;
+    pppoe_padi_interval_schema = initialize_timepoints(schema);
+}
+
+static void
+set_padr_interval_schema(char **argv)
+{
+    char *schema = *argv;
