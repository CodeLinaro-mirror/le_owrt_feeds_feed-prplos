diff --git a/common/zlib.h b/common/zlib.h
index 702a402..1ae764f 100644
--- a/common/zlib.h
+++ b/common/zlib.h
@@ -952,7 +952,7 @@ extern uLong EXPORT adler32 OF((uLong adler, const Bytef *buf, uInt len));
      while (read_buffer(buffer, length) != EOF) {
        adler = adler32(adler, buffer, length);
      }
-     if (adler != original_adler) error();
+     if (adler != original_adler) my_error();
 */
 
 extern uLong EXPORT crc32   OF((uLong crc, const Bytef *buf, uInt len));
@@ -968,7 +968,7 @@ extern uLong EXPORT crc32   OF((uLong crc, const Bytef *buf, uInt len));
      while (read_buffer(buffer, length) != EOF) {
        crc = crc32(crc, buffer, length);
      }
-     if (crc != original_crc) error();
+     if (crc != original_crc) my_error();
 */
 
 
diff --git a/pppd/auth.c b/pppd/auth.c
index a21477b..a5d337b 100644
--- a/pppd/auth.c
+++ b/pppd/auth.c
@@ -852,7 +852,7 @@ link_established(int unit)
 	if (passwd[0] == 0 && !explicit_passwd) {
 	    passwd_from_file = 1;
 	    if (!get_pap_passwd(passwd))
-		error("No secret found for PAP login");
+		my_error("No secret found for PAP login");
 	}
 	upap_authwithpeer(unit, user, passwd);
 	auth |= PAP_WITHPEER;
@@ -1491,7 +1491,7 @@ check_passwd(int unit,
     ret = UPAP_AUTHNAK;
     f = fopen(filename, "r");
     if (f == NULL) {
-	error("Can't open PAP password file %s: %m", filename);
+	my_error("Can't open PAP password file %s: %m", filename);
 
     } else {
 	check_access(f, filename);
@@ -1792,7 +1792,7 @@ get_secret(int unit, char *client, char *server,
 	strlcpy(secbuf, passwd, sizeof(secbuf));
     } else if (!am_server && chap_passwd_hook) {
 	if ( (*chap_passwd_hook)(client, secbuf) < 0) {
-	    error("Unable to obtain CHAP password for %s on %s from plugin",
+	    my_error("Unable to obtain CHAP password for %s on %s from plugin",
 		  client, server);
 	    return 0;
 	}
@@ -1803,7 +1803,7 @@ get_secret(int unit, char *client, char *server,
 
 	f = fopen(filename, "r");
 	if (f == NULL) {
-	    error("Can't open chap secret file %s: %m", filename);
+	    my_error("Can't open chap secret file %s: %m", filename);
 	    return 0;
 	}
 	check_access(f, filename);
@@ -1823,7 +1823,7 @@ get_secret(int unit, char *client, char *server,
 
     len = strlen(secbuf);
     if (len > MAXSECRETLEN) {
-	error("Secret for %s on %s is too long", client, server);
+	my_error("Secret for %s on %s is too long", client, server);
 	len = MAXSECRETLEN;
     }
     BCOPY(secbuf, secret, len);
@@ -1856,7 +1856,7 @@ get_srp_secret(int unit, char *client, char *server,
 
 	fp = fopen(filename, "r");
 	if (fp == NULL) {
-	    error("Can't open srp secret file %s: %m", filename);
+	    my_error("Can't open srp secret file %s: %m", filename);
 	    return 0;
 	}
 	check_access(fp, filename);
diff --git a/pppd/ccp.c b/pppd/ccp.c
index cfd9a3f..5ad4ac7 100644
--- a/pppd/ccp.c
+++ b/pppd/ccp.c
@@ -542,7 +542,7 @@ ccp_input(int unit, u_char *p, int len)
 	notice("Compression disabled by peer.");
 #ifdef MPPE
 	if (ccp_wantoptions[unit].mppe) {
-	    error("MPPE disabled, closing LCP");
+	    my_error("MPPE disabled, closing LCP");
 	    lcp_close(unit, "MPPE disabled by peer");
 	}
 #endif /* MPPE */
@@ -606,7 +606,7 @@ ccp_protrej(int unit)
 
 #ifdef MPPE
     if (ccp_wantoptions[unit].mppe) {
-	error("MPPE required but peer negotiation failed");
+	my_error("MPPE required but peer negotiation failed");
 	lcp_close(unit, "MPPE required but peer negotiation failed");
     }
 #endif /* MPPE */
@@ -654,7 +654,7 @@ ccp_resetci(fsm *f)
 		auth_mschap_bits >>= 1;
 	    } while (auth_mschap_bits);
 	    if (numbits > 1) {
-		error("MPPE required, but auth done in both directions.");
+		my_error("MPPE required, but auth done in both directions.");
 		lcp_close(f->unit, "MPPE required but not available");
 		return;
 	    }
@@ -670,10 +670,10 @@ ccp_resetci(fsm *f)
 		auth_eap_bits &= (EAP_WITHPEER | EAP_PEER );
 
 		if ((numbits == 0) && (auth_eap_bits == 0)) {
-		    error("MPPE required, but MS-CHAP[v2] nor EAP-TLS auth are performed.");
+		    my_error("MPPE required, but MS-CHAP[v2] nor EAP-TLS auth are performed.");
 #else
 	    if (!numbits) {
-		error("MPPE required, but MS-CHAP[v2] auth not performed.");
+		my_error("MPPE required, but MS-CHAP[v2] auth not performed.");
 #endif
 		lcp_close(f->unit, "MPPE required but not available");
 		return;
@@ -681,7 +681,7 @@ ccp_resetci(fsm *f)
 
 	    /* A plugin (eg radius) may not have obtained key material. */
 	    if (!mppe_keys_set) {
-		error("MPPE required, but keys are not available.  "
+		my_error("MPPE required, but keys are not available.  "
 		      "Possible plugin problem?");
 		lcp_close(f->unit, "MPPE required but not available");
 		return;
@@ -735,7 +735,7 @@ ccp_resetci(fsm *f)
 	}
 	if (!go->mppe_40 && !go->mppe_56 && !go->mppe_128) {
 	    if (ccp_wantoptions[f->unit].mppe) {
-		error("MPPE required, but kernel has no support.");
+		my_error("MPPE required, but kernel has no support.");
 		lcp_close(f->unit, "MPPE required but not available");
 	    }
 	    go->mppe = go->mppe_stateless = 0;
@@ -1640,7 +1640,7 @@ ccp_reqci(fsm *f, u_char *p, int *lenp, int dont_nak)
  		} else {
 		    newret = CONFREJ;
  		    if (ccp_wantoptions[f->unit].mppe) {
- 			error("Cannot adjust MTU needed by MPPE.");
+ 			my_error("Cannot adjust MTU needed by MPPE.");
  			lcp_close(f->unit, "Cannot adjust MTU needed by MPPE.");
  		    }
  		}
@@ -1939,7 +1939,7 @@ ccp_down(fsm *f)
 	ccp_gotoptions[f->unit].mppe = 0;
 	if (lcp_fsm[f->unit].state == OPENED) {
 	    /* If LCP is not already going down, make sure it does. */
-	    error("MPPE disabled");
+	    my_error("MPPE disabled");
 	    lcp_close(f->unit, "MPPE disabled");
 	}
     }
@@ -2101,7 +2101,7 @@ ccp_datainput(int unit, u_char *pkt, int len)
 	    /*
 	     * Disable compression by taking CCP down.
 	     */
-	    error("Lost compression sync: disabling compression");
+	    my_error("Lost compression sync: disabling compression");
 	    ccp_close(unit, "Lost compression sync");
 #ifdef MPPE
 	    /* My module dosn't need this. J.D., 2003-07-06 */
@@ -2109,7 +2109,7 @@ ccp_datainput(int unit, u_char *pkt, int len)
 	     * If we were doing MPPE, we must also take the link down.
 	     */
 	    if (ccp_gotoptions[unit].mppe) {
-		error("Too many MPPE errors, closing LCP");
+		my_error("Too many MPPE errors, closing LCP");
 		lcp_close(unit, "Too many MPPE errors");
 	    }
 #endif /* MPPE */
diff --git a/pppd/chap-new.c b/pppd/chap-new.c
index ad2f5eb..ea7323b 100644
--- a/pppd/chap-new.c
+++ b/pppd/chap-new.c
@@ -219,7 +219,7 @@ chap_auth_peer(int unit, char *our_name, int digest_code)
 	struct chap_digest_type *dp;
 
 	if (ss->flags & AUTH_STARTED) {
-		error("CHAP: peer authentication already started!");
+		my_error("CHAP: peer authentication already started!");
 		return;
 	}
 	for (dp = chap_digests; dp != NULL; dp = dp->next)
@@ -249,7 +249,7 @@ chap_auth_with_peer(int unit, char *our_name, int digest_code)
 	struct chap_digest_type *dp;
 
 	if (cs->flags & AUTH_STARTED) {
-		error("CHAP: authentication with peer already started!");
+		my_error("CHAP: authentication with peer already started!");
 		return;
 	}
 	for (dp = chap_digests; dp != NULL; dp = dp->next)
@@ -301,7 +301,7 @@ chap_client_timeout(void *arg)
 
 	cs->flags &= ~TIMEOUT_PENDING;
 	cs->flags |= AUTH_DONE | AUTH_FAILED;
-	error("CHAP authentication timed out");
+	my_error("CHAP authentication timed out");
 	auth_withpeer_fail(0, PPP_CHAP);
 }
 
@@ -459,7 +459,7 @@ chap_verify_response(char *name, char *ourname, int id,
 
 	/* Get the secret that the peer is supposed to know */
 	if (!get_secret(0, name, ourname, (char *)secret, &secret_len, 1)) {
-		error("No CHAP secret found for authenticating %q", name);
+		my_error("No CHAP secret found for authenticating %q", name);
 		return 0;
 	}
 
@@ -563,7 +563,7 @@ chap_handle_status(struct chap_client_state *cs, int code, int id,
 		auth_withpeer_success(0, PPP_CHAP, cs->digest->code);
 	else {
 		cs->flags |= AUTH_FAILED;
-		error("CHAP authentication failed");
+		my_error("CHAP authentication failed");
 		auth_withpeer_fail(0, PPP_CHAP);
 	}
 }
@@ -615,7 +615,7 @@ chap_protrej(int unit)
 	}
 	if ((cs->flags & (AUTH_STARTED|AUTH_DONE)) == AUTH_STARTED) {
 		cs->flags &= ~AUTH_STARTED;
-		error("CHAP authentication failed due to protocol-reject");
+		my_error("CHAP authentication failed due to protocol-reject");
 		auth_withpeer_fail(0, PPP_CHAP);
 	}
 }
diff --git a/pppd/chap_ms.c b/pppd/chap_ms.c
index 744bf3e..53645d2 100644
--- a/pppd/chap_ms.c
+++ b/pppd/chap_ms.c
@@ -407,7 +407,7 @@ chapms2_check_success(int id, unsigned char *msg, int len)
 	if ((len < MS_AUTH_RESPONSE_LENGTH + 2) ||
 	    strncmp((char *)msg, "S=", 2) != 0) {
 		/* Packet does not start with "S=" */
-		error("MS-CHAPv2 Success packet is badly formed.");
+		my_error("MS-CHAPv2 Success packet is badly formed.");
 		return 0;
 	}
 	msg += 2;
@@ -415,7 +415,7 @@ chapms2_check_success(int id, unsigned char *msg, int len)
 	if (len < MS_AUTH_RESPONSE_LENGTH
 	    || !chapms2_find_in_response_cache(id, NULL /* challenge */, msg)) {
 		/* Authenticator Response did not match expected. */
-		error("MS-CHAPv2 mutual authentication failed.");
+		my_error("MS-CHAPv2 mutual authentication failed.");
 		return 0;
 	}
 	/* Authenticator Response matches. */
@@ -427,7 +427,7 @@ chapms2_check_success(int id, unsigned char *msg, int len)
 		msg += 2; /* Eat the delimiter */
 	} else if (len) {
 		/* Packet has extra text which does not begin " M=" */
-		error("MS-CHAPv2 Success packet is badly formed.");
+		my_error("MS-CHAPv2 Success packet is badly formed.");
 		return 0;
 	}
 	return 1;
@@ -493,14 +493,14 @@ chapms_handle_failure(unsigned char *inp, int len)
 
 		default:
 			free(msg);
-			error("Unknown MS-CHAP authentication failure: %.*v",
+			my_error("Unknown MS-CHAP authentication failure: %.*v",
 			      len, inp);
 			return;
 		}
 	}
 print_msg:
 	if (p != NULL)
-		error("MS-CHAP authentication failed: %v", p);
+		my_error("MS-CHAP authentication failed: %v", p);
 	free(msg);
 }
 
diff --git a/pppd/eap.c b/pppd/eap.c
index 7914655..46ddc70 100644
--- a/pppd/eap.c
+++ b/pppd/eap.c
@@ -239,7 +239,7 @@ eap_client_timeout(void *arg)
 	if (!eap_client_active(esp))
 		return;
 
-	error("EAP: timeout waiting for Request from peer");
+	my_error("EAP: timeout waiting for Request from peer");
 	auth_withpeer_fail(esp->es_unit, PPP_EAP);
 	esp->es_client.ea_state = eapBadAuth;
 }
@@ -822,7 +822,7 @@ eap_chap_verify_response(char *name, char *ourname, int id,
 
 	/* Get the secret that the peer is supposed to know */
 	if (!get_secret(0, name, ourname, (char *)secret, &secret_len, 1)) {
-		error("No CHAP secret found for authenticating %q", name);
+		my_error("No CHAP secret found for authenticating %q", name);
 		return 0;
 	}
 
@@ -914,9 +914,9 @@ eap_send_request(eap_state *esp)
 	if (esp->es_server.ea_maxrequests > 0 &&
 	    esp->es_server.ea_requests >= esp->es_server.ea_maxrequests) {
 		if (esp->es_server.ea_responses > 0)
-			error("EAP: too many Requests sent");
+			my_error("EAP: too many Requests sent");
 		else
-			error("EAP: no response to Requests");
+			my_error("EAP: no response to Requests");
 		eap_send_failure(esp);
 		return;
 	}
@@ -1352,11 +1352,11 @@ eap_protrej(int unit)
 	eap_state *esp = &eap_states[unit];
 
 	if (eap_client_active(esp)) {
-		error("EAP authentication failed due to Protocol-Reject");
+		my_error("EAP authentication failed due to Protocol-Reject");
 		auth_withpeer_fail(unit, PPP_EAP);
 	}
 	if (eap_server_active(esp)) {
-		error("EAP authentication of peer failed on Protocol-Reject");
+		my_error("EAP authentication of peer failed on Protocol-Reject");
 		auth_peer_fail(unit, PPP_EAP);
 	}
 	eap_lowerdown(unit);
@@ -1760,7 +1760,7 @@ eap_request(eap_state *esp, u_char *inp, int id, int len)
 	}
 
 	if (len <= 0) {
-		error("EAP: empty Request message discarded");
+		my_error("EAP: empty Request message discarded");
 		return;
 	}
 
@@ -1819,14 +1819,14 @@ eap_request(eap_state *esp, u_char *inp, int id, int len)
 
 	case EAPT_MD5CHAP:
 		if (len < 1) {
-			error("EAP: received MD5-Challenge with no data");
+			my_error("EAP: received MD5-Challenge with no data");
 			/* Bogus request; wait for something real. */
 			return;
 		}
 		GETCHAR(vallen, inp);
 		len--;
 		if (vallen < 8 || vallen > len) {
-			error("EAP: MD5-Challenge with bad length %d (8..%d)",
+			my_error("EAP: MD5-Challenge with bad length %d (8..%d)",
 			    vallen, len);
 			/* Try something better. */
 			eap_send_nak(esp, id, EAPT_SRP);
@@ -1877,7 +1877,7 @@ eap_request(eap_state *esp, u_char *inp, int id, int len)
 		case eapListen:
 
 			if (len < 1) {
-				error("EAP: received EAP-TLS Listen packet with no data");
+				my_error("EAP: received EAP-TLS Listen packet with no data");
 				/* Bogus request; wait for something real. */
 				return;
 			}
@@ -1917,7 +1917,7 @@ eap_request(eap_state *esp, u_char *inp, int id, int len)
 
 		case eapTlsRecv:
 			if (len < 1) {
-				error("EAP: discarding EAP-TLS Receive packet with no data");
+				my_error("EAP: discarding EAP-TLS Receive packet with no data");
 				/* Bogus request; wait for something real. */
 				return;
 			}
@@ -1962,7 +1962,7 @@ eap_request(eap_state *esp, u_char *inp, int id, int len)
 #ifdef USE_SRP
 	case EAPT_SRP:
 		if (len < 1) {
-			error("EAP: received empty SRP Request");
+			my_error("EAP: received empty SRP Request");
 			/* Bogus request; wait for something real. */
 			return;
 		}
@@ -1993,7 +1993,7 @@ eap_request(eap_state *esp, u_char *inp, int id, int len)
 				GETCHAR(vallen, inp);
 				len--;
 				if (vallen >= len) {
-					error("EAP: badly-formed SRP Challenge"
+					my_error("EAP: badly-formed SRP Challenge"
 					    " (name)");
 					/* Ignore badly-formed messages */
 					return;
@@ -2021,7 +2021,7 @@ eap_request(eap_state *esp, u_char *inp, int id, int len)
 				GETCHAR(vallen, inp);
 				len--;
 				if (vallen >= len) {
-					error("EAP: badly-formed SRP Challenge"
+					my_error("EAP: badly-formed SRP Challenge"
 					    " (s)");
 					/* Ignore badly-formed messages */
 					return;
@@ -2034,7 +2034,7 @@ eap_request(eap_state *esp, u_char *inp, int id, int len)
 				GETCHAR(vallen, inp);
 				len--;
 				if (vallen > len) {
-					error("EAP: badly-formed SRP Challenge"
+					my_error("EAP: badly-formed SRP Challenge"
 					    " (g)");
 					/* Ignore badly-formed messages */
 					return;
@@ -2116,7 +2116,7 @@ eap_request(eap_state *esp, u_char *inp, int id, int len)
 				    t_clientgetkey(tc, &Bval);
 				if (esp->es_client.ea_skey == NULL) {
 					/* Server is rogue; stop now */
-					error("EAP: SRP server is rogue");
+					my_error("EAP: SRP server is rogue");
 					goto client_failure;
 				}
 			}
@@ -2146,7 +2146,7 @@ eap_request(eap_state *esp, u_char *inp, int id, int len)
 				len -= sizeof (u_int32_t) + SHA_DIGESTSIZE;
 				if (len < 0 || t_clientverify(tc, inp +
 					sizeof (u_int32_t)) != 0) {
-					error("EAP: SRP server verification "
+					my_error("EAP: SRP server verification "
 					    "failed");
 					goto client_failure;
 				}
@@ -2184,7 +2184,7 @@ eap_request(eap_state *esp, u_char *inp, int id, int len)
 			break;
 
 		default:
-			error("EAP: unknown SRP Subtype %d", vallen);
+			my_error("EAP: unknown SRP Subtype %d", vallen);
 			eap_send_nak(esp, id, EAPT_MD5CHAP);
 			break;
 		}
@@ -2194,7 +2194,7 @@ eap_request(eap_state *esp, u_char *inp, int id, int len)
 #ifdef CHAPMS
         case EAPT_MSCHAPV2:
 	    if (len < 4) {
-		error("EAP: received invalid MSCHAPv2 packet, too short");
+		my_error("EAP: received invalid MSCHAPv2 packet, too short");
 		return;
 	    }
 	    unsigned char opcode;
@@ -2206,14 +2206,14 @@ eap_request(eap_state *esp, u_char *inp, int id, int len)
 
 	    /* Validate the mssize field */
 	    if (len != mssize) { 
-		error("EAP: received invalid MSCHAPv2 packet, invalid length");
+		my_error("EAP: received invalid MSCHAPv2 packet, invalid length");
 		return;
 	    }
 	    len -= 4;
 
 	    /* If MSCHAPv2 digest was not found, NAK the packet */
 	    if (!esp->es_client.digest) {
-		error("EAP MSCHAPv2 not supported");
+		my_error("EAP MSCHAPv2 not supported");
 		eap_send_nak(esp, id, EAPT_SRP);
 		return;
 	    }
@@ -2230,7 +2230,7 @@ eap_request(eap_state *esp, u_char *inp, int id, int len)
 
 		/* Validate the VALUE field */
                 if (vsize != MS_CHAP2_PEER_CHAL_LEN || len < MS_CHAP2_PEER_CHAL_LEN) {
-                    error("EAP: received invalid MSCHAPv2 packet, invalid value-length: %d", vsize);
+                    my_error("EAP: received invalid MSCHAPv2 packet, invalid value-length: %d", vsize);
                     return;
                 }
 
@@ -2291,7 +2291,7 @@ eap_request(eap_state *esp, u_char *inp, int id, int len)
 	    }
 	    default:
 
-                error("EAP: received invalid MSCHAPv2 packet, invalid or unsupported opcode: %d", opcode);
+                my_error("EAP: received invalid MSCHAPv2 packet, invalid or unsupported opcode: %d", opcode);
 		eap_send_nak(esp, id, EAPT_SRP);
 	    }
 
@@ -2371,7 +2371,7 @@ eap_response(eap_state *esp, u_char *inp, int id, int len)
 	esp->es_server.ea_responses++;
 
 	if (len <= 0) {
-		error("EAP: empty Response message discarded");
+		my_error("EAP: empty Response message discarded");
