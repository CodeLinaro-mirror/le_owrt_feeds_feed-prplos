From 37c7a3af4f0c7f79b3572532768520ced89fe7d0 Mon Sep 17 00:00:00 2001
From: Matthias Van Parys <matthias.vanparys@softathome.com>
Date: Fri, 12 Jan 2024 17:22:06 +0100
Subject: [PATCH] libfstools: use_f2fs: Add check if mkfs.f2fs is present

Check if /usr/sbin/mkfs.f2fs is present on the board
If not, return false so f2fs will not be used
---
 libfstools/common.c | 6 ++++++
 1 file changed, 6 insertions(+)

diff --git a/libfstools/common.c b/libfstools/common.c
index c27f7ca..62854ad 100644
--- a/libfstools/common.c
+++ b/libfstools/common.c
@@ -97,6 +97,12 @@ static bool use_f2fs(struct volume *v, uint64_t offset, const char *bdev)
 	bool ret = false;
 	int fd;
 
+	// Check if mkfs.f2fs is present
+	if (access("/usr/sbin/mkfs.f2fs", F_OK) != 0) {
+		ULOG_WARN("mkfs.f2fs not present, not using f2fs\n");
+		return false;
+	}
+
 	fd = open(bdev, O_RDONLY);
 	if (fd < 0)
 		return false;
-- 
2.34.1

