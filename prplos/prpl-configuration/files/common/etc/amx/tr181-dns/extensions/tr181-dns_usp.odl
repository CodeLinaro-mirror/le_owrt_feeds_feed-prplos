%config {
    %global usp.translate = {
       "'DNS.'" = "Device.DNS."
    };

    %global usp.registrations = [
        "Device.DNS.SupportedRecordTypes",
        "Device.DNS.X_PRPL-COM_ForwardZoneNumberOfEntries",
        "Device.DNS.X_PRPL-COM_HostNumberOfEntries",
        "Device.DNS.Client.",
        "Device.DNS.Diagnostics.",
        "Device.DNS.Relay.",
        "Device.DNS.X_PRPL-COM_Host.",
        "Device.DNS.X_PRPL-COM_RebindProtection."
    ];

    %global backend-dir = [ "/usr/bin/mods/usp", "/usr/bin/mods/amxb" ];

    %global usp.connect-retry = true;
}
