+    start)
         if [[ -e "/etc/amx/tr181-captiveportal/webpage/lighttpd.conf" ]]; then
             lighttpd -f "/etc/amx/tr181-captiveportal/webpage/lighttpd.conf"
         fi
-        tr181-captiveportal -D
