config PACKAGE_oopsmonitor
    tristate
    select SAH_AMX_OOPSMONITOR

if PACKAGE_oopsmonitor

menu "Select oopsmonitor build options"
    depends on PACKAGE_oopsmonitor

config SAH_AMX_OOPSMONITOR
    bool "Build the oopsmonitor plugin"
    default y

config SAH_AMX_OOPSMONITOR_ORDER
    int "Start up order"
    default 99

endmenu

endif
