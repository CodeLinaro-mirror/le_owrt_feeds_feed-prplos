config PACKAGE_tr181-captiveportal
    tristate
    select SAH_AMX_TR181_CAPTIVEPORTAL

if PACKAGE_tr181-captiveportal

menu "Select tr181-captiveportal build options"
    depends on PACKAGE_tr181-captiveportal

config SAH_AMX_TR181_CAPTIVEPORTAL
    bool "Build the AMX Captive Portal plugin"
    default y

config SAH_AMX_TR181_CAPTIVEPORTAL_EXAMPLE
    bool "Install the example captive portal page"
    default y

config SAH_AMX_TR181_CAPTIVEPORTAL_START_ORDER
    int "Init start up order for the the AMX Captive Portal plugin"
    default 90

config SAH_AMX_TR181_CAPTIVEPORTAL_STOP_ORDER
    int "Init stop order for the AMX Captive Portal plugin"
    default 90

config SAH_AMX_TR181_CAPTIVEPORTAL_RUN_AS_USER
    string "User will be used for the tr181-captiveportal plugin"
    default "tr181_app"

config SAH_AMX_TR181_CAPTIVEPORTAL_RUN_AS_GROUP
    string "Group will be used for the tr181-captiveportal plugin"
    default "tr181_app"

endmenu

endif
