config PACKAGE_tr181-mqttbroker
    tristate
    select SAH_AMX_TR181_MQTTBROKER

if PACKAGE_tr181-mqttbroker

menu "Select tr181-mqttbroker build options"
    depends on PACKAGE_tr181-mqttbroker

config SAH_AMX_TR181_MQTTBROKER
    bool "TR-181 compatible MQTT broker"
    default y

config SAH_AMX_TR181_MQTTBROKER_ORDER
    int "TR-181 MQTT broker plugin start up order"
    default 49

endmenu

endif
