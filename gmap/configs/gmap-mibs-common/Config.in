config PACKAGE_gmap-mibs-common
    tristate
    select SAH_SERVICES_GMAP-MIBS-COMMON

if PACKAGE_gmap-mibs-common

menu "Select gmap-mibs-common build options"
    depends on PACKAGE_gmap-mibs-common

config SAH_SERVICES_GMAP-MIBS-COMMON
    bool "Include gmap mibs"
    default y

config SAH_SERVICES_GMAP-MIBS-COMMON_WAN-ACCESS
    bool "Enable the WanAccess mib"
    default y

config SAH_SERVICES_GMAP-MIBS-COMMON_PRIORITY
    bool "Enable the Priority mib"
    default y

config SAH_SERVICES_GMAP-MIBS-COMMON_LOCATION
    bool "Enable the Location mib"
    default y

config SAH_SERVICES_GMAP-MIBS-COMMON_INFORMATION
    bool "Enable the Information mib"
    default y

endmenu

endif
