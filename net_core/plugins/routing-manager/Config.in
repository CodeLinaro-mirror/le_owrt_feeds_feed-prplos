config PACKAGE_routing-manager
    tristate
    select SAH_AMX_TR181_ROUTING

if PACKAGE_routing-manager

menu "Select routing-manager build options"
    depends on PACKAGE_routing-manager

config SAH_AMX_TR181_ROUTING
    bool "TR-181 Routing"
    default y

config SAH_AMX_TR181_ROUTING_RUN_AS_USER
    string "User will be used for the ROUTING-MANAGER plugin"
    default "tr181_app"

config SAH_AMX_TR181_ROUTING_RUN_AS_GROUP
    string "Group will be used for the ROUTING-MANAGER plugin"
    default "tr181_app"

config SAH_AMX_TR181_ROUTING_ROUTER_DISCOVERY
    bool "Enable TR-181 Routing router discovery functionality"
    default n

config SAH_AMX_TR181_ROUTING_PASSTHROUGH_TABLE_ID
    int "Passthrough policy routing table ID (Device.Routing.Router.2)"
    depends on SAH_AMX_TR181_ROUTING
    default 100
    range 1 254
    help
      Linux routing table number for IP passthrough (Router instance Alias Passthrough).
      Sets Routing.Router.2 Name and ID at build time. Default 100.
      tr181-passthrough reads this via RouterReference.

config SAH_AMX_TR181_ROUTING_START_ORDER
    int "Start up order"
    default 30

config SAH_AMX_TR181_ROUTING_STOP_ORDER
    int "Stop order"
    default 10

endmenu

endif
