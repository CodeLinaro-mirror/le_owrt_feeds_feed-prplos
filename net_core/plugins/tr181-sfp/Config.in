config PACKAGE_tr181-sfp
    tristate
    select SAH_AMX_TR181_SFP

if PACKAGE_tr181-sfp

menu "Select tr181-sfp build options"
    depends on PACKAGE_tr181-sfp

config SAH_AMX_TR181_SFP
    bool "Build a TR-181 compatible SFP plugin"
    default y

config SAH_AMX_TR181_SFP_ORDER
    int "SFP manager plugin start up order"
    default 30

config SAH_AMX_TR181_SFP_RUN_AS_USER
    string "User will be used for the tr181-sfp plugin"
    default "tr181_app"

config SAH_AMX_TR181_SFP_RUN_AS_GROUP
    string "Group will be used for the tr181-sfp plugin"
    default "tr181_app"

endmenu

endif
