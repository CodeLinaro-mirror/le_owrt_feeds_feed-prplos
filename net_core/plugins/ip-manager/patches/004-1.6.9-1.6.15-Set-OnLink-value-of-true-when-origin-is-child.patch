From bd2800c21ccb8b30f8ee38e2bf7dec2560e7479c Mon Sep 17 00:00:00 2001
From: rui_zhong <rui_zhong@arcadyan.com.cn>
Date: Thu, 6 Mar 2025 11:47:03 +0800
Subject: [PATCH] [1.6.9][1.6.15][Set OnLink value of true when origin is
 child]

[Description]
Set OnLink value of true when origin is child

[ChangeLog]
N/A
---
 include_priv/ip_manager_ip.h |  1 +
 src/ip_manager_ip.c          | 27 +++++++++++++++++++++++++++
 src/ipv6_utils.c             |  1 +
 3 files changed, 29 insertions(+)

diff --git a/include_priv/ip_manager_ip.h b/include_priv/ip_manager_ip.h
index 8ad0f45..705d4b1 100644
--- a/include_priv/ip_manager_ip.h
+++ b/include_priv/ip_manager_ip.h
@@ -75,6 +75,7 @@ extern "C" {
 
 amxd_status_t ip_manager_status_notpresent(amxd_object_t* intf_obj);
 amxd_status_t ip_manager_set_status(const amxd_object_t* instance, const char* status);
+amxd_status_t ip_manager_set_child_onlink(const amxd_object_t* instance, bool child);
 amxd_status_t ip_manager_intf_set_status(amxd_object_t* instance, const char* status);
 int subscribe_if_added_to_netdev(amxd_object_t* intf_obj, amxd_object_t* addr_obj, const char* ip_addr, uint8_t ip_family);
 int nm_open_dhcpoption_query(amxd_object_t* intf_obj,
diff --git a/src/ip_manager_ip.c b/src/ip_manager_ip.c
index 88599dd..4b96206 100644
--- a/src/ip_manager_ip.c
+++ b/src/ip_manager_ip.c
@@ -170,6 +170,33 @@ exit:
 }
 
 
+/**
+ * @brief Sets the status on a Prefix instance
+ * @param instance pointer to the Prefix instance object
+ * @param child boolean, 'Child' is the value of 'Origin'
+ * @return amxd_status_ok when the status is applied, otherwise an other error code and no changes in the data model are done
+ */
+amxd_status_t ip_manager_set_child_onlink(const amxd_object_t* instance, bool child) {
+    SAH_TRACEZ_IN(ME);
+    amxd_status_t rv = amxd_status_unknown_error;
+    amxd_trans_t* trans = NULL;
+
+    when_false_status(child, exit, rv = amxd_status_ok);
+    when_null_trace(instance, exit, ERROR, "No object provided to set status for");
+    trans = ip_manager_trans_create(instance);
+    when_null(trans, exit);
+
+    amxd_trans_set_value(bool, trans, "OnLink", true);
+    rv = ip_manager_trans_apply(trans);
+    when_failed_trace(rv, exit, ERROR, "Failed to set onlink 'true' on '%s'", instance->name);
+    SAH_TRACEZ_INFO(ME, "OnLink set 'true' on '%s' which 'Origin' is 'Child'", instance->name);
+
+exit:
+    SAH_TRACEZ_OUT(ME);
+    return rv;
+}
+
+
 /**
  * @brief Sets the status on a IP interface and also resets the LastChanged parameter
  * @param intf_obj pointer to the IP interface object
diff --git a/src/ipv6_utils.c b/src/ipv6_utils.c
index 66513b4..ee723e9 100644
--- a/src/ipv6_utils.c
+++ b/src/ipv6_utils.c
@@ -1110,6 +1110,7 @@ int dm_ipv6_prefix_set(const amxc_string_t* prefix,
                      prefix_info->preferred_timer, prefix_info->valid_timer);
 
     ip_manager_set_status(prefix_info->prefix_obj, (rv == 0 && !str_empty(new_prefix)) ? STATUS_ENABLED : STATUS_ERROR);
+    ip_manager_set_child_onlink(prefix_info->prefix_obj, (prefix_info->prefix_origin == PREFIX_ORIGIN_CHILD) ? true : false);
 
 exit:
     SAH_TRACEZ_OUT(ME);
-- 
