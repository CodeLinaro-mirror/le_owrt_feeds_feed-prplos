config PACKAGE_tr181-dhcpv4client
    tristate
    select SAH_AMX_TR181_DHCPV4CLIENT

if PACKAGE_tr181-dhcpv4client

menu "Select tr181-dhcpv4client build options"
    depends on PACKAGE_tr181-dhcpv4client

config SAH_AMX_TR181_DHCPV4CLIENT
    bool "Build TR-181 compatible DHCPv4 client"
    default y

config SAH_AMX_TR181_DHCPV4CLIENT_RUN_AS_USER
    string "User will be used for the TR-181 DHCPV4CLIENT plugin"
    default "tr181_app"

config SAH_AMX_TR181_DHCPV4CLIENT_RUN_AS_GROUP
    string "Group will be used for the TR-181 DHCPV4CLIENT plugin"
    default "tr181_app"

config SAH_AMX_TR181_DHCPV4CLIENT_SENTOPTION_125
    string "Vendor-Identifying Vendor-Specific Information Option to sent in DHCP requests"
    default ""

config SAH_AMX_TR181_DHCPV4CLIENT_USP_DISCOVERY_ENABLED
    bool "Whether USP Controller discovery is enabled"
    default y
    depends on PACKAGE_usp_discovery

config SAH_AMX_TR181_DHCPV4CLIENT_TR069_DISCOVERY_ENABLED
    bool "Whether ACS discovery is enabled"
    default y
    depends on PACKAGE_tr069-discovery

config SAH_AMX_TR181_DHCPV4CLIENT_TR181_GATEWAYINFO_ENABLED
    bool "Whether tr181-gatewayinfo is enabled"
    default y
    depends on PACKAGE_tr181-gatewayinfo

endmenu

endif
