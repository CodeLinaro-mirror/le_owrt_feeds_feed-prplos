config PACKAGE_tr181-passthrough
        tristate
        select AMX_TR181-PASSTHROUGH
 
if PACKAGE_tr181-passthrough
 
menu "Select tr181-passthrough build options"
        depends on PACKAGE_tr181-passthrough
 
config AMX_TR181_PASSTHROUGH
        bool "TR-181 passthrough manager implementation"
        default y
 
config AMX_TR181_PASSTHROUGH_ORDER
        int "Startup order for passthrough-manager"
        default 96

config AMX_TR181_PASSTHROUGH_RUN_AS_USER
        string "User will be used for the passthrough-manager plugin"
        default "tr181_app"
 
config AMX_TR181_PASSTHROUGH_RUN_AS_GROUP
        string "Group will be used for the passthrough-manager plugin"
        default "tr181_app"
 
endmenu
 
endif
