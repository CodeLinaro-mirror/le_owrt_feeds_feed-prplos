config PACKAGE_tr181-xpon
    tristate
    select SAH_AMX_TR181_XPON

if PACKAGE_tr181-xpon

menu "Select tr181-xpon build options"
    depends on PACKAGE_tr181-xpon

config SAH_AMX_TR181_XPON
    bool "Build a TR-181 XPON manager"
    default y

config SAH_AMX_TR181_XPON_ORDER
    int "TR-181 XPON manager start up order"
    default 30

config SAH_AMX_TR181_XPON_MAX_ONUS
    int "Maximum number of ONUs"
    default 1

config SAH_AMX_TR181_XPON_DISABLE_SUPPORT_FOR_PM_OBJECTS
    bool "Remove support for performance monitoring (PM) objects"
    default n
	help
	  Say Y if tr181-xpon should not support querying the parameters of the PM objects. The XPON DM always shows the PM objects, independent of the value of this option. Set to Y if your config uses a PON vendor module which does not support the PM objects to avoid error or warning messages when PM objects are queried for such a PON vendor module. Then the parameters of the PM objects stay 0.

config SAH_AMX_TR181_XPON_USE_NETDEV_COUNTERS
    bool "Get counters from netdev"
    default n
	help
	  If not enabled the vendor module is responsible for displaying the network statistics in the tr181-xpon datamodel

endmenu

endif
