diff --git a/mod-dhcp-dnsmasq/include_priv/mod_dhcp_dnsmasq.h b/mod-dhcp-dnsmasq/include_priv/mod_dhcp_dnsmasq.h
index 333c10e..206b7e7 100644
--- a/mod-dhcp-dnsmasq/include_priv/mod_dhcp_dnsmasq.h
+++ b/mod-dhcp-dnsmasq/include_priv/mod_dhcp_dnsmasq.h
@@ -88,6 +88,8 @@ extern "C" {
 #define MATCH_VENDOR        (1u << 0)
 #define MATCH_MAC           (1u << 1)
 #define MATCH_DEVICE        (1u << 2)
+#define MATCH_CLIENT        (1u << 3)
+#define MATCH_USERCLASS     (1u << 4)
 
 #define REJECTED_TAG "drop"
 
diff --git a/mod-dhcp-dnsmasq/src/mod_dhcp_dnsmasq.c b/mod-dhcp-dnsmasq/src/mod_dhcp_dnsmasq.c
index cff3abd..1edbae8 100644
