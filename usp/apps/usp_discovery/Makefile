include $(TOPDIR)/rules.mk

PKG_NAME:=usp_discovery
PKG_VERSION:=v0.1.0
PKG_RELEASE:=1
PKG_LICENSE:=BSD-2-Clause-Patent

PKG_SOURCE_PROTO:=git
PKG_SOURCE_URL:=https://gitlab.com/prpl-foundation/components/core/plugins/usp-discovery.git
PKG_MIRROR_HASH:=5c631e3249f694764e797565895542d161b390cb9c155d1976674fed58766146
PKG_SOURCE_VERSION:=PCF-1912_develop_usp_discovery_component

COMPONENT:=usp_discovery

define DMMInit/Install
	install -d ${PKG_INSTALL_DIR}/etc/rc.d/
	ln -sfr ${PKG_INSTALL_DIR}/etc/init.d/$(COMPONENT) ${PKG_INSTALL_DIR}/etc/rc.d/S$(CONFIG_DMM_USP_DISCOVERY_ORDER)$(COMPONENT)
	ln -sfr ${PKG_INSTALL_DIR}/etc/init.d/$(COMPONENT) ${PKG_INSTALL_DIR}/etc/rc.d/K$(CONFIG_DMM_USP_DISCOVERY_ORDER)$(COMPONENT)
endef

include $(INCLUDE_DIR)/package.mk

define Package/$(PKG_NAME)
	CATEGORY:=prpl Foundation
	SUBMENU:=Utilities
	TITLE:=Basic usp_discovery
	DEPENDS += +libamxrt
	DEPENDS += +libamxc
	DEPENDS += +libamxd
	DEPENDS += +libamxo
	DEPENDS += +libamxp
	DEPENDS += +libsahtrace
	DEPENDS += +uriparser
	DEPENDS += +libnetmodel
	MENU:=1
endef

define Package/$(PKG_NAME)/description
	USP Controller discovery using DHCP
endef

define Build/Compile
	$(call Build/Compile/Default, STAGINGDIR=$(STAGING_DIR) CONFIGDIR=$(STAGING_DIR) PKG_CONFIG_PATH=$(STAGING_DIR)/usr/lib/pkgconfig LIBDIR=/usr/lib INSTALL_LIB_DIR=/lib INSTALL_BIN_DIR=/bin RAW_VERSION=$(PKG_VERSION) HARDCO_HAL_DIR=$(STAGING_DIR)/usr/include CONFIG_DMM_USP_DISCOVERY_ORDER=$(CONFIG_DMM_USP_DISCOVERY_ORDER) CONFIG_USP_DISCOVERY_MQTT_AGENT_REPLY_TOPIC=$(CONFIG_USP_DISCOVERY_MQTT_AGENT_REPLY_TOPIC) CONFIG_USP_DISCOVERY_MQTT_CONTROLLER_RESPONSE_TOPIC=$(CONFIG_USP_DISCOVERY_MQTT_CONTROLLER_RESPONSE_TOPIC) CONFIG_USP_DISCOVERY_MQTT_TRANSPORT_PROTOCOL=$(CONFIG_USP_DISCOVERY_MQTT_TRANSPORT_PROTOCOL) CONFIG_USP_DISCOVERY_STOMP_AGENT_CONTROLLER_DST=$(CONFIG_USP_DISCOVERY_STOMP_AGENT_CONTROLLER_DST) CONFIG_USP_DISCOVERY_STOMP_CONTROLLER_AGENT_DST=$(CONFIG_USP_DISCOVERY_STOMP_CONTROLLER_AGENT_DST) CONFIG_USP_DISCOVERY_STOMP_FORCE_NO_ENCRYPTION=$(CONFIG_USP_DISCOVERY_STOMP_FORCE_NO_ENCRYPTION) CONFIG_USP_DISCOVERY_SUPPORT_MQTT_MTP=$(CONFIG_USP_DISCOVERY_SUPPORT_MQTT_MTP) CONFIG_USP_DISCOVERY_SUPPORT_STOMP_MTP=$(CONFIG_USP_DISCOVERY_SUPPORT_STOMP_MTP))
endef

define Build/Install
	$(call Build/Install/Default, install INSTALL=install D=$(PKG_INSTALL_DIR) DEST=$(PKG_INSTALL_DIR) STAGINGDIR=$(STAGING_DIR) CONFIGDIR=$(STAGING_DIR) PV=$(PKG_VERSION) PKG_CONFIG_LIBDIR=$(STAGING_DIR)/usr/lib/pkgconfig LIBDIR=/usr/lib INSTALL_LIB_DIR=/lib INSTALL_BIN_DIR=/bin RAW_VERSION=$(PKG_VERSION) HARDCO_HAL_DIR=$(STAGING_DIR)/usr/include CONFIG_USP_DISCOVERY_MQTT_AGENT_REPLY_TOPIC=$(CONFIG_USP_DISCOVERY_MQTT_AGENT_REPLY_TOPIC) CONFIG_USP_DISCOVERY_MQTT_CONTROLLER_RESPONSE_TOPIC=$(CONFIG_USP_DISCOVERY_MQTT_CONTROLLER_RESPONSE_TOPIC) CONFIG_USP_DISCOVERY_MQTT_TRANSPORT_PROTOCOL=$(CONFIG_USP_DISCOVERY_MQTT_TRANSPORT_PROTOCOL) CONFIG_USP_DISCOVERY_STOMP_AGENT_CONTROLLER_DST=$(CONFIG_USP_DISCOVERY_STOMP_AGENT_CONTROLLER_DST) CONFIG_USP_DISCOVERY_STOMP_CONTROLLER_AGENT_DST=$(CONFIG_USP_DISCOVERY_STOMP_CONTROLLER_AGENT_DST) CONFIG_USP_DISCOVERY_STOMP_FORCE_NO_ENCRYPTION=$(CONFIG_USP_DISCOVERY_STOMP_FORCE_NO_ENCRYPTION) CONFIG_USP_DISCOVERY_SUPPORT_MQTT_MTP=$(CONFIG_USP_DISCOVERY_SUPPORT_MQTT_MTP) CONFIG_USP_DISCOVERY_SUPPORT_STOMP_MTP=$(CONFIG_USP_DISCOVERY_SUPPORT_STOMP_MTP))

	$(call DMMInit/Install)
endef

define Build/InstallDev
	$(call Build/Install/Default, install INSTALL=install D=$(STAGING_DIR) DEST=$(STAGING_DIR) STAGINGDIR=$(STAGING_DIR) CONFIGDIR=$(STAGING_DIR) PV=$(PKG_VERSION) PKG_CONFIG_LIBDIR=$(STAGING_DIR)/usr/lib/pkgconfig LIBDIR=/usr/lib INSTALL_LIB_DIR=/lib INSTALL_BIN_DIR=/bin RAW_VERSION=$(PKG_VERSION) HARDCO_HAL_DIR=$(STAGING_DIR)/usr/include CONFIG_USP_DISCOVERY_MQTT_AGENT_REPLY_TOPIC=$(CONFIG_USP_DISCOVERY_MQTT_AGENT_REPLY_TOPIC) CONFIG_USP_DISCOVERY_MQTT_CONTROLLER_RESPONSE_TOPIC=$(CONFIG_USP_DISCOVERY_MQTT_CONTROLLER_RESPONSE_TOPIC) CONFIG_USP_DISCOVERY_MQTT_TRANSPORT_PROTOCOL=$(CONFIG_USP_DISCOVERY_MQTT_TRANSPORT_PROTOCOL) CONFIG_USP_DISCOVERY_STOMP_AGENT_CONTROLLER_DST=$(CONFIG_USP_DISCOVERY_STOMP_AGENT_CONTROLLER_DST) CONFIG_USP_DISCOVERY_STOMP_CONTROLLER_AGENT_DST=$(CONFIG_USP_DISCOVERY_STOMP_CONTROLLER_AGENT_DST) CONFIG_USP_DISCOVERY_STOMP_FORCE_NO_ENCRYPTION=$(CONFIG_USP_DISCOVERY_STOMP_FORCE_NO_ENCRYPTION) CONFIG_USP_DISCOVERY_SUPPORT_MQTT_MTP=$(CONFIG_USP_DISCOVERY_SUPPORT_MQTT_MTP) CONFIG_USP_DISCOVERY_SUPPORT_STOMP_MTP=$(CONFIG_USP_DISCOVERY_SUPPORT_STOMP_MTP))
endef

define Package/$(PKG_NAME)/install
	$(CP) $(PKG_INSTALL_DIR)/* $(1)/
	if [ -d ./files ]; then \
		$(CP) ./files/* $(1)/; \
	fi
	find $(1) -name *.a -exec rm {} +;
	find $(1) -name *.h -exec rm {} +;
	find $(1) -name *.pc -exec rm {} +;
endef

define Package/$(PKG_NAME)/config
	source "$(SOURCE)/Config.in"
endef

$(eval $(call BuildPackage,$(PKG_NAME)))
