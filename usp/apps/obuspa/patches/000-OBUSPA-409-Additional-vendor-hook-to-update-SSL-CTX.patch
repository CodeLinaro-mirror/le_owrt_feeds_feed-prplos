From d771621a3024fdb80bc91f9ee3828bbb8d3c5ab2 Mon Sep 17 00:00:00 2001
From: Sergio Panseri <sergio.panseri@consult.red>
Date: Tue, 2 Dec 2025 13:53:37 +0000
Subject: [PATCH] OBUSPA-409: Additional vendor hook to update SSL CTX before
 MTPs connect

---
 src/core/mqtt.c       | 15 ++++++++++++
 src/core/stomp.c      | 14 +++++++++++
 src/core/wsclient.c   | 54 +++++++++++++++++++++++++++++++++++++++++++
 src/include/usp_api.h |  3 +++
 4 files changed, 86 insertions(+)

diff --git a/src/core/mqtt.c b/src/core/mqtt.c
index 3e1e601..a4a9b6a 100644
--- a/src/core/mqtt.c
+++ b/src/core/mqtt.c
@@ -4,6 +4,7 @@
  * Copyright (C) 2024-2025, Vantiva Technologies SAS
  * Copyright (C) 2020, BT PLC
  * Copyright (C) 2020-2024  CommScope, Inc
+ * Copyright (C) 2025 Consult.Red
  *
  * Redistribution and use in source and binary forms, with or without
  * modification, are permitted provided that the following conditions
@@ -65,6 +66,7 @@
 #include "text_utils.h"
 #include "msg_handler.h"
 #include "iso8601.h"
+#include "data_model.h"  // for vendor_hook_callbacks
 
 // Defines for MQTT Property Values
 #define PUBLISH 0x30
@@ -2671,8 +2673,21 @@ exit:
 int ConnectSetEncryption(mqtt_client_t *client)
 {
     USP_ASSERT(client->ssl_ctx != NULL);
+    update_ssl_ctx_cb_t update_ssl_ctx_cb;
     int err;
 
+    update_ssl_ctx_cb = vendor_hook_callbacks.update_ssl_ctx_cb;
+    if (update_ssl_ctx_cb != NULL)
+    {
+        USP_LOG_Info("%s: Calling vendor hook to update SSL settings", __FUNCTION__);
+        err = update_ssl_ctx_cb(client->ssl_ctx);
+        if (err != USP_ERR_OK)
+        {
+            USP_LOG_Error("%s: update_ssl_ctx_cb failed", __FUNCTION__);
+            return USP_ERR_INTERNAL_ERROR;
+        }
+    }
+
     // Load the trust store certs into the context. This is performed here, rather than in MQTT_start() in order
     // to minimise memory usage, since most of the MQTT client structures will typically be unused
     // NOTE: The 'are_certs_loaded' flag ensures that the certs are loaded only once, rather than every reconnect
diff --git a/src/core/stomp.c b/src/core/stomp.c
index f76db4f..4d63428 100644
--- a/src/core/stomp.c
+++ b/src/core/stomp.c
@@ -3,6 +3,7 @@
  * Copyright (C) 2019-2025, Broadband Forum
  * Copyright (C) 2024-2025, Vantiva Technologies SAS
  * Copyright (C) 2016-2024  CommScope, Inc
+ * Copyright (C) 2025 Consult.Red
  *
  * Redistribution and use in source and binary forms, with or without
  * modification, are permitted provided that the following conditions
@@ -1654,6 +1655,19 @@ int PerformStompSslConnect(stomp_connection_t *sc)
 {
     int err;
     X509 *server_cert;
+    update_ssl_ctx_cb_t update_ssl_ctx_cb;
+
+    update_ssl_ctx_cb = vendor_hook_callbacks.update_ssl_ctx_cb;
+    if (update_ssl_ctx_cb != NULL)
+    {
+        USP_LOG_Info("%s: Calling vendor hook to update the SSL settings", __FUNCTION__);
+        err = update_ssl_ctx_cb(stomp_ssl_ctx);
+        if (err != USP_ERR_OK)
+        {
+            USP_LOG_Error("%s: update_ssl_ctx_cb failed", __FUNCTION__);
+            return USP_ERR_INTERNAL_ERROR;
+        }
+    }
 
     // Exit if unable to create a new SSL connection
     sc->ssl = SSL_new(stomp_ssl_ctx);
diff --git a/src/core/wsclient.c b/src/core/wsclient.c
index 8574a7b..083e504 100644
--- a/src/core/wsclient.c
+++ b/src/core/wsclient.c
@@ -3,6 +3,7 @@
  * Copyright (C) 2021-2025, Broadband Forum
  * Copyright (C) 2024-2025, Vantiva Technologies SAS
  * Copyright (C) 2021-2024  CommScope, Inc
+ * Copyright (C) 2025 Consult.Red
  *
  * Redistribution and use in source and binary forms, with or without
  * modification, are permitted provided that the following conditions
@@ -57,6 +58,7 @@
 #include "nu_ipaddr.h"
 #include "nu_macaddr.h"
 #include "text_utils.h"
+#include "data_model.h"  // for vendor_hook_callbacks
 
 //------------------------------------------------------------------------------
 // State of a websocket client connection
@@ -219,6 +221,10 @@ static pthread_mutex_t wsc_access_mutex;
 // libwebsockets context for this component
 static struct lws_context *wsc_ctx = NULL;
 
+//------------------------------------------------------------------------------------
+// SSL_CTX associated with the libwebsocket's vhost.
+static SSL_CTX *lws_ssl_ctx = NULL;
+
 //------------------------------------------------------------------------------------
 // Structure passed to libwebsockets defining the websocket USP sub-protocol
 static struct lws_protocols wsc_subprotocol[2];      // last entry is NULL terminator
@@ -242,6 +248,7 @@ int HandleAllWscEvents(struct lws *handle, enum lws_callback_reasons event, void
 int ValidateReceivedWsclientSubProtocol(struct lws *handle);
 int HandleWscEvent_LoadCerts(SSL_CTX *ssl_ctx);
 int HandleWscEvent_VerifyCerts(struct lws *handle, SSL *ssl, int preverify_ok, X509_STORE_CTX *x509_ctx);
+void HandleWscEvent_NewClient(void);
 int HandleWscEvent_Error(struct lws *handle, char *err_msg);
 int HandleWscEvent_Closed(struct lws *handle);
 int HandleWscEvent_Destroyed(struct lws *handle);
@@ -352,6 +359,7 @@ void WSCLIENT_Destroy(void)
     // NOTE: This also frees libwebsockets' SSL context and associated certs
     lws_context_destroy(wsc_ctx);
     wsc_ctx = NULL;
+    lws_ssl_ctx = NULL;
 
     // Iterate over all websock clients, freeing any memory they're using
     for (i=0; i<NUM_ELEM(wsclients); i++)
@@ -413,6 +421,7 @@ int WSCLIENT_Start(void)
     // Create the websocket context
     // NOTE: libwebsockets calls HandleAllWscEvents() from within lws_create_context() to load the
     // trust store and client certs into libwebsockets SSL context
+    lws_ssl_ctx = NULL;
     wsc_ctx = lws_create_context(&info);
     if (wsc_ctx == NULL)
     {
@@ -1501,6 +1510,12 @@ int HandleAllWscEvents(struct lws *handle, enum lws_callback_reasons event, void
             result = HandleWscEvent_VerifyCerts(handle, event_args, event_args_len, per_session_data);
             break;
 
+        case LWS_CALLBACK_SERVER_NEW_CLIENT_INSTANTIATED:
+            tr_event("WS client: LWS_CALLBACK_SERVER_NEW_CLIENT_INSTANTIATED");
+            HandleWscEvent_NewClient();
+            result = 0;
+            break;
+
         default:
             tr_event("WS client: event=%d", event);
             break;
@@ -1528,6 +1543,10 @@ int HandleAllWscEvents(struct lws *handle, enum lws_callback_reasons event, void
 int HandleWscEvent_LoadCerts(SSL_CTX *ssl_ctx)
 {
     int err;
+    update_ssl_ctx_cb_t update_ssl_ctx_cb;
+
+    // Save the global vhost's SSL_CTX to allow vendor-specific SSL configuration later
+    lws_ssl_ctx = ssl_ctx;
 
     // Exit if unable to load trust store and client cert into libwebsocket's SSL context
     err = DEVICE_SECURITY_LoadTrustStore(ssl_ctx, 0, NULL);
@@ -1536,6 +1555,18 @@ int HandleWscEvent_LoadCerts(SSL_CTX *ssl_ctx)
         return -1;
     }
 
+    update_ssl_ctx_cb = vendor_hook_callbacks.update_ssl_ctx_cb;
+    if (update_ssl_ctx_cb != NULL)
+    {
+        USP_LOG_Info("%s: Calling vendor hook to update SSL settings", __FUNCTION__);
+        err = update_ssl_ctx_cb(ssl_ctx);
+        if (err != USP_ERR_OK)
+        {
+            USP_LOG_Error("%s: Vendor hook update_ssl_ctx_cb() failed", __FUNCTION__);
+            return -1;
+        }
+    }
+
     return 0;
 }
 
@@ -1575,6 +1606,29 @@ int HandleWscEvent_VerifyCerts(struct lws *handle, SSL *ssl, int preverify_ok, X
     return 0;
 }
 
+/*********************************************************************//**
+**
+** int HandleWscEvent_NewClient(void)
+**
+** Called from the LWS_CALLBACK_SERVER_NEW_CLIENT_INSTANTIATED event to
+** allow vendor hooks to modify the SSL context before the connection is made
+**
+**************************************************************************/
+void HandleWscEvent_NewClient(void)
+{
+    update_ssl_ctx_cb_t update_ssl_ctx_cb;
+
+    update_ssl_ctx_cb = vendor_hook_callbacks.update_ssl_ctx_cb;
+    if (update_ssl_ctx_cb != NULL && lws_ssl_ctx != NULL)
+    {
+        USP_LOG_Info("%s: Calling vendor hook to update SSL settings", __FUNCTION__);
+        if (update_ssl_ctx_cb(lws_ssl_ctx) != USP_ERR_OK)
+        {
+            USP_LOG_Error("%s: Vendor hook update_ssl_ctx_cb() failed", __FUNCTION__);
+        }
+   }
+}
+
 /*********************************************************************//**
 **
 ** HandleWscEvent_Error
diff --git a/src/include/usp_api.h b/src/include/usp_api.h
index 3b54428..0d756c8 100644
--- a/src/include/usp_api.h
+++ b/src/include/usp_api.h
@@ -3,6 +3,7 @@
  * Copyright (C) 2019-2025, Broadband Forum
  * Copyright (C) 2024-2025, Vantiva Technologies SAS
  * Copyright (C) 2016-2024  CommScope, Inc
+ * Copyright (c) 2025 Consult.Red
  *
  * Redistribution and use in source and binary forms, with or without
  * modification, are permitted provided that the following conditions
@@ -369,6 +370,7 @@ typedef bool (*can_mtp_connect_cb_t)(void);
 
 #ifndef REMOVE_DEVICE_SECURITY
 typedef int (*load_agent_cert_cb_t)(SSL_CTX *ctx);
+typedef int (*update_ssl_ctx_cb_t)(SSL_CTX *ctx);
 #endif
 
 //-------------------------------------------------------------------------
@@ -402,6 +404,7 @@ typedef struct
     dm_vendor_get_mtp_password_cb_t         get_mtp_password_cb;
 #ifndef REMOVE_DEVICE_SECURITY
     load_agent_cert_cb_t                    load_agent_cert_cb;
+    update_ssl_ctx_cb_t                     update_ssl_ctx_cb;
 #endif
     log_message_cb_t                        log_message_cb;
     modify_firmware_updated_cb_t            modify_firmware_updated_cb;
-- 
