config PACKAGE_mod-amxb-usp
    tristate
    select SAH_MOD_AMXB_USP

if PACKAGE_mod-amxb-usp

menu "Select mod-amxb-usp build options"
    depends on PACKAGE_mod-amxb-usp

config SAH_MOD_AMXB_USP
    bool "Build the USP backend for ambiorix"
    default y

config SAH_MOD_AMXB_USP_INSTALL_DIR
    string "Installation directory for the USP backend"
    default "/usr/bin/mods/usp"

endmenu

endif
