+static bool uspl_msghandler_trace_proto_enabled(void) {
+    sah_trace_zone_it* zone = sahTraceGetZone(uspl_traceme);
+
+    if(zone == NULL) {
+        zone = sahTraceGetZone("all");
+    }
+
+    return sahTraceZoneLevel(zone) >= TRACE_LEVEL_INFO;
+}
+
+static void uspl_msghandler_trace_proto(ProtobufCMessage* msg) {
+    when_false(uspl_msghandler_trace_proto_enabled(), exit);
+    PrintProtobufCMessageRecursive(msg, 0);
+exit:
+    return;
+}
