diff --git a/test/usp_msghandler/test_usp_msghandler.c b/test/usp_msghandler/test_usp_msghandler.c
index 3161d7186440..5ae9df626f7a 100644
--- a/test/usp_msghandler/test_usp_msghandler.c
+++ b/test/usp_msghandler/test_usp_msghandler.c
@@ -60,11 +60,14 @@
 #include <setjmp.h>
 #include <cmocka.h>
 
+#include <debug/sahtrace.h>
+
 #include "uspl_private.h"
 #include "test_usp_msghandler.h"
 #include "uspl_msghandler_priv.h"
 #include "usp/uspl_msghandler.h"
 #include "usp/uspl_get.h"
+#include "bbf/proto_trace.h"
 
 static Usp__Msg* CreateGet(char* msg_id) {
     Usp__Msg* msg;
@@ -199,3 +202,69 @@ void test_uspl_msghandler_pack_unpack_protobuf(UNUSED void** state) {
     uspl_msghandler_free_unpacked_message(msg);
     free(path_exprs);
 }
+
+/**
+ * Wrap counter for PrintProtobufCMessageRecursive.
+ * Counts every entry into the function (top-level and recursive sub-message calls).
+ * Reset to 0 at the start of each test that uses it.
+ */
+static int proto_walk_count = 0;
+
+extern void __real_PrintProtobufCMessageRecursive(ProtobufCMessage* msg, int indent);
+void __wrap_PrintProtobufCMessageRecursive(ProtobufCMessage* msg, int indent);
+
+void __wrap_PrintProtobufCMessageRecursive(ProtobufCMessage* msg, int indent) {
+    proto_walk_count++;
+    __real_PrintProtobufCMessageRecursive(msg, indent);
+}
+
+/**
+ * Guard test: uspl_trace zone is not registered → guard returns false →
+ * PrintProtobufCMessageRecursive must never be called for a full pack+unpack.
+ */
+void test_proto_walk_skipped_when_zone_disabled(UNUSED void** state) {
+    uspl_tx_t* record = NULL;
+    uspl_rx_t* usp_rx = NULL;
+    Usp__Msg* msg = CreateGet("guard-off");
+
+    assert_int_equal(uspl_tx_new(&record, "foo", "bar"), 0);
+
+    /* uspl_trace zone is absent: sahTraceGetZone returns NULL for both
+     * "uspl_trace" and "all", so sahTraceZoneLevel returns 0 < TRACE_LEVEL_INFO */
+    proto_walk_count = 0;
+    assert_int_equal(uspl_msghandler_pack_protobuf(msg, record), 0);
+    usp_rx = uspl_msghandler_unpack_protobuf(record->pbuf, record->pbuf_len);
+    assert_non_null(usp_rx);
+
+    assert_int_equal(proto_walk_count, 0);
+
+    uspl_rx_delete(&usp_rx);
+    uspl_tx_delete(&record);
+    uspl_msghandler_free_unpacked_message(msg);
+}
+
+/**
+ * Guard test: uspl_trace zone is registered at INFO level → guard returns true →
+ * PrintProtobufCMessageRecursive must be called at least once per pack+unpack.
+ */
+void test_proto_walk_runs_when_zone_enabled(UNUSED void** state) {
+    uspl_tx_t* record = NULL;
+    uspl_rx_t* usp_rx = NULL;
+    Usp__Msg* msg = CreateGet("guard-on");
+
+    assert_int_equal(uspl_tx_new(&record, "foo", "bar"), 0);
+
+    sahTraceAddZone(TRACE_LEVEL_INFO, uspl_traceme);
+
+    proto_walk_count = 0;
+    assert_int_equal(uspl_msghandler_pack_protobuf(msg, record), 0);
+    usp_rx = uspl_msghandler_unpack_protobuf(record->pbuf, record->pbuf_len);
+    assert_non_null(usp_rx);
+
+    assert_true(proto_walk_count > 0);
+
+    sahTraceRemoveZone(uspl_traceme);
+    uspl_rx_delete(&usp_rx);
+    uspl_tx_delete(&record);
+    uspl_msghandler_free_unpacked_message(msg);
+}
