config PACKAGE_tr181-gre
    tristate
    select SAH_AMX_TR181_GRE

if PACKAGE_tr181-gre

menu "Select tr181-gre build options"
    depends on PACKAGE_tr181-gre

config SAH_AMX_TR181_GRE
    bool "Build a tr181 compatible gre tunnel manager"
    default y

config SAH_AMX_TR181_GRE_START_ORDER
    int "tr181 gre plugin start up order"
    default 81

config SAH_AMX_TR181_GRE_STOP_ORDER
    int "tr181 gre plugin shutdown order"
    default 19

endmenu

endif
