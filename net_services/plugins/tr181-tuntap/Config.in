config PACKAGE_tr181-tuntap
    tristate
    select SAH_AMX_TR181_TUNTAP

if PACKAGE_tr181-tuntap

menu "Select tr181-tuntap build options"
    depends on PACKAGE_tr181-tuntap

config SAH_AMX_TR181_TUNTAP
    bool "Build a tr181 compatible tuntap manager"
    default y

config SAH_AMX_TR181_TUNTAP_START_ORDER
    int "tr181 tuntap plugin start up order"
    default 82

config SAH_AMX_TR181_TUNTAP_STOP_ORDER
    int "tr181 tuntap plugin shutdown order"
    default 18

endmenu

endif
