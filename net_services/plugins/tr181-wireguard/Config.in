config PACKAGE_tr181-wireguard
    tristate
    select SAH_AMX_TR181_WIREGUARD

if PACKAGE_tr181-wireguard

menu "Select tr181-wireguard build options"
    depends on PACKAGE_tr181-wireguard

config SAH_AMX_TR181_WIREGUARD
    bool "Build a tr181 compatible WireGuard plugin"
    default y

config SAH_AMX_TR181_WIREGUARD_START_ORDER
    int "Start up order for the tr181 WireGuard plugin"
    default 25

config SAH_AMX_TR181_WIREGUARD_STOP_ORDER
    int "Shutdown order for the tr181 WireGuard plugin"
    default 75

endmenu

endif
