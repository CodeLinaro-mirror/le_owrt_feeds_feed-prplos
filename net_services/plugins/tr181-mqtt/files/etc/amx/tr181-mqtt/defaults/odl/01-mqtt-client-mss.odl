%populate {
    object MQTT.Client {
        instance add (0, "local", Name = "local") {
            parameter BrokerAddress="127.0.0.1";
            parameter BrokerPort = 1883;
            parameter Enable = false;
            parameter ClientID = "HGW-$(SERIALNUMBER)";
            parameter Username = "$(LOCAL_MQTT_USER)";
            parameter Password = "$(LOCAL_MQTT_PWD)";
            parameter TransportProtocol = "TCP/IP";
        }
    }
}
