config PACKAGE_initramfs-generator
    tristate
    select INITRAMFS_GENERATOR

if PACKAGE_initramfs-generator

menu "Select initramfs-generator build options"
    depends on PACKAGE_initramfs-generator

config INITRAMFS_GENERATOR
    bool "Build initramfs-generator"
    default y
	help
	  Provide tools to build a pivoting initramfs.
    depends on KERNEL_DEVTMPFS && BUSYBOX_CONFIG_MODPROBE && BUSYBOX_CONFIG_MODPROBE_SMALL && BUSYBOX_CONFIG_FEATURE_MODPROBE_SMALL_CHECK_ALREADY_LOADED && PACKAGE_kmod-dm && PACKAGE_blkid && PACKAGE_blockdev && PACKAGE_lvm2

config INITRAMFS_GENERATOR_DEBUG
    bool "debug mode"
    default n
	help
	  Debugging mode. Will enable more traces, and a fail during startup will drop
	  the user in a rescue shell instead of rebooting.

config INITRAMFS_GENERATOR_DEMO
    bool "use demo values and files"
    default n
	help
	  A bunch of options of initramfs generator require specific files at runtime
	  to work (for instance, configuration files or keys). If they are not found
	  in the initramfs, the boot may fail.
	  With this option, demo files will be copied to initramfs as needed, making
	  sure any selected feature may proceed as possible.
	  This option is intended as a debugging and bringup tool: you can use the demo
	  files to avoid building a bunch of values for development, and avoid doubts
	  related to values.

choice
    prompt "Choose the flash type: eMMC or NAND"
    default INITRAMFS_GENERATOR_FLASH_TYPE_EMMC

config INITRAMFS_GENERATOR_FLASH_TYPE_EMMC
    bool "Select eMMC as flash type"

config INITRAMFS_GENERATOR_FLASH_TYPE_NAND
    bool "Select NAND as flash type"

endchoice

config INITRAMFS_GENERATOR_KRS
    bool "KRS key injection support"
    default n
	help
	  This flag adds support for kernel KRS (Key Retention Service) keys injection.
	  It means that, initramfs will be able to take a list of keys, and add them
	  to the KRS, making them available to userspace without exposing them.
	  The keys list should be located in the initramfs, and define the list of
	  keys to be added and how.
	  More information is available in the matching init script.
    depends on PACKAGE_keyctl && KERNEL_KEYS

config INITRAMFS_GENERATOR_KEY_DERIVATION
    bool "HKDF key derivation support"
    default n
	help
	  This flag adds support for keys derivation in initramfs, using HKDF and
	  openssl-kdf.
	  The derivation(s) list and specifications should be located in the initramfs,
	  provided by the builder.
	  More information is available in the matching init script, and demo values.
    depends on PACKAGE_openssl-util

config INITRAMFS_GENERATOR_ROOTFS_FIT
    bool "support rootfs in a FIT"
    default y
	help
	  Support rootfs packaged in a FIT (see https://fitspec.osfw.foundation/).
	  Note that, your FIT needs to be built with data out of tree, with
	  absolute position (see --external and --position for mkimage).
    depends on BUSYBOX_CONFIG_HEXDUMP && PACKAGE_fdt-utils

config INITRAMFS_GENERATOR_ROOTFS_SIG_PRELOAD
    bool "support rootfs pre-load signature"
    default y
	help
	  Support rootfs signature with U-boot pre-load method (see
	  https://github.com/u-boot/u-boot/blob/master/tools/binman/etype/pre_load.py).
    depends on BUSYBOX_CONFIG_HEXDUMP && BUSYBOX_CONFIG_SHA256SUM && BUSYBOX_CONFIG_DD && PACKAGE_openssl-util

config INITRAMFS_GENERATOR_ROOTFS_SIG_PRELOAD_MANDATORY
    bool "make pre-load signature mandatory on rootfs FIT"
    default n
	help
	  With this option, rootfs SHOULD be signed with U-boot pre-load signature. If
	  the corresponding magic is not found, instead of skipping signature verification,
	  the boot will fail this image.
    depends on INITRAMFS_GENERATOR_ROOTFS_SIG_PRELOAD

config INITRAMFS_GENERATOR_ROOTFS_DMVERITY
    bool "set up dm-verity on rootfs"
    default n
	help
	  Enable dm-verity setup routines, on rootfs device.
	  The verity target parameters will be taken or deduced from the rootfs
	  FIT metadata, which should contain appropriate data.
	  Note that, your rootfs will be readonly if you select this option.
    depends on INITRAMFS_GENERATOR_ROOTFS_FIT

config INITRAMFS_GENERATOR_ROOTFS_DMCRYPT
    bool "set up dm-crypt on rootfs"
    default n
	help
	  Enable dm-crypt setup routines, on rootfs device.
	  The crypt target requires a key and parameters, which should be provided
	  to init scripts.
	  You can find an example as a demo key and parameters, using KRS.
	  Note that, enabling this flag without KRS support will disable the demo files.

config INITRAMFS_GENERATOR_NONROOT_DMCRYPT
    bool "support ciphering of non-root partitions"
    default n
	help
	  Enable dm-crypt setup routines, on non-root devices.
	  The devices and crypt targets should be defined by a specifications file,
	  provided in the initramfs.
	  You can find an example with demo keys and parameters, using KRS.
	  Note that, enabling this flag without KRS support will disable the demo files.

endmenu

endif
