include $(TOPDIR)/rules.mk

PKG_NAME:=initramfs-generator

PKG_VERSION:=dev_FEAT-29_PCF-1893
SHORT_DESCRIPTION:=Provide tools to build a pivoting initramfs

PKG_SOURCE_PROTO:=git
PKG_SOURCE_VERSION:=dev_FEAT-29/PCF-1893
PKG_SOURCE_URL:=git@gitlab.com:prpl-foundation/components/utilities/initramfs-generator.git
PKG_MIRROR_HASH:=skip
PKG_BUILD_DIR:=$(BUILD_DIR)/$(PKG_NAME)-$(PKG_VERSION)

PKG_MAINTAINER:=mohamed-nour TOUMI <mohamed.toumi_ext@softathome.com>
PKG_LICENSE:=BSD-2-Clause-Patent
PKG_LICENSE_FILES:=LICENSE


PKG_RELEASE:=1

include $(INCLUDE_DIR)/package.mk

define Package/$(PKG_NAME)
  CATEGORY:=Utilities
  SUBMENU:=Other
  TITLE:=$(SHORT_DESCRIPTION)
 
  URL:=git@gitlab.com:prpl-foundation/components/utilities/initramfs-generator.git
  DEPENDS += +INITRAMFS_GENERATOR_ROOTFS_FIT:dtc
  DEPENDS += +INITRAMFS_GENERATOR_ROOTFS_SIG_PRELOAD:libopenssl
  MENU:=1
endef

define Package/$(PKG_NAME)/description
	Provide tools to build a pivoting initramfs
endef

define Build/Compile
	$(call Build/Compile/Default, STAGINGDIR=$(STAGING_DIR) CONFIGDIR=$(STAGING_DIR) PKG_CONFIG_PATH=$(STAGING_DIR)/usr/lib/pkgconfig LIBDIR=/usr/lib INSTALL_LIB_DIR=/lib INSTALL_BIN_DIR=/bin RAW_VERSION=$(PKG_VERSION) HARDCO_HAL_DIR=$(STAGING_DIR)/usr/include CONFIG_INITRAMFS_GENERATOR_DEBUG=$(CONFIG_INITRAMFS_GENERATOR_DEBUG) CONFIG_INITRAMFS_GENERATOR_DEMO=$(CONFIG_INITRAMFS_GENERATOR_DEMO) CONFIG_INITRAMFS_GENERATOR_FLASH_TYPE_EMMC=$(CONFIG_INITRAMFS_GENERATOR_FLASH_TYPE_EMMC) CONFIG_INITRAMFS_GENERATOR_FLASH_TYPE_NAND=$(CONFIG_INITRAMFS_GENERATOR_FLASH_TYPE_NAND) CONFIG_INITRAMFS_GENERATOR_ROOTFS_FIT=$(CONFIG_INITRAMFS_GENERATOR_ROOTFS_FIT) CONFIG_INITRAMFS_GENERATOR_ROOTFS_SIG_PRELOAD=$(CONFIG_INITRAMFS_GENERATOR_ROOTFS_SIG_PRELOAD) CONFIG_INITRAMFS_GENERATOR_ROOTFS_SIG_PRELOAD_MANDATORY=$(CONFIG_INITRAMFS_GENERATOR_ROOTFS_SIG_PRELOAD_MANDATORY))
endef

define Build/Install
	$(call Build/Install/Default, install INSTALL=install D=$(PKG_INSTALL_DIR) DEST=$(PKG_INSTALL_DIR) STAGINGDIR=$(STAGING_DIR) CONFIGDIR=$(STAGING_DIR) PV=$(PKG_VERSION) PKG_CONFIG_LIBDIR=$(STAGING_DIR)/usr/lib/pkgconfig LIBDIR=/usr/lib INSTALL_LIB_DIR=/lib INSTALL_BIN_DIR=/bin RAW_VERSION=$(PKG_VERSION) HARDCO_HAL_DIR=$(STAGING_DIR)/usr/include CONFIG_GATEWAY=$(CONFIG_GATEWAY) CONFIG_ACCESSPOINT=$(CONFIG_ACCESSPOINT) CONFIG_INITRAMFS_GENERATOR_DEBUG=$(CONFIG_INITRAMFS_GENERATOR_DEBUG) CONFIG_INITRAMFS_GENERATOR_DEMO=$(CONFIG_INITRAMFS_GENERATOR_DEMO) CONFIG_INITRAMFS_GENERATOR_FLASH_TYPE_EMMC=$(CONFIG_INITRAMFS_GENERATOR_FLASH_TYPE_EMMC) CONFIG_INITRAMFS_GENERATOR_FLASH_TYPE_NAND=$(CONFIG_INITRAMFS_GENERATOR_FLASH_TYPE_NAND) CONFIG_INITRAMFS_GENERATOR_ROOTFS_FIT=$(CONFIG_INITRAMFS_GENERATOR_ROOTFS_FIT) CONFIG_INITRAMFS_GENERATOR_ROOTFS_SIG_PRELOAD=$(CONFIG_INITRAMFS_GENERATOR_ROOTFS_SIG_PRELOAD) CONFIG_INITRAMFS_GENERATOR_ROOTFS_SIG_PRELOAD_MANDATORY=$(CONFIG_INITRAMFS_GENERATOR_ROOTFS_SIG_PRELOAD_MANDATORY))
endef

define Build/InstallDev
	$(call Build/Install/Default, install INSTALL=install D=$(STAGING_DIR) DEST=$(STAGING_DIR) STAGINGDIR=$(STAGING_DIR) CONFIGDIR=$(STAGING_DIR) PV=$(PKG_VERSION) PKG_CONFIG_LIBDIR=$(STAGING_DIR)/usr/lib/pkgconfig LIBDIR=/usr/lib INSTALL_LIB_DIR=/lib INSTALL_BIN_DIR=/bin RAW_VERSION=$(PKG_VERSION) HARDCO_HAL_DIR=$(STAGING_DIR)/usr/include CONFIG_GATEWAY=$(CONFIG_GATEWAY) CONFIG_ACCESSPOINT=$(CONFIG_ACCESSPOINT) CONFIG_INITRAMFS_GENERATOR_DEBUG=$(CONFIG_INITRAMFS_GENERATOR_DEBUG) CONFIG_INITRAMFS_GENERATOR_DEMO=$(CONFIG_INITRAMFS_GENERATOR_DEMO) CONFIG_INITRAMFS_GENERATOR_FLASH_TYPE_EMMC=$(CONFIG_INITRAMFS_GENERATOR_FLASH_TYPE_EMMC) CONFIG_INITRAMFS_GENERATOR_FLASH_TYPE_NAND=$(CONFIG_INITRAMFS_GENERATOR_FLASH_TYPE_NAND)  CONFIG_INITRAMFS_GENERATOR_ROOTFS_FIT=$(CONFIG_INITRAMFS_GENERATOR_ROOTFS_FIT) CONFIG_INITRAMFS_GENERATOR_ROOTFS_SIG_PRELOAD=$(CONFIG_INITRAMFS_GENERATOR_ROOTFS_SIG_PRELOAD) CONFIG_INITRAMFS_GENERATOR_ROOTFS_SIG_PRELOAD_MANDATORY=$(CONFIG_INITRAMFS_GENERATOR_ROOTFS_SIG_PRELOAD_MANDATORY))
endef

define Package/$(PKG_NAME)/install
	$(CP) $(PKG_INSTALL_DIR)/* $(1)/
	if [ -d ./files ]; then \
		$(CP) ./files/* $(1)/; \
	fi
	find $(1) -name *.a -exec rm {} +;
	find $(1) -name *.h -exec rm {} +;
	find $(1) -name *.pc -exec rm {} +;
endef

define Package/$(PKG_NAME)/config
	source "$(SOURCE)/Config.in"
endef

$(eval $(call BuildPackage,$(PKG_NAME)))
