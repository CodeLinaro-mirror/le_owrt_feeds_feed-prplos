diff --git a/src/firewall/dm_rule_events.c b/src/firewall/dm_rule_events.c
index 0b3c7c6..1994b71 100644
--- a/src/firewall/dm_rule_events.c
+++ b/src/firewall/dm_rule_events.c
@@ -232,20 +232,49 @@ exit:
     return rule;
 }
 
+static int rule_iterate_update(amxd_object_t* templ) {
+    int rv = 0;
+    amxd_object_t* object;
+    rule_t* rule;
+
+    amxd_object_iterate(instance, it, templ) {
+        object = amxc_llist_it_get_data(it, amxd_object_t, it);
+        rule = object->priv;
+        if(rule == NULL)
+            continue;
+        decrement_set_ref(object_da_string(rule->common.object, "SourceMatchSet"));
+        decrement_set_ref(object_da_string(rule->common.object, "SourceMatchSetExclude"));
+        decrement_set_ref(object_da_string(rule->common.object, "DestMatchSet"));
+        decrement_set_ref(object_da_string(rule->common.object, "DestMatchSetExclude"));
+        rule_delete(&rule);
+        object->priv = rule;
+        set_status(object, FIREWALL_DISABLED);
+    }
+
+    amxd_object_iterate(instance, it, templ) {
+        int status;
+
+        object = amxc_llist_it_get_data(it, amxd_object_t, it);
+        rule = rule_init(object);
+        status = rule ? fw_apply() : 1;
+        if(status != 0)
+            SAH_TRACEZ_WARNING(ME, "Could not init new rule to [%s]", 
+                               amxd_object_get_name(object, AMXD_OBJECT_NAMED));
+        rv |= status;
+    }
+
+    return rv;
+}
+
 void _firewall_rule_added(UNUSED const char* const sig_name,
                           const amxc_var_t* const event_data,
                           UNUSED void* const priv) {
     FW_PROFILING_IN(TRACE_DM_EVENT);
     amxd_object_t* templ = amxd_dm_signal_get_object(fw_get_dm(), event_data);
-    amxd_object_t* object = amxd_object_get_instance(templ, NULL, GET_UINT32(event_data, "index"));
-    rule_t* rule = NULL;
-
-    when_null(object, exit);
 
-    rule = rule_init(object);
-    when_null(rule, exit);
+    when_null(templ, exit);
+    when_failed(rule_iterate_update(templ), exit);
 
-    fw_apply();
 exit:
     FW_PROFILING_OUT();
     return;
@@ -255,147 +274,15 @@ void _firewall_rule_changed(UNUSED const char* const sig_name,
