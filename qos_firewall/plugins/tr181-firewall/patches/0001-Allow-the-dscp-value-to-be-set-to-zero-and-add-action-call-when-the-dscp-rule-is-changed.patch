From dc9751f96f72c87ad81d5fac971b22c8ebb7f50a Mon Sep 17 00:00:00 2001
From: Zhijian <vip.zhijian@gmail.com>
Date: Fri, 11 Apr 2025 19:24:36 +0800
Subject: Fixed some bugs.

1. Allow the dscp value to be set to zero
2. Add action call when the dscp rule is changed.

To resolve CDRouter prpl certification bugs 1.5.18-1.5.19.

(by Rui Zhong)
---
 odl/firewall/firewall_definition.odl | 2 ++
 odl/tr181-firewall.odl               | 6 +++++-
 src/fwrule_helpers.c                 | 2 +-
 3 files changed, 8 insertions(+), 2 deletions(-)

diff --git a/odl/firewall/firewall_definition.odl b/odl/firewall/firewall_definition.odl
index a13160f..80ccc7b 100644
--- a/odl/firewall/firewall_definition.odl
+++ b/odl/firewall/firewall_definition.odl
@@ -753,6 +753,8 @@
                    (contains("parameters.DestMatchSet")) ||
                    (contains("parameters.SourceMatchSetExclude")) ||
                    (contains("parameters.DestMatchSetExclude")) ||
+                   (contains("parameters.DSCP")) ||
+                   (contains("parameters.DSCPExclude")) ||
                    (contains("parameters.Log")) ||
                    (contains("parameters.${prefix_}LogController")) ||
                    (contains("parameters.${prefix_}LogControllerDeniedInbound")) ||
diff --git a/odl/tr181-firewall.odl b/odl/tr181-firewall.odl
index a5da136..430a2e1 100644
--- a/odl/tr181-firewall.odl
+++ b/odl/tr181-firewall.odl
@@ -60,7 +60,11 @@
     fw-auto-all-interfaces = false;
 }
 
-import "mod-dmext.so";
+import "mod-dmext.so" as "tr181";
+%define {
+    entry-point tr181.dmext_main;
+}
+
 import "${name}.so" as firewall;
 
 include "${name}_vars.odl";
diff --git a/src/fwrule_helpers.c b/src/fwrule_helpers.c
index e6bbcad..049a0ca 100644
--- a/src/fwrule_helpers.c
+++ b/src/fwrule_helpers.c
@@ -976,7 +976,7 @@ bool folder_feature_set_dscp(fw_folder_t* folder, int32_t dscp, bool exclude) {
     fw_rule_t* s = NULL;
     bool retval = false;
 
-    if(dscp > 0) {
+    if(dscp != -1) {
         fw_folder_set_feature(folder, FW_FEATURE_DSCP);
 
         s = fw_folder_fetch_feature_rule(folder, FW_FEATURE_DSCP);
