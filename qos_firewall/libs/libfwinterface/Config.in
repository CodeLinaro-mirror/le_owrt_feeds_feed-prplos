config PACKAGE_libfwinterface
    tristate
    select SAH_LIB_FWINTERFACE

if PACKAGE_libfwinterface

menu "Select libfwinterface build options"
    depends on PACKAGE_libfwinterface

config SAH_LIB_FWINTERFACE
    bool "Build the firewall interfaces library"
    default n
    depends on SAH_LIB_FWRULES

choice
    prompt "Choose the interface to use between lib_fwrules and netfilter"
    default SAH_LIB_FWINTERFACE_INTERFACE_IPTC

config SAH_LIB_FWINTERFACE_INTERFACE_DUMMY
    bool "Dummy interface. Does nothing"

config SAH_LIB_FWINTERFACE_INTERFACE_IPTC
    bool "Use lib_iptc as the interface"

endchoice

config SAH_LIB_FWINTERFACE_SUPPORTS_PHYSDEV
    bool "Build with iptables-mod-physdev support"
    default y
    depends on SAH_LIB_FWINTERFACE_INTERFACE_IPTC

config SAH_LIB_FWINTERFACE_DEFAULT_LOCKFILE
    string "Default value for the lockfile"
    default "/var/run/xtables.lock"
    depends on !SAH_LIB_FWINTERFACE_LOCKFILE_PER_TABLE

config SAH_LIB_FWINTERFACE_LOCKFILE_PER_TABLE
    bool "Use a lockfile per table (and IP version). WARNING: iptables should be patched to support the same lockfiles to avoid conflicts. WARNING: risk of deadlocking? The following lockfiles will be used for IPv6: /var/run/ip6tables.lock_mangle /var/run/ip6tables.lock_filter /var/run/ip6tables.lock_raw /var/run/ip6tables.lock_nat The following lockfiles will be used for IPv4: /var/run/iptables.lock_mangle /var/run/iptables.lock_filter /var/run/iptables.lock_raw /var/run/iptables.lock_nat"
    default n

endmenu

endif
