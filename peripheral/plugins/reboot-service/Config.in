config PACKAGE_reboot-service
    tristate
    select SAH_REBOOT_SERVICE

if PACKAGE_reboot-service

menu "Select reboot-service build options"
    depends on PACKAGE_reboot-service

config SAH_REBOOT_SERVICE
    bool "Build reboot plug-in"
    default y

config SAH_REBOOT_SERVICE_ORDER
    int "Start up order"
    default 18

endmenu

endif
