config OPENSOURCE_SWUPDATE
    bool "build OPENSOURCE_SWUPDATE component"
    default y
config CONFIG_SWUPDATE_MTD
    bool "build OPENSOURCE_SWUPDATE component"
    default n
config OPENSOURCE_SWUPDATE_HWREVISION
    string "swupdate hwrevision file"
    depends on OPENSOURCE_SWUPDATE
    default "/tmp/hwrevision"
config OPENSOURCE_SWUPDATE_SWVERSIONS
    string "swupdate sw-versions file"
    depends on OPENSOURCE_SWUPDATE
    default "/tmp/sw-versions"
config OPENSOURCE_SWUPDATE_HANDLER_UBI
    bool "enable UBI volumes update support"
    default n
config OPENSOURCE_SURICATTA
    bool "enable suricatta"
    default y
config OPENSOURCE_SURICATTA_SSL
    bool "enable suricatta ssl"
    depends on OPENSOURCE_SURICATTA
    default y
config OPENSOURCE_SURICATTA_HAWKBIT
    bool "enable suricatta hawkbit"
    depends on OPENSOURCE_SURICATTA
    default y
config OPENSOURCE_SURICATTA_LUA
    bool "enable suricatta Lua"
    depends on OPENSOURCE_SURICATTA
    default n
config OPENSOURCE_EMBEDDED_SURICATTA_LUA
    bool "Embed Suricatta Lua module in SWUpdate binary"
    depends on OPENSOURCE_SURICATTA_LUA
    default n
config OPENSOURCE_EMBEDDED_SURICATTA_LUA_SOURCE
    string "Suricatta Lua module file"
    depends on OPENSOURCE_EMBEDDED_SURICATTA_LUA
    default "swupdate_suricatta.lua"
config OPENSOURCE_SWUPDATE_WEBSERVER
    bool "enable webserver support"
    default n
config OPENSOURCE_SWUPDATE_MONGOOSE
    bool "choose mongoose as webserver"
    depends on OPENSOURCE_SWUPDATE_WEBSERVER
    default y
config OPENSOURCE_SWUPDATE_MONGOOSEIPV6
    bool "enable ipv6 support on mongoose (dependancy not supported)"
    depends on OPENSOURCE_SWUPDATE_MONGOOSE
    default n
config OPENSOURCE_SWUPDATE_MONGOOSESSL
    bool "enable ssl support on mongoose (dependancy not supported)"
    depends on OPENSOURCE_SWUPDATE_MONGOOSE
    default n
config OPENSOURCE_SWUPDATE_INSTALL_WEB_EXAMPLE
    bool "install web example"
    depends on OPENSOURCE_SWUPDATE_MONGOOSE
    default n
config OPENSOURCE_SWUPDATE_RELEASE_WEB_EXAMPLE
    bool "release web example"
    depends on OPENSOURCE_SWUPDATE_INSTALL_WEB_EXAMPLE
    default y
    help
      Release web server example to rootfs during release step.
      If disabled, web server example sources will remain in staging only.
config OPENSOURCE_SWUPDATE_INSTALL_WEB_EXAMPLE_PATH
    string "path of the web example on the target"
    depends on OPENSOURCE_SWUPDATE_INSTALL_WEB_EXAMPLE
    default ""


config OPENSOURCE_SWUPDATE_UBOOT
    bool "Bootloader Interfaces U-Boot"
    depends on PACKAGE_libubootenv
    help
      Support for U-Boot
    default n
config OPENSOURCE_SWUPDATE_UBOOT_FWENV
    string "U-Boot Environment Configuration file"
    depends on OPENSOURCE_SWUPDATE_UBOOT
    help
	  This is the file described in U-Boot documentation
	  in the tools directory. It tells where the U-Boot
	  environment is saved.
    default "/etc/fw_env.config"
config OPENSOURCE_SWUPDATE_UBOOT_DEFAULTENV
    string "U-Boot Initial Environment file"
    depends on OPENSOURCE_SWUPDATE_UBOOT
    help
	  This is the file with the initial environment delivered
	  with the bootloader. It is used by SWUpdate if no environment
	  is found on the storage.
    default "/etc/u-boot-initial-env"
config OPENSOURCE_SWUPDATE_DISKFORMAT_HANDLER
    bool "diskformat handler for creating file systems"
    default n
config OPENSOURCE_SWUPDATE_EXT_FILESYSTEM
    bool "EXT2 / EXT3 / EXT4 file system creation support"
    depends on OPENSOURCE_SWUPDATE_DISKFORMAT_HANDLER
    select PACKAGE_libext2fs
    help
      Enable support for creating EXT file systems
    default n
config OPENSOURCE_SWUPDATE_DISKPART_HANDLER
	bool "enable diskpart update support"
	select PACKAGE_libfdisk
	default n
config OPENSOURCE_SWUPDATE_FAT_FILESYSTEM
    bool "FAT file system creation support"
    depends on OPENSOURCE_SWUPDATE_DISKFORMAT_HANDLER
    help
      Enable support for creating FAT file systems
    default n
