include $(TOPDIR)/rules.mk

PKG_NAME:=libmfg
PKG_VERSION:=v1.2.0
SHORT_DESCRIPTION:=Tool to parse/read the Manufacturing data, providing a lib that can be used by other tools

PKG_SOURCE_PROTO:=git
PKG_SOURCE_VERSION:=FEAT-29
PKG_SOURCE_URL:=https://gitlab.com/prpl-foundation/components/mfgdata/libmfg.git
PKG_MIRROR_HASH:=8a1559ec72f2170028cfd01664bd7a0949e65149fd7f9d14e7d5e7be9734eb22
PKG_BUILD_DIR:=$(BUILD_DIR)/$(PKG_NAME)-$(PKG_VERSION)
PKG_MAINTAINER:=Soft At Home <support.opensource@softathome.com>
PKG_LICENSE:=BSD-2-Clause-Patent
PKG_LICENSE_FILES:=LICENSE


PKG_RELEASE:=1
PKG_BUILD_DEPENDS += dtc
PKG_BUILD_DEPENDS += SAH_LIB_MFG_SECURE_MFG_KERNEL_KEYRING_SUPPORT:kernel

include $(INCLUDE_DIR)/package.mk

define Package/$(PKG_NAME)
  CATEGORY:=prpl Foundation
  SUBMENU:=Other
  TITLE:=$(SHORT_DESCRIPTION)
  URL:=https://gitlab.com/prpl-foundation/components/mfgdata/libmfg
  DEPENDS += +libopenssl
  DEPENDS += +libsahtrace
  DEPENDS += +libfdt
  DEPENDS += +SAH_LIB_MFG_SECURE_MFG_SUPPORT:kmod-mfgdecrypt
  DEPENDS += +SAH_LIB_MFG_SECURE_MFG_KERNEL_KEYRING_SUPPORT:libkcapi
  DEPENDS += +SAH_LIB_MFG_SECURE_MFG_KERNEL_KEYRING_SUPPORT:libkeyutils
  DEPENDS += +SAH_LIB_MFG_SECURE_MFG_KERNEL_KEYRING_SUPPORT:keyctl
  DEPENDS += +SAH_LIB_MFG_SECURE_MFG_KERNEL_KEYRING_SUPPORT:keyutils
  MENU:=1
endef

define Package/$(PKG_NAME)/description
	Tool to parse/read the Manufacturing data, providing a lib that can be used by other tools
endef

define Build/Compile
	$(call Build/Compile/Default, STAGINGDIR=$(STAGING_DIR) CONFIGDIR=$(STAGING_DIR) PKG_CONFIG_PATH=$(STAGING_DIR)/usr/lib/pkgconfig LIBDIR=/usr/lib INSTALL_LIB_DIR=/lib INSTALL_BIN_DIR=/bin RAW_VERSION=$(PKG_VERSION) HARDCO_HAL_DIR=$(STAGING_DIR)/usr/include CONFIG_SAH_LIB_MFG_RO_PART_FILE=$(CONFIG_SAH_LIB_MFG_RO_PART_FILE) CONFIG_SAH_LIB_MFG_RW_PART_FILE=$(CONFIG_SAH_LIB_MFG_RW_PART_FILE) CONFIG_SAH_LIB_MFG_SECURE_MFG_SUPPORT=$(CONFIG_SAH_LIB_MFG_SECURE_MFG_SUPPORT) CONFIG_SAH_LIB_MFG_PUBLIC_PEM_FILE=$(CONFIG_SAH_LIB_MFG_PUBLIC_PEM_FILE) CONFIG_SAH_LIB_MFG_GLOBAL_SIGNATURE=$(CONFIG_SAH_LIB_MFG_GLOBAL_SIGNATURE) CONFIG_SAH_LIB_MFG_GLOBAL_SIGNATURE_PUBLIC_PEM_FILE=$(CONFIG_SAH_LIB_MFG_GLOBAL_SIGNATURE_PUBLIC_PEM_FILE) CONFIG_SAH_LIB_MFG_GLOBAL_SIGNATURE_PADDING_MODE=$(CONFIG_SAH_LIB_MFG_GLOBAL_SIGNATURE_PADDING_MODE) CONFIG_SAH_LIB_MFG_SECURE_MFG_KERNEL_KEYRING_SUPPORT=$(CONFIG_SAH_LIB_MFG_SECURE_MFG_KERNEL_KEYRING_SUPPORT) CONFIG_SAH_LIB_MFG_SECURE_MFG_KERNEL_KEYRING_KEY_NAME=$(CONFIG_SAH_LIB_MFG_SECURE_MFG_KERNEL_KEYRING_KEY_NAME) CONFIG_SAH_LIB_MFG_SECURE_MFG_KERNEL_KEYRING_IV_FILE=$(CONFIG_SAH_LIB_MFG_SECURE_MFG_KERNEL_KEYRING_IV_FILE))
endef

define Build/Install
	$(call Build/Install/Default, install INSTALL=install D=$(PKG_INSTALL_DIR) DEST=$(PKG_INSTALL_DIR) STAGINGDIR=$(STAGING_DIR) CONFIGDIR=$(STAGING_DIR) PV=$(PKG_VERSION) PKG_CONFIG_LIBDIR=$(STAGING_DIR)/usr/lib/pkgconfig LIBDIR=/usr/lib INSTALL_LIB_DIR=/lib INSTALL_BIN_DIR=/bin RAW_VERSION=$(PKG_VERSION) HARDCO_HAL_DIR=$(STAGING_DIR)/usr/include CONFIG_GATEWAY=$(CONFIG_GATEWAY) CONFIG_ACCESSPOINT=$(CONFIG_ACCESSPOINT) CONFIG_SAH_LIB_MFG_RO_PART_FILE=$(CONFIG_SAH_LIB_MFG_RO_PART_FILE) CONFIG_SAH_LIB_MFG_RW_PART_FILE=$(CONFIG_SAH_LIB_MFG_RW_PART_FILE) CONFIG_SAH_LIB_MFG_SECURE_MFG_SUPPORT=$(CONFIG_SAH_LIB_MFG_SECURE_MFG_SUPPORT) CONFIG_SAH_LIB_MFG_PUBLIC_PEM_FILE=$(CONFIG_SAH_LIB_MFG_PUBLIC_PEM_FILE) CONFIG_SAH_LIB_MFG_GLOBAL_SIGNATURE=$(CONFIG_SAH_LIB_MFG_GLOBAL_SIGNATURE) CONFIG_SAH_LIB_MFG_GLOBAL_SIGNATURE_PUBLIC_PEM_FILE=$(CONFIG_SAH_LIB_MFG_GLOBAL_SIGNATURE_PUBLIC_PEM_FILE) CONFIG_SAH_LIB_MFG_GLOBAL_SIGNATURE_PADDING_MODE=$(CONFIG_SAH_LIB_MFG_GLOBAL_SIGNATURE_PADDING_MODE) CONFIG_SAH_LIB_MFG_SECURE_MFG_KERNEL_KEYRING_SUPPORT=$(CONFIG_SAH_LIB_MFG_SECURE_MFG_KERNEL_KEYRING_SUPPORT) CONFIG_SAH_LIB_MFG_SECURE_MFG_KERNEL_KEYRING_KEY_NAME=$(CONFIG_SAH_LIB_MFG_SECURE_MFG_KERNEL_KEYRING_KEY_NAME) CONFIG_SAH_LIB_MFG_SECURE_MFG_KERNEL_KEYRING_IV_FILE=$(CONFIG_SAH_LIB_MFG_SECURE_MFG_KERNEL_KEYRING_IV_FILE))
endef

define Build/InstallDev
	$(call Build/Install/Default, install INSTALL=install D=$(STAGING_DIR) DEST=$(STAGING_DIR) STAGINGDIR=$(STAGING_DIR) CONFIGDIR=$(STAGING_DIR) PV=$(PKG_VERSION) PKG_CONFIG_LIBDIR=$(STAGING_DIR)/usr/lib/pkgconfig LIBDIR=/usr/lib INSTALL_LIB_DIR=/lib INSTALL_BIN_DIR=/bin RAW_VERSION=$(PKG_VERSION) HARDCO_HAL_DIR=$(STAGING_DIR)/usr/include CONFIG_GATEWAY=$(CONFIG_GATEWAY) CONFIG_ACCESSPOINT=$(CONFIG_ACCESSPOINT) CONFIG_SAH_LIB_MFG_RO_PART_FILE=$(CONFIG_SAH_LIB_MFG_RO_PART_FILE) CONFIG_SAH_LIB_MFG_RW_PART_FILE=$(CONFIG_SAH_LIB_MFG_RW_PART_FILE) CONFIG_SAH_LIB_MFG_SECURE_MFG_SUPPORT=$(CONFIG_SAH_LIB_MFG_SECURE_MFG_SUPPORT) CONFIG_SAH_LIB_MFG_PUBLIC_PEM_FILE=$(CONFIG_SAH_LIB_MFG_PUBLIC_PEM_FILE) CONFIG_SAH_LIB_MFG_GLOBAL_SIGNATURE=$(CONFIG_SAH_LIB_MFG_GLOBAL_SIGNATURE) CONFIG_SAH_LIB_MFG_GLOBAL_SIGNATURE_PUBLIC_PEM_FILE=$(CONFIG_SAH_LIB_MFG_GLOBAL_SIGNATURE_PUBLIC_PEM_FILE) CONFIG_SAH_LIB_MFG_GLOBAL_SIGNATURE_PADDING_MODE=$(CONFIG_SAH_LIB_MFG_GLOBAL_SIGNATURE_PADDING_MODE) CONFIG_SAH_LIB_MFG_SECURE_MFG_KERNEL_KEYRING_SUPPORT=$(CONFIG_SAH_LIB_MFG_SECURE_MFG_KERNEL_KEYRING_SUPPORT) CONFIG_SAH_LIB_MFG_SECURE_MFG_KERNEL_KEYRING_KEY_NAME=$(CONFIG_SAH_LIB_MFG_SECURE_MFG_KERNEL_KEYRING_KEY_NAME) CONFIG_SAH_LIB_MFG_SECURE_MFG_KERNEL_KEYRING_IV_FILE=$(CONFIG_SAH_LIB_MFG_SECURE_MFG_KERNEL_KEYRING_IV_FILE))
endef

define Package/$(PKG_NAME)/install
	$(CP) $(PKG_INSTALL_DIR)/* $(1)/
	if [ -d ./files ]; then \
		$(CP) ./files/* $(1)/; \
	fi
	find $(1) -name *.a -exec rm {} +;
	find $(1) -name *.h -exec rm {} +;
	find $(1) -name *.pc -exec rm {} +;
endef

define Package/$(PKG_NAME)/config
	source "$(SOURCE)/Config.in"
endef

$(eval $(call BuildPackage,$(PKG_NAME)))
